#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$APP_ROOT"

echo "== Resetting generated assets before pull =="
git checkout -- app/assets/builds/tailwind.css 2>/dev/null || true
rm -rf public/assets

echo "== Pulling latest code =="
git pull --ff-only origin main

echo "== Installing, migrating, and precompiling =="
bin/release

echo "== Restarting app =="
sudo systemctl restart removlo

echo "Deploy complete."
