#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir(APP_ROOT) do
  bundle_without = ENV.fetch("BUNDLE_WITHOUT", "development:test")

  puts "== Installing dependencies =="
  unless system({ "BUNDLE_WITHOUT" => bundle_without }, "bundle check")
    system!({ "BUNDLE_WITHOUT" => bundle_without }, "bundle install")
  end

  puts "== Preparing database =="
  system! "bin/rails db:prepare"

  puts "== Compiling assets =="
  system! "bin/rails assets:precompile"

  puts "== Generating sitemap =="
  system! "bin/rails sitemap:refresh"
end
