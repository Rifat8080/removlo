<% content_for :title, "About Removlo — Smart UK Removals with Human Support" %>
<% content_for :meta_description, "Learn about Removlo: a UK removals company combining transparent quotes, careful movers, live tracking, and dedicated support from quote to doorstep." %>

<main data-controller="reveal" class="relative flex-1 overflow-hidden bg-[#f7f9ff] text-slate-800">
  <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-[48rem] bg-[radial-gradient(circle_at_18%_20%,rgba(37,99,235,0.14),transparent_26%),radial-gradient(circle_at_80%_16%,rgba(124,58,237,0.13),transparent_28%),linear-gradient(180deg,#fbfdff_0%,#eef5ff_58%,#ffffff_100%)]"></div>

  <%= render "pages/marketing_hero",
    badge: "About us",
    title: "Moving made smarter, with people at the centre",
    subtitle: "Removlo blends intelligent logistics with real human support — so you always know what's happening and who's handling your move." %>

  <section class="relative z-10 px-4 pb-8 sm:px-6 lg:px-10 2xl:px-14">
    <div class="reveal mx-auto grid w-full max-w-[1600px] gap-6 lg:grid-cols-2">
      <div class="rounded-[2rem] border border-white/90 bg-white/85 p-6 shadow-[0_24px_80px_rgba(30,64,175,0.10)] ring-1 ring-blue-100/70 sm:p-8">
        <h2 class="text-xl font-black tracking-[-0.03em] text-slate-950 sm:text-2xl">Why Removlo?</h2>
        <p class="mt-4 text-sm font-medium leading-7 text-slate-600">
          We built Removlo because moving shouldn't feel like guesswork. Customers deserve clear pricing, responsive coordinators, and crews who treat belongings with care.
        </p>
        <p class="mt-4 text-sm font-medium leading-7 text-slate-600">
          Whether you're relocating a family home, an office floor, or need packing and storage in between, our platform keeps everyone aligned — with live updates when it matters most.
        </p>
        <div class="mt-6 grid grid-cols-2 gap-3">
          <% [["15K+", "Moves completed"], ["4.9/5", "Average rating"], ["50+", "Trained movers"], ["UK-wide", "Coverage"]].each do |stat, label| %>
            <div class="rounded-xl bg-slate-50 px-4 py-3 ring-1 ring-slate-100">
              <p class="text-lg font-black text-slate-950"><%= stat %></p>
              <p class="text-[11px] font-bold text-slate-500"><%= label %></p>
            </div>
          <% end %>
        </div>
      </div>

      <div class="rounded-[2rem] border border-white/90 bg-white/85 p-6 shadow-[0_24px_80px_rgba(30,64,175,0.10)] ring-1 ring-blue-100/70 sm:p-8">
        <h2 class="text-xl font-black tracking-[-0.03em] text-slate-950 sm:text-2xl">What we stand for</h2>
        <ul class="mt-5 space-y-4">
          <% [
            ["Transparency", "Quotes itemise crew, transport, and extras — no pressure, no surprises."],
            ["Care", "Trained movers, protection options, and notes for fragile or valuable items."],
            ["Communication", "A dedicated coordinator and live tracking when your move is underway."],
            ["Reliability", "Punctual crews, realistic timelines, and support if plans change."]
          ].each do |title, copy| %>
            <li class="rounded-xl border border-slate-100 bg-slate-50/70 px-4 py-3">
              <h3 class="text-sm font-black text-slate-950"><%= title %></h3>
              <p class="mt-1 text-sm font-medium text-slate-600"><%= copy %></p>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </section>

  <section id="team" class="relative z-10 px-4 pb-8 sm:px-6 lg:px-10 2xl:px-14">
    <div class="reveal mx-auto w-full max-w-[1600px] rounded-[2rem] border border-white/90 bg-white/85 p-6 shadow-[0_24px_80px_rgba(30,64,175,0.10)] ring-1 ring-blue-100/70 sm:p-8">
      <h2 class="text-xl font-black tracking-[-0.03em] text-slate-950 sm:text-2xl">Our team</h2>
      <p class="mt-3 max-w-3xl text-sm font-medium leading-7 text-slate-600">
        Removlo is powered by operations specialists, move coordinators, and professional crews across the UK. Every booking is supported by people who understand how stressful moving can be — and how much difference clear communication makes.
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        <% [["Operations", "Planning routes, crews, and timelines."], ["Customer support", "Quotes, updates, and move-day help."], ["Professional movers", "Careful loading, transport, and unloading."]].each do |title, copy| %>
          <div class="rounded-xl bg-blue-50/60 p-4 ring-1 ring-blue-100">
            <h3 class="text-sm font-black text-slate-950"><%= title %></h3>
            <p class="mt-2 text-xs font-semibold leading-5 text-slate-600"><%= copy %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%= render "pages/marketing_cta" %>
</main>

<%= render "shared/marketing_footer" %>
