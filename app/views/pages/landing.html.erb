<% service_cards = [
  ["Home Removals", "From flats to family homes, we move it all.", "home_removals_icon.svg", "home_removals_image.png"],
  ["Office Removals", "Minimise downtime with our efficient service.", "office_removals_icon.svg", "office_removals_image.png"],
  ["Packing Services", "Professional packing for a stress-free move.", "packing_services_icon.svg", "packing_services_image.png"],
  ["Storage Solutions", "Secure short or long-term storage options.", "storage_solutions_icon.svg", "storage_solutions_image.png"]
] %>
<% trust_logos = [
  ["Google", "Excellent 4.9", "google_logo_transparent.png"],
  ["Trustpilot", "5-star service", "trustpilot_logo_transparent.png"],
  ["feefo", "Verified reviews", "feefo_logo_transparent.png"],
  ["Which?", "Trusted mover", "which_logo_transparent.png"]
] %>
<% benefits = [
  ["Real-time tracking", "Know your route, ETA, and crew status.", "route-tracking.svg"],
  ["Dedicated support", "One friendly coordinator from quote to keys.", "headset-support.svg"],
  ["Care & protection", "Careful crews, insurance options, and item notes.", "shield-protection.svg"],
  ["Transparent pricing", "No surprises, no pressure, no hidden extras.", "price-receipt.svg"]
] %>
<% reviews = [
  ["Sarah T.", "London to Manchester", "Removlo made our move go from stressful to simple. The team was professional, careful, and friendly."],
  ["James R.", "Office relocation", "Clear quote, punctual crew, and great communication. We were working again the next morning."],
  ["Amina K.", "Packing and storage", "The packing team labelled everything beautifully and kept fragile items safe from start to finish."]
] %>
<% faqs = [
  ["How much does a home move cost?", "The price depends on distance, property size, access, packing, and storage needs. The quote form gives us what we need to prepare a clear estimate."],
  ["How far in advance should I book?", "Two to six weeks is ideal for most moves, but we can often help with shorter notice depending on crew availability."],
  ["What is included in the quote?", "Your quote itemises crew time, loading, transport, unloading, and any selected extras such as packing or storage."],
  ["Do you offer packing services?", "Yes. You can book full packing, fragile-only packing, materials, labelling, and inventory support."],
  ["Are my items insured?", "We explain protection options before booking so you can choose the level that fits your move."]
] %>
<% asset_image = ->(file) { "images/#{file}" } %>

<main data-controller="cursor-glow reveal" class="relative flex-1 overflow-hidden bg-[#f7f9ff] text-slate-800">
  <div class="cursor-glow pointer-events-none fixed inset-0 z-0 opacity-40"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-[48rem] bg-[radial-gradient(circle_at_18%_20%,rgba(37,99,235,0.14),transparent_26%),radial-gradient(circle_at_80%_16%,rgba(124,58,237,0.13),transparent_28%),linear-gradient(180deg,#fbfdff_0%,#eef5ff_58%,#ffffff_100%)]"></div>
  <div class="pointer-events-none absolute left-1/2 top-28 z-0 h-[38rem] w-[58rem] -translate-x-1/2 rounded-full bg-blue-200/25 blur-3xl"></div>

  <section class="relative isolate z-10 overflow-hidden px-3 pb-7 pt-28 min-[380px]:px-4 sm:px-6 sm:pt-28 min-[1360px]:pt-32 lg:px-8">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(37,99,235,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(37,99,235,0.055)_1px,transparent_1px)] bg-[size:3rem_3rem]"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_45%_24%,rgba(96,165,250,0.16),transparent_34%),radial-gradient(circle_at_78%_22%,rgba(124,58,237,0.10),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.30),rgba(239,246,255,0.25)_55%,rgba(255,255,255,0.65))]"></div>
    <div class="mx-auto max-w-[1320px]">
      <div class="reveal relative">
        <div class="pointer-events-none absolute -inset-x-8 -inset-y-10 bg-[radial-gradient(circle_at_45%_24%,rgba(96,165,250,0.22),transparent_32%),radial-gradient(circle_at_78%_22%,rgba(124,58,237,0.12),transparent_32%),linear-gradient(180deg,rgba(255,255,255,0.45),rgba(239,246,255,0.35)_55%,rgba(255,255,255,0.35))]"></div>
        <div class="pointer-events-none absolute -top-12 -bottom-12 left-[22%] right-[13%] hidden min-[1360px]:block">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_52%_54%,rgba(96,165,250,0.16),transparent_48%)]"></div>
          <%= image_tag asset_image.call("van.png"), alt: "", class: "absolute inset-0 h-full w-full object-cover object-center opacity-90 contrast-105 saturate-105 [mask-image:radial-gradient(ellipse_at_center,black_34%,rgba(0,0,0,0.72)_54%,transparent_76%)]", aria: { hidden: true } %>
        </div>

        <div class="relative grid min-w-0 gap-6 sm:gap-7 min-[1360px]:min-h-[31rem] min-[1360px]:grid-cols-[minmax(21rem,0.95fr)_minmax(31rem,1.1fr)_minmax(22rem,0.92fr)] min-[1360px]:items-center">
          <div class="relative isolate z-20 min-w-0 overflow-hidden pb-4 sm:pb-6 min-[1360px]:overflow-visible min-[1360px]:pb-0">
            <%= image_tag asset_image.call("van.png"), alt: "", class: "pointer-events-none absolute -right-16 top-12 -z-10 h-52 w-[105%] object-contain object-right-bottom opacity-30 mix-blend-multiply contrast-105 saturate-105 [mask-image:linear-gradient(to_left,black_0%,rgba(0,0,0,0.72)_46%,transparent_100%)] min-[380px]:top-10 min-[380px]:h-60 sm:-right-24 sm:top-0 sm:h-[24rem] sm:w-[82%] sm:opacity-40 md:w-[72%] min-[1360px]:hidden", aria: { hidden: true } %>
            <div class="inline-flex max-w-full items-center gap-1.5 rounded-full border border-slate-200/80 bg-white/90 px-2.5 py-1.5 text-[8px] font-black uppercase tracking-[0.13em] text-slate-700 shadow-sm shadow-blue-950/5 backdrop-blur min-[380px]:gap-2 min-[380px]:px-3 min-[380px]:text-[10px]">
              <%= image_tag asset_image.call("route-pin.svg"), alt: "", class: "h-3.5 w-3.5 shrink-0 min-[380px]:h-4 min-[380px]:w-4", aria: { hidden: true } %>
              UK's smartest way to move
            </div>

            <h1 class="mt-4 max-w-2xl text-[2.05rem] font-black leading-[0.98] tracking-[-0.055em] text-slate-950 min-[380px]:text-[2.35rem] min-[420px]:text-[2.6rem] sm:text-[3.2rem] xl:text-[3.95rem]">
              <span class="sm:whitespace-nowrap">Moving home,</span> <span class="relative inline-block bg-gradient-to-r from-blue-700 via-indigo-600 to-violet-600 bg-clip-text pb-3 text-transparent">made smart<svg class="absolute -bottom-0.5 left-0 h-3 w-full text-blue-600" viewBox="0 0 280 18" fill="none" preserveAspectRatio="none" aria-hidden="true"><path d="M4 13C64 4 204 4 276 12" stroke="currentColor" stroke-width="5" stroke-linecap="round"/></svg></span>
            </h1>
            <p class="mt-3 max-w-md text-[13px] font-medium leading-6 text-slate-600 sm:text-[0.95rem] sm:leading-7">
              Removlo blends intelligent logistics with real human support. Get a transparent quote, track your move live, and relax knowing your move is in safe hands.
            </p>

            <div class="mt-4 flex flex-wrap gap-x-3 gap-y-2 sm:mt-5 sm:gap-x-5">
              <% [["Fully insured", "shield-protection.svg"], ["No hidden fees", "price-receipt.svg"], ["UK-wide coverage", "route-pin.svg"]].each do |label, icon| %>
                <div class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-600 sm:gap-2 sm:text-xs">
                  <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-blue-600 sm:h-5 sm:w-5">
                    <%= image_tag asset_image.call(icon), alt: "", class: "h-2.5 w-2.5 brightness-0 invert sm:h-3 sm:w-3", aria: { hidden: true } %>
                  </span>
                  <%= label %>
                </div>
              <% end %>
            </div>

            <div class="mt-5 flex flex-col gap-2.5 min-[380px]:gap-3 sm:flex-row sm:items-center">
              <% if user_signed_in? %>
                <%= link_to current_user.customer? ? new_quotation_path : dashboard_path, class: "soft-shine inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 px-4 py-3 text-[11px] font-black text-white shadow-xl shadow-blue-600/25 transition hover:-translate-y-0.5 hover:shadow-2xl focus:outline-none focus:ring-4 focus:ring-blue-200 sm:px-5 sm:text-xs" do %>
                  <%= current_user.customer? ? "Start your free quote" : "Open dashboard" %>
                  <%= image_tag asset_image.call("arrow-right.svg"), alt: "", class: "h-4 w-4 brightness-0 invert", aria: { hidden: true } %>
                <% end %>
              <% else %>
                <%= link_to "#quote", class: "soft-shine inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 px-4 py-3 text-[11px] font-black text-white shadow-xl shadow-blue-600/25 transition hover:-translate-y-0.5 hover:shadow-2xl focus:outline-none focus:ring-4 focus:ring-blue-200 sm:px-5 sm:text-xs" do %>
                  Get your free quote
                  <%= image_tag asset_image.call("arrow-right.svg"), alt: "", class: "h-4 w-4 brightness-0 invert", aria: { hidden: true } %>
                <% end %>
              <% end %>
              <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white/90 px-4 py-3 text-[11px] font-black text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-blue-200 hover:text-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-100 sm:px-5 sm:text-xs">
                See how it works
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M8 5v14l11-7z"/></svg>
              </a>
            </div>

            <div class="relative mt-4 max-w-full overflow-hidden rounded-2xl border border-white/80 bg-white/75 p-1.5 shadow-lg shadow-blue-950/5 backdrop-blur-xl sm:max-w-md sm:p-2">
              <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-10 bg-gradient-to-r from-white to-transparent"></div>
              <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-10 bg-gradient-to-l from-white to-transparent"></div>
              <div class="route-marquee flex w-max items-center gap-2">
                <% (["London to Leeds", "Bristol to Bath", "Cardiff to Swansea", "Edinburgh to Glasgow"] * 2).each do |route| %>
                  <span class="inline-flex items-center gap-2 rounded-xl bg-white px-2.5 py-2 text-[10px] font-black text-slate-600 shadow-sm ring-1 ring-slate-100 sm:px-3 sm:text-[11px]">
                    <span class="h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_0_4px_rgba(52,211,153,0.12)]"></span>
                    <%= route %>
                  </span>
                <% end %>
              </div>
            </div>

            <div class="mt-5 flex flex-col gap-3 sm:mt-6 sm:flex-row sm:items-center sm:gap-4">
              <div class="flex -space-x-3">
                <% ["SM", "JR", "AK", "OP"].each_with_index do |initials, index| %>
                  <span class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-gradient-to-br <%= index.even? ? 'from-blue-600 to-indigo-600' : 'from-violet-600 to-fuchsia-600' %> text-[9px] font-black text-white shadow-md sm:h-9 sm:w-9 sm:text-[10px]"><%= initials %></span>
                <% end %>
              </div>
              <div>
                <p class="text-xs font-bold text-slate-500">Trusted by thousands across the UK</p>
                <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1">
                  <span class="text-sm font-black text-slate-950">4.9/5</span>
                  <span class="flex text-amber-400" aria-label="Five star rating"><% 5.times do %><svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.36 1.12l1.07 3.29c.3.92-.76 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.18 0l-2.8 2.03c-.78.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12l-2.8-2.03c-.78-.57-.38-1.81.59-1.81h3.46a1 1 0 00.95-.69l1.07-3.29z"/></svg><% end %></span>
                  <span class="text-xs font-bold text-emerald-600">Trustpilot</span>
                </div>
              </div>
            </div>
          </div>

          <div class="relative z-10 hidden min-h-[14rem] min-[380px]:min-h-[16rem] sm:min-h-[25rem] min-[1360px]:block min-[1360px]:min-h-[30rem]">
            <div class="relative isolate h-full min-h-[14rem] min-[380px]:min-h-[16rem] sm:min-h-[25rem] min-[1360px]:min-h-[30rem]">

              <div class="float-slower absolute left-1/2 top-8 hidden -translate-x-1/2 items-center gap-2 rounded-2xl border border-white/80 bg-white/92 px-3.5 py-2.5 shadow-xl shadow-blue-950/10 backdrop-blur-xl sm:flex">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-blue-50">
                  <%= image_tag asset_image.call("route-pin.svg"), alt: "", class: "h-5 w-5", aria: { hidden: true } %>
                </span>
                <span>
                  <span class="block text-[9px] font-black uppercase tracking-wide text-slate-400">Live tracking</span>
                  <span class="block text-xs font-black text-slate-950">London to Leeds <span class="ml-1 text-emerald-600">In progress</span></span>
                </span>
              </div>

              <div class="float-slow absolute left-5 top-16 hidden rounded-2xl border border-white/80 bg-white/90 p-3 shadow-xl shadow-blue-950/10 backdrop-blur-xl sm:block">
                <p class="text-[9px] font-black uppercase tracking-wide text-slate-400">Crew ETA</p>
                <p class="mt-1 text-xs font-black text-slate-950">08:30 AM</p>
                <p class="mt-0.5 text-[10px] font-bold text-emerald-600">Today</p>
              </div>
              <div class="absolute bottom-10 left-8 hidden items-center gap-2 rounded-2xl border border-white/80 bg-white/90 px-3 py-2 shadow-xl shadow-blue-950/10 backdrop-blur-xl min-[1360px]:flex">
                <span class="flex h-7 w-7 items-center justify-center rounded-xl bg-emerald-50">
                  <%= image_tag asset_image.call("shield-protection.svg"), alt: "", class: "h-4 w-4", aria: { hidden: true } %>
                </span>
                <span>
                  <span class="block text-[9px] font-black uppercase tracking-wide text-slate-400">Protected move</span>
                  <span class="block text-[10px] font-bold text-slate-700">Fully insured</span>
                </span>
              </div>
            </div>
          </div>

          <aside id="quote" class="relative z-20 rounded-[1.25rem] border border-white/85 bg-white/95 p-4 shadow-[0_24px_70px_rgba(30,64,175,0.16)] ring-1 ring-blue-100/80 backdrop-blur-2xl sm:rounded-[1.5rem] sm:p-6">
            <div class="flex items-start justify-between gap-3 sm:gap-4">
              <div class="min-w-0">
                <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1.5 text-[9px] font-black uppercase tracking-[0.16em] text-blue-700">
                  <%= image_tag asset_image.call("quote-document.svg"), alt: "", class: "h-4 w-4", aria: { hidden: true } %>
                  2-min instant quote
                </span>
                <h2 class="mt-4 text-xl font-black tracking-[-0.03em] text-slate-950 sm:text-2xl">Get your quick quote</h2>
                <p class="mt-1 text-xs font-semibold text-slate-500">Tell us the basics and we will shape the plan.</p>
              </div>
              <div class="shrink-0 rounded-2xl bg-gradient-to-br from-blue-600 to-violet-600 p-2.5 shadow-lg shadow-blue-600/25 sm:p-3">
                <%= image_tag asset_image.call("price-receipt.svg"), alt: "", class: "h-5 w-5 brightness-0 invert sm:h-6 sm:w-6", aria: { hidden: true } %>
              </div>
            </div>

            <%= form_with scope: :quotation, url: quotations_path, method: :post, local: true, class: "mt-5 space-y-4" do |f| %>
              <% field_class = "block w-full rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-3 text-sm font-semibold text-slate-900 placeholder-slate-400 shadow-sm transition focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-100 sm:px-4" %>
              <% label_class = "mb-1.5 block text-[10px] font-black uppercase tracking-wide text-slate-500" %>

              <% unless user_signed_in? %>
                <div>
                  <%= f.label :customer_email, "Email address", class: label_class %>
                  <%= f.email_field :customer_email, required: true, autocomplete: "email", placeholder: "you@example.com", class: field_class %>
                </div>
              <% end %>

              <div class="grid gap-3 sm:grid-cols-2 min-[1360px]:grid-cols-1 2xl:grid-cols-2">
                <div>
                  <%= f.label :pickup_postcode, "From", class: label_class %>
                  <%= f.text_field :pickup_postcode, required: true, placeholder: "SW1A 1AA", class: field_class %>
                </div>
                <div>
                  <%= f.label :delivery_postcode, "To", class: label_class %>
                  <%= f.text_field :delivery_postcode, required: true, placeholder: "M1 1AD", class: field_class %>
                </div>
              </div>

              <div class="grid gap-3 sm:grid-cols-2 min-[1360px]:grid-cols-1 2xl:grid-cols-2">
                <div>
                  <%= f.label :move_size, "Move size", class: label_class %>
                  <%= f.select :move_size, [["Select size", ""], ["Studio", "studio"], ["1 bedroom", "one_bed"], ["2 bedrooms", "two_bed"], ["3 bedrooms", "three_bed"], ["4+ bedrooms", "four_plus"], ["Office / commercial", "office"]], {}, class: field_class %>
                </div>
                <div>
                  <%= f.label :preferred_move_date, "Move date", class: label_class %>
                  <%= f.date_field :preferred_move_date, class: field_class %>
                </div>
              </div>

              <div>
                <%= f.label :customer_notes, "Additional services", class: label_class %>
                <%= f.text_field :customer_notes, placeholder: "Packing, storage, fragile items...", class: field_class %>
              </div>

              <%= f.hidden_field :service_level, value: "standard" %>
              <%= f.submit "Get my instant quote", class: "w-full cursor-pointer rounded-xl bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600 px-4 py-3.5 text-sm font-black text-white shadow-xl shadow-blue-600/25 transition hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-blue-600/30 focus:outline-none focus:ring-4 focus:ring-blue-200 sm:px-6" %>
              <p class="text-center text-[11px] font-semibold text-slate-500">No obligation. Response within 24 hours.</p>
            <% end %>
          </aside>
        </div>
      </div>

      <div class="reveal mt-6 grid gap-4 lg:grid-cols-[0.74fr_1fr]">
        <div class="rounded-[1.5rem] border border-white bg-white/90 p-4 shadow-xl shadow-blue-950/5 backdrop-blur sm:p-5">
          <p class="text-center text-[9px] font-black uppercase tracking-[0.18em] text-slate-400 sm:text-left sm:text-[10px]">Trusted by thousands across the UK</p>
          <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-4">
            <% trust_logos.each do |name, rating, logo| %>
              <div class="rounded-2xl bg-slate-50/70 p-3 text-center ring-1 ring-slate-100 transition hover:-translate-y-0.5 hover:bg-white hover:shadow-md hover:shadow-blue-950/5 min-[1360px]:rounded-none min-[1360px]:bg-transparent min-[1360px]:p-0 min-[1360px]:text-left min-[1360px]:ring-0 min-[1360px]:border-r min-[1360px]:border-slate-100 min-[1360px]:last:border-r-0">
                <%= image_tag asset_image.call(logo), alt: "#{name} logo", class: "mx-auto h-5 w-auto object-contain sm:h-6 lg:mx-0" %>
                <div class="mt-1.5 flex justify-center text-amber-400 min-[1360px]:justify-start" aria-hidden="true"><% 5.times do %><svg class="h-3 w-3 sm:h-3.5 sm:w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.36 1.12l1.07 3.29c.3.92-.76 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.18 0l-2.8 2.03c-.78.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12l-2.8-2.03c-.78-.57-.38-1.81.59-1.81h3.46a1 1 0 00.95-.69l1.07-3.29z"/></svg><% end %></div>
                <p class="mt-1 text-[9px] font-bold uppercase tracking-wide text-slate-400 sm:text-[10px]"><%= rating %></p>
              </div>
            <% end %>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 rounded-[1.5rem] border border-white bg-white/90 p-4 shadow-xl shadow-blue-950/5 backdrop-blur sm:grid-cols-4 lg:grid-cols-4">
          <% [["15K+", "Moves completed", "users-customers.svg"], ["4.9/5", "Average rating", "rating-star.svg"], ["50+", "Trained movers", "shield-protection.svg"], ["20+", "UK locations", "location-contact.svg"]].each do |stat, label, icon| %>
            <div class="flex flex-col items-center justify-center gap-2 rounded-2xl bg-slate-50/70 px-2 py-3 text-center ring-1 ring-slate-100 sm:bg-transparent sm:ring-0 min-[1360px]:flex-row min-[1360px]:justify-start min-[1360px]:gap-3 min-[1360px]:text-left min-[1360px]:border-r min-[1360px]:border-slate-100 min-[1360px]:last:border-r-0">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-2xl bg-blue-50 sm:h-10 sm:w-10">
                <%= image_tag asset_image.call(icon), alt: "", class: "h-5 w-5 sm:h-6 sm:w-6", aria: { hidden: true } %>
              </span>
              <span>
                <span class="block text-lg font-black tracking-tight text-slate-950 sm:text-xl"><%= stat %></span>
                <span class="block text-[10px] font-bold text-slate-500 sm:text-[11px]"><%= label %></span>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section id="services" class="relative z-10 px-4 py-7 sm:px-6 sm:py-9 lg:px-8">
    <div class="mx-auto max-w-[1320px]">
      <div class="reveal rounded-[2rem] border border-white/90 bg-white/80 p-4 shadow-[0_24px_80px_rgba(30,64,175,0.10)] ring-1 ring-blue-100/70 backdrop-blur-xl sm:p-6 lg:p-7">
        <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
          <div>
            <h2 class="text-2xl font-black tracking-[-0.04em] text-slate-950 sm:text-3xl">Our services</h2>
          </div>
          <a href="#quote" class="inline-flex items-center gap-2 text-xs font-black text-blue-700 sm:text-sm">
            View all services
            <%= image_tag asset_image.call("arrow-right.svg"), alt: "", class: "h-4 w-4", aria: { hidden: true } %>
          </a>
        </div>

        <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
