          <div class="flex gap-4 justify-center flex-wrap">
            <% if user_signed_in? %>
              <%= link_to "Go to Dashboard", dashboard_path, class: "inline-flex items-center rounded-lg bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 font-semibold shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300" %>
            <% else %>
              <%= link_to "Get Your Free Quote", new_user_registration_path, class: "inline-flex items-center rounded-lg bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 font-semibold shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300" %>
              <%= link_to "Sign In", new_user_session_path, class: "inline-flex items-center rounded-lg border-2 border-blue-600 text-blue-600 hover:bg-blue-50 px-8 py-3 font-semibold transition-all duration-300" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
