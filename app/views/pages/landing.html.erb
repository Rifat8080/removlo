      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Our Services</h2>
        <p class="text-xl text-gray-600">Comprehensive solutions for every stage of your move</p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <div class="relative group overflow-hidden rounded-xl">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-100 to-blue-50 opacity-0 group-hover:opacity-100 transition duration-500"></div>
          <div class="relative p-8 bg-white border border-blue-100 rounded-xl hover:border-blue-200 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-blue-100 flex items-center justify-center mb-4">
