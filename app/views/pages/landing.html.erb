<footer class="relative z-10 overflow-hidden bg-[#eef4ff]">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-48 bg-[radial-gradient(circle_at_18%_20%,rgba(37,99,235,0.14),transparent_30%),radial-gradient(circle_at_82%_18%,rgba(124,58,237,0.12),transparent_32%)]"></div>
  <div class="relative mx-auto w-full max-w-[1600px] px-4 py-8 sm:px-6 lg:px-10 lg:py-10 2xl:px-14">
    <div class="rounded-[2rem] border border-white/90 bg-white/72 p-5 shadow-[0_24px_80px_rgba(30,64,175,0.10)] ring-1 ring-blue-100/70 backdrop-blur-xl sm:p-7 lg:p-8">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_2.8fr] lg:items-start xl:grid-cols-[1.05fr_3fr]">
      <div class="max-w-md">
        <%= link_to root_path, class: "group flex items-center" do %>
          <%= image_tag asset_image.call("logo.png"), alt: "Removlo - Moving Made Simple", class: "h-auto w-44 transition duration-300 group-hover:-translate-y-0.5 sm:w-56" %>
        <% end %>
        <p class="mt-4 max-w-sm text-sm font-semibold leading-6 text-slate-500">
          Intelligent logistics, careful movers, live updates, and human support from quote to doorstep.
        </p>
        <a href="#quote" class="mt-5 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 px-4 py-2.5 text-xs font-black text-white shadow-lg shadow-blue-600/25 transition hover:-translate-y-0.5 hover:shadow-xl">
          Get a quote
          <%= image_tag asset_image.call("arrow-right.svg"), alt: "", class: "h-4 w-4 brightness-0 invert", aria: { hidden: true } %>
        </a>
      </div>

      <div class="grid grid-cols-2 gap-x-8 gap-y-9 sm:grid-cols-3 lg:grid-cols-5 xl:gap-x-12">
        <% [["Services", ["Home Removals", "Office Removals", "Packing Services", "Storage Solutions"]], ["Company", ["About us", "Why Removlo?", "Our team", "Careers"]], ["Support", ["Contact us", "Help centre", "FAQs", "Moving guides"]], ["Resources", ["Moving checklist", "Packing tips", "Storage guide", "Blog"]], ["Contact", ["020 7946 0958", "hello@removlo.com", "UK-wide coverage", "Mon-Fri, 8am-8pm"]]].each do |heading, links| %>
          <div>
            <h2 class="mb-5 text-xs font-black uppercase tracking-[0.18em] text-slate-950"><%= heading %></h2>
            <ul class="font-semibold text-slate-500">
              <% links.each do |label| %>
                <li class="mb-4 last:mb-0">
                  <a href="#" class="transition hover:text-blue-700 hover:underline"><%= label %></a>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </div>

    <hr class="my-6 border-blue-100 sm:mx-auto lg:my-8" />

    <div class="sm:flex sm:items-center sm:justify-between">
      <span class="text-sm font-semibold text-slate-500 sm:text-center">
        © <%= Time.current.year %> <%= link_to "Removlo Ltd", root_path, class: "hover:text-blue-700 hover:underline" %>. All Rights Reserved.
      </span>

      <div class="mt-4 flex sm:mt-0 sm:justify-center">
        <a href="#" class="text-slate-500 transition hover:-translate-y-0.5 hover:text-blue-700">
          <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M13.135 6H15V3h-1.865a4.147 4.147 0 0 0-4.142 4.142V9H7v3h2v9.938h3V12h2.021l.592-3H12V6.591A.6.6 0 0 1 12.592 6h.543Z" clip-rule="evenodd"/></svg>
          <span class="sr-only">Facebook page</span>
        </a>
        <a href="#" class="ms-5 text-slate-500 transition hover:-translate-y-0.5 hover:text-blue-700">
          <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M18.942 5.556a16.3 16.3 0 0 0-4.126-1.3 12.04 12.04 0 0 0-.529 1.1 15.175 15.175 0 0 0-4.573 0 11.586 11.586 0 0 0-.535-1.1 16.274 16.274 0 0 0-4.129 1.3 17.392 17.392 0 0 0-2.868 11.662 15.785 15.785 0 0 0 4.963 2.521c.41-.564.773-1.16 1.084-1.785a10.638 10.638 0 0 1-1.706-.83c.143-.106.283-.217.418-.331a11.664 11.664 0 0 0 10.118 0c.137.114.277.225.418.331-.544.328-1.116.606-1.71.832a12.58 12.58 0 0 0 1.084 1.785 16.46 16.46 0 0 0 5.064-2.595 17.286 17.286 0 0 0-2.973-11.59ZM8.678 14.813a1.94 1.94 0 0 1-1.8-2.045 1.93 1.93 0 0 1 1.8-2.047 1.918 1.918 0 0 1 1.8 2.047 1.929 1.929 0 0 1-1.8 2.045Zm6.644 0a1.94 1.94 0 0 1-1.8-2.045 1.93 1.93 0 0 1 1.8-2.047 1.919 1.919 0 0 1 1.8 2.047 1.93 1.93 0 0 1-1.8 2.045Z"/></svg>
          <span class="sr-only">Discord community</span>
        </a>
        <a href="#" class="ms-5 text-slate-500 transition hover:-translate-y-0.5 hover:text-blue-700">
          <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M13.795 10.533 20.68 2h-3.073l-5.255 6.517L7.69 2H1l7.806 10.91L1.47 22h3.074l5.705-7.07L15.31 22H22l-8.205-11.467Zm-2.38 2.95L9.97 11.464 4.36 3.627h2.31l4.528 6.317 1.443 2.02 6.018 8.409h-2.31l-4.934-6.89Z"/></svg>
          <span class="sr-only">Twitter page</span>
        </a>
        <a href="#" class="ms-5 text-slate-500 transition hover:-translate-y-0.5 hover:text-blue-700">
          <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.006 2a9.847 9.847 0 0 0-6.484 2.44 10.32 10.32 0 0 0-3.393 6.17 10.48 10.48 0 0 0 1.317 6.955 10.045 10.045 0 0 0 5.4 4.418c.504.095.683-.223.683-.494 0-.245-.01-1.052-.014-1.908-2.78.62-3.366-1.21-3.366-1.21a2.711 2.711 0 0 0-1.11-1.5c-.907-.637.07-.621.07-.621.317.044.62.163.885.346.266.183.487.426.647.71.135.253.318.476.538.655a2.079 2.079 0 0 0 2.37.196c.045-.52.27-1.006.635-1.37-2.219-.259-4.554-1.138-4.554-5.07a4.022 4.022 0 0 1 1.031-2.75 3.77 3.77 0 0 1 .096-2.713s.839-.275 2.749 1.05a9.26 9.26 0 0 1 5.004 0c1.906-1.325 2.74-1.05 2.74-1.05.37.858.406 1.828.101 2.713a4.017 4.017 0 0 1 1.029 2.75c0 3.939-2.339 4.805-4.564 5.058a2.471 2.471 0 0 1 .679 1.897c0 1.372-.012 2.477-.012 2.814 0 .272.18.592.687.492a10.05 10.05 0 0 0 5.388-4.421 10.473 10.473 0 0 0 1.313-6.948 10.32 10.32 0 0 0-3.39-6.165A9.847 9.847 0 0 0 12.007 2Z" clip-rule="evenodd"/></svg>
          <span class="sr-only">GitHub account</span>
        </a>
        <a href="#" class="ms-5 text-slate-500 transition hover:-translate-y-0.5 hover:text-blue-700">
          <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2a10 10 0 1 0 10 10A10.009 10.009 0 0 0 12 2Zm6.613 4.614a8.523 8.523 0 0 1 1.93 5.32 20.093 20.093 0 0 0-5.949-.274c-.059-.149-.122-.292-.184-.441a23.879 23.879 0 0 0-.566-1.239 11.41 11.41 0 0 0 4.769-3.366ZM10 3.707a8.82 8.82 0 0 1 2-.238 8.5 8.5 0 0 1 5.664 2.152 9.608 9.608 0 0 1-4.476 3.087A45.755 45.755 0 0 0 10 3.707Zm-6.358 6.555a8.57 8.57 0 0 1 4.73-5.981 53.99 53.99 0 0 1 3.168 4.941 32.078 32.078 0 0 1-7.9 1.04h.002Zm2.01 7.46a8.51 8.51 0 0 1-2.2-5.707v-.262a31.641 31.641 0 0 0 8.777-1.219c.243.477.477.964.692 1.449-.114.032-.227.067-.336.1a13.569 13.569 0 0 0-6.942 5.636l.009.003ZM12 20.556a8.508 8.508 0 0 1-5.243-1.8 11.717 11.717 0 0 1 6.7-5.332.509.509 0 0 1 .055-.02 35.65 35.65 0 0 1 1.819 6.476 8.476 8.476 0 0 1-3.331.676Zm4.772-1.462A37.232 37.232 0 0 0 15.113 13a12.513 12.513 0 0 1 5.321.364 8.56 8.56 0 0 1-3.66 5.73h-.002Z" clip-rule="evenodd"/></svg>
          <span class="sr-only">Dribbble account</span>
        </a>
      </div>
    </div>
    </div>
  </div>
</footer>
