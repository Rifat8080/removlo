<!-- Modern Blue Header -->
<header class="relative overflow-hidden bg-gradient-to-r from-blue-900 via-blue-800 to-blue-900 shadow-2xl">
  <!-- Animated background elements - Blue only -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-15 animate-blob"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-300 rounded-full mix-blend-multiply filter blur-3xl opacity-15 animate-blob animation-delay-2000"></div>
    <div class="absolute top-1/2 left-1/2 w-96 h-96 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-4000"></div>
  </div>

  <div class="relative mx-auto max-w-7xl py-12 px-4 sm:px-6 lg:flex lg:items-center lg:justify-between lg:py-24 lg:px-8">
    <div class="flex flex-col">
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-white mb-3">Removlo</h1>
      <p class="text-xl text-blue-100 font-light">UK Relocation Specialists</p>
      <p class="mt-3 text-base text-blue-200 max-w-lg">Experience seamless, professional relocation services tailored to your unique needs</p>
    </div>

    <div class="mt-10 flex gap-4 lg:mt-0 lg:flex-shrink-0">
      <% if user_signed_in? %>
        <%= link_to "Dashboard", dashboard_path, class: "inline-flex items-center justify-center rounded-lg bg-blue-500 hover:bg-blue-600 px-8 py-4 text-base font-semibold text-white shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300" %>
      <% else %>
        <%= link_to "Get Started", new_user_registration_path, class: "inline-flex items-center justify-center rounded-lg bg-blue-500 hover:bg-blue-600 px-8 py-4 text-base font-semibold text-white shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300" %>
      <% end %>
      <% unless user_signed_in? %>
        <%= link_to "Sign in", new_user_session_path, class: "inline-flex items-center justify-center rounded-lg border-2 border-white bg-white/10 px-8 py-4 text-base font-semibold text-white backdrop-blur-sm hover:bg-white/20 transition-all duration-300" %>
      <% end %>
    </div>
  </div>
</header>

<main class="bg-gradient-to-b from-slate-50 via-blue-50 to-slate-50">
  <!-- Hero Section with Quote Form -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
      <!-- Left Column -->
      <div class="flex flex-col justify-center">
        <div class="inline-flex items-center rounded-full bg-blue-100 px-4 py-2 w-fit">
          <span class="text-sm font-semibold text-blue-700">✓ Trusted by Thousands</span>
        </div>

        <h2 class="mt-6 text-5xl font-bold tracking-tight text-gray-900 sm:text-5xl leading-tight">
          Moving Made <span class="text-blue-600">Simple & Stress-Free</span>
        </h2>
        
        <p class="mt-6 text-xl text-gray-600 leading-relaxed">From packing and transport to settling-in services and visa guidance, Removlo delivers comprehensive relocation support tailored to your needs.</p>

        <!-- Feature List -->
        <ul class="mt-10 space-y-4">
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-500 flex items-center justify-center mt-1">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">UK-wide Coverage</h3>
              <p class="text-gray-600 text-sm mt-1">Local teams across the UK ensuring smooth, compliant moves</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-500 flex items-center justify-center mt-1">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Dedicated Support</h3>
              <p class="text-gray-600 text-sm mt-1">Single point of contact for logistics and communications</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-500 flex items-center justify-center mt-1">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">End-to-End Services</h3>
              <p class="text-gray-600 text-sm mt-1">Packing, customs, storage, and settling-in assistance included</p>
            </div>
          </li>
        </ul>

        <div class="mt-10">
          <% if user_signed_in? %>
            <%= link_to "Open Dashboard", dashboard_path, class: "inline-flex items-center rounded-lg bg-blue-600 hover:bg-blue-700 px-8 py-3 text-white font-semibold shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300" %>
          <% else %>
            <%= link_to "Request a Quote", new_user_registration_path, class: "inline-flex items-center rounded-lg bg-blue-600 hover:bg-blue-700 px-8 py-3 text-white font-semibold shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300" %>
          <% end %>
        </div>
      </div>

      <!-- Right Column - Quote Form -->
      <div class="mt-14 lg:mt-0">
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-200 to-blue-100 rounded-2xl blur-lg opacity-40 group-hover:opacity-60 transition duration-500"></div>
          
          <div class="relative bg-white rounded-2xl px-8 py-10 shadow-2xl border border-blue-100 hover:border-blue-200 transition-all duration-300">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-gray-900">Quick Quote</h3>
                <p class="text-sm text-gray-600">Get a cost estimate in minutes</p>
              </div>
            </div>

            <%= form_with url: '#', method: :get, local: true, class: "space-y-5" do |f| %>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">From (postcode)</label>
                <%= f.text_field :from_postcode, placeholder: "e.g. SW1A 1AA", class: "w-full rounded-lg border border-blue-200 px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-all" %>
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">To (postcode)</label>
                <%= f.text_field :to_postcode, placeholder: "e.g. M1 1AD", class: "w-full rounded-lg border border-blue-200 px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-all" %>
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Move Size</label>
                <%= f.select :size, [['Studio','studio'], ['1 Bedroom','1bed'], ['2 Bedrooms','2bed'], ['3+ Bedrooms','3plus']], {}, class: "w-full rounded-lg border border-blue-200 px-4 py-3 text-gray-900 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-all appearance-none cursor-pointer" %>
              </div>
              <div>
                <%= f.submit "Get Estimate", class: "w-full mt-6 inline-flex justify-center items-center rounded-lg bg-blue-600 hover:bg-blue-700 px-6 py-3 text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-300 cursor-pointer" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">How It Works</h2>
        <p class="text-xl text-gray-600">Simple, transparent, and stress-free relocation process</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center relative">
          <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Get a Quote</h3>
          <p class="mt-2 text-gray-600 text-sm">Enter your details and get an instant cost estimate</p>
          <div class="hidden lg:block absolute top-20 right-0 w-20 h-1 bg-gradient-to-r from-blue-300 to-transparent"></div>
        </div>

        <div class="text-center relative">
          <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Plan & Book</h3>
