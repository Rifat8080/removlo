<% content_for :title, "Get a Quotation - Removlo UK Removals" %>
<% content_for :meta_description, "Request a Removlo quotation for home removals, office moves, packing, and storage. Share your move details and get a clear response from our team." %>

<main data-controller="reveal" class="relative flex-1 overflow-hidden bg-[#f7f9ff] text-slate-800">
  <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-[52rem] bg-[radial-gradient(circle_at_18%_20%,rgba(37,99,235,0.16),transparent_28%),radial-gradient(circle_at_84%_18%,rgba(124,58,237,0.14),transparent_30%),linear-gradient(180deg,#fbfdff_0%,#eef5ff_58%,#ffffff_100%)]"></div>
  <div class="pointer-events-none absolute left-1/2 top-28 z-0 h-[38rem] w-[58rem] -translate-x-1/2 rounded-full bg-blue-200/25 blur-3xl"></div>

  <section class="relative isolate z-10 overflow-hidden px-4 pb-8 pt-28 sm:px-6 sm:pt-28 min-[1360px]:pt-32 lg:px-10 2xl:px-14">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(37,99,235,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(37,99,235,0.055)_1px,transparent_1px)] bg-[size:3rem_3rem]"></div>

    <div class="mx-auto grid w-full max-w-[1600px] gap-6 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
      <div class="reveal rounded-[2rem] border border-white/90 bg-white/82 p-6 shadow-[0_24px_80px_rgba(30,64,175,0.10)] ring-1 ring-blue-100/70 backdrop-blur-xl sm:p-8 lg:sticky lg:top-32">
        <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.16em] text-blue-700 ring-1 ring-blue-100">
          <span class="h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_0_4px_rgba(52,211,153,0.14)]"></span>
          Get a quotation
        </span>
        <h1 class="mt-4 max-w-2xl text-4xl font-black leading-[0.98] tracking-[-0.05em] text-slate-950 sm:text-5xl">Tell us about your move.</h1>
        <p class="mt-4 max-w-2xl text-sm font-medium leading-7 text-slate-600 sm:text-base">
          Share the essentials and our team will prepare a clear removals quotation with crew, transport, packing, and storage options where needed.
        </p>

        <div class="mt-7 grid gap-3 sm:grid-cols-2">
          <% [["2 min", "Quick request"], ["24 hrs", "Typical response"], ["UK-wide", "Home and office moves"], ["No pressure", "Clear next steps"]].each do |stat, label| %>
            <div class="rounded-2xl border border-slate-100 bg-white/80 p-4 shadow-sm shadow-blue-950/5">
              <p class="text-xl font-black tracking-[-0.03em] text-slate-950"><%= stat %></p>
              <p class="mt-1 text-xs font-bold text-slate-500"><%= label %></p>
            </div>
          <% end %>
        </div>

        <div class="mt-7 rounded-[1.5rem] border border-blue-100 bg-blue-50/70 p-5">
          <h2 class="text-sm font-black text-slate-950">What happens next?</h2>
          <div class="mt-4 space-y-4">
            <% marketing_how_it_works_steps.each_with_index do |(title, copy, icon), index| %>
              <div class="flex gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-white shadow-sm ring-1 ring-blue-100">
                  <%= image_tag marketing_asset_image(icon), alt: "", class: "h-5 w-5", aria: { hidden: true } %>
                </span>
                <div>
                  <p class="text-sm font-black text-slate-950"><%= index + 1 %>. <%= title %></p>
                  <p class="mt-1 text-xs font-semibold leading-5 text-slate-500"><%= copy %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="reveal rounded-[2rem] border border-white/90 bg-white/92 p-5 shadow-[0_24px_90px_rgba(30,64,175,0.14)] ring-1 ring-blue-100/80 backdrop-blur-xl sm:p-7 lg:p-8">
        <% if user_signed_in? && !current_user.customer? %>
          <div class="rounded-[1.5rem] border border-amber-200 bg-amber-50 p-5">
            <h2 class="text-xl font-black tracking-[-0.03em] text-slate-950">Quotation requests are for customer accounts</h2>
            <p class="mt-2 text-sm font-medium leading-6 text-amber-900">Operators can create quotations from the operations area. Drivers can manage assigned work from the dashboard.</p>
            <%= link_to "Open dashboard", dashboard_path, class: "mt-5 inline-flex rounded-xl bg-slate-950 px-5 py-3 text-sm font-black text-white transition hover:-translate-y-0.5" %>
          </div>
        <% else %>
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1.5 text-[9px] font-black uppercase tracking-[0.16em] text-blue-700">
                <%= image_tag marketing_asset_image("quote-document.svg"), alt: "", class: "h-4 w-4", aria: { hidden: true } %>
                Request details
              </span>
              <h2 class="mt-4 text-2xl font-black tracking-[-0.04em] text-slate-950">Get your removals quotation</h2>
              <p class="mt-2 text-sm font-semibold leading-6 text-slate-500">Required fields help us price the job accurately.</p>
              <p data-google-places-target="status" class="mt-2 text-xs font-bold text-slate-500">Start typing a postcode or use current location.</p>
            </div>
            <div class="hidden shrink-0 rounded-2xl bg-gradient-to-br from-blue-600 to-violet-600 p-3 shadow-lg shadow-blue-600/25 sm:block">
              <%= image_tag marketing_asset_image("price-receipt.svg"), alt: "", class: "h-6 w-6 brightness-0 invert", aria: { hidden: true } %>
            </div>
          </div>

          <%= form_with scope: :quotation, url: quotations_path, method: :post, local: true, data: { controller: "google-places" }, class: "mt-6 space-y-5" do |f| %>
            <% field_class = "block w-full rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-3 text-sm font-semibold text-slate-900 placeholder-slate-400 shadow-sm transition focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-100 sm:px-4" %>
            <% label_class = "mb-1.5 block text-[10px] font-black uppercase tracking-wide text-slate-500" %>
            <% inline_label_class = "block text-[10px] font-black uppercase tracking-wide text-slate-500" %>

            <% unless user_signed_in? %>
              <div>
                <%= f.label :customer_email, "Email address", class: label_class %>
                <%= f.email_field :customer_email, required: true, autocomplete: "email", placeholder: "you@example.com", class: field_class %>
              </div>
            <% end %>

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <div class="mb-1.5 flex items-center justify-between gap-3">
                  <%= f.label :pickup_postcode, "From postcode", class: inline_label_class %>
                  <button type="button" data-action="google-places#useCurrentLocation" data-google-places-input-param="quotation_pickup_postcode" class="text-[10px] font-black uppercase tracking-wide text-blue-700 transition hover:text-blue-900">Use current</button>
                </div>
                <%= f.text_field :pickup_postcode, required: true, placeholder: "SW1A 1AA", data: { google_places_target: "postcode", google_places_address_field_id: "quotation_pickup_address" }, class: field_class %>
              </div>
              <div>
                <div class="mb-1.5 flex items-center justify-between gap-3">
                  <%= f.label :delivery_postcode, "To postcode", class: inline_label_class %>
                  <button type="button" data-action="google-places#useCurrentLocation" data-google-places-input-param="quotation_delivery_postcode" class="text-[10px] font-black uppercase tracking-wide text-blue-700 transition hover:text-blue-900">Use current</button>
                </div>
                <%= f.text_field :delivery_postcode, required: true, placeholder: "M1 1AD", data: { google_places_target: "postcode", google_places_address_field_id: "quotation_delivery_address" }, class: field_class %>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <%= f.label :pickup_address, "Pickup address", class: label_class %>
                <%= f.text_field :pickup_address, placeholder: "Flat, house, office, floor, access notes", class: field_class %>
              </div>
              <div>
                <%= f.label :delivery_address, "Delivery address", class: label_class %>
                <%= f.text_field :delivery_address, placeholder: "Destination address or known details", class: field_class %>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-3">
              <div>
                <%= f.label :move_size, "Move size", class: label_class %>
                <%= f.select :move_size, [["Studio", "studio"], ["1 bedroom", "one_bed"], ["2 bedrooms", "two_bed"], ["3 bedrooms", "three_bed"], ["4+ bedrooms", "four_plus"], ["Office / commercial", "office"]], { selected: "studio" }, class: field_class %>
              </div>
              <div>
                <%= f.label :service_level, "Service", class: label_class %>
                <%= f.select :service_level, [["Standard move", "standard"], ["Packing help", "packing"], ["Storage needed", "storage"], ["Full service", "full_service"]], { selected: "standard" }, class: field_class %>
              </div>
              <div>
                <%= f.label :preferred_move_date, "Move date", class: label_class %>
                <%= f.date_field :preferred_move_date, class: field_class %>
              </div>
            </div>

            <div>
              <%= f.label :customer_notes, "Anything else we should know?", class: label_class %>
              <%= f.text_area :customer_notes, rows: 5, placeholder: "Packing, storage, fragile items, stairs, parking, timing, or special instructions...", class: "#{field_class} resize-none" %>
            </div>

            <%= f.submit "Request my quotation", class: "w-full cursor-pointer rounded-xl bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600 px-4 py-3.5 text-sm font-black text-white shadow-xl shadow-blue-600/25 transition hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-blue-600/30 focus:outline-none focus:ring-4 focus:ring-blue-200 sm:px-6" %>
            <p class="text-center text-[11px] font-semibold text-slate-500">No obligation. We will use your details only to prepare and manage your quotation.</p>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>
</main>

<%= render "shared/marketing_footer" %>
