<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white shadow rounded-lg p-6">
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-bold">Your Dashboard</h2>
      <div class="space-x-2">
        <%= link_to "Edit profile", edit_user_registration_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-white hover:bg-indigo-700" %>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete, form: { style: 'display:inline' }, class: "inline-flex items-center rounded-md bg-gray-200 px-3 py-2 text-gray-800 hover:bg-gray-300" %>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-lg border p-4">
        <h3 class="font-semibold">Upcoming Moves</h3>
        <p class="mt-2 text-sm text-gray-600">No upcoming moves yet.</p>
      </div>

      <div class="rounded-lg border p-4">
        <h3 class="font-semibold">Active quotes</h3>
        <p class="mt-2 text-sm text-gray-600">You have 0 active quotes. Request one from the landing page.</p>
      </div>

      <div class="rounded-lg border p-4">
        <h3 class="font-semibold">Support</h3>
        <p class="mt-2 text-sm text-gray-600">Contact your coordinator or open a ticket.</p>
      </div>
    </div>
  </div>
</div>
