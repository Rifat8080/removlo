<% content_for :title, "How Removlo Works — Simple UK Removals in 3 Steps" %>
<% content_for :meta_description, "See how Removlo works: get a transparent quote, book your move date, and track your crew live with dedicated support from start to finish." %>

<main data-controller="reveal" class="relative flex-1 overflow-hidden bg-[#f7f9ff] text-slate-800">
  <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-[48rem] bg-[radial-gradient(circle_at_18%_20%,rgba(37,99,235,0.14),transparent_26%),radial-gradient(circle_at_80%_16%,rgba(124,58,237,0.13),transparent_28%),linear-gradient(180deg,#fbfdff_0%,#eef5ff_58%,#ffffff_100%)]"></div>

  <%= render "pages/marketing_hero",
    badge: "Simple process",
    title: "How it works",
    subtitle: "Three straightforward steps from quote to keys — with live updates and a dedicated coordinator throughout." %>

  <section class="relative z-10 px-4 pb-8 sm:px-6 lg:px-10 2xl:px-14">
    <div class="reveal mx-auto w-full max-w-[1600px] overflow-hidden rounded-[2rem] border border-white/90 bg-white/88 p-5 shadow-[0_24px_90px_rgba(30,64,175,0.12)] ring-1 ring-blue-100/70 backdrop-blur-xl sm:p-7">
      <div class="grid gap-8 min-[1360px]:grid-cols-[1fr_18rem] min-[1360px]:items-start">
        <div class="grid gap-6 md:grid-cols-3">
          <% marketing_how_it_works_steps.each_with_index do |(title, copy, icon), index| %>
            <div class="group relative rounded-[1.5rem] border border-white/80 bg-white/72 p-5 shadow-lg shadow-blue-950/5 ring-1 ring-blue-50/80 transition duration-300 hover:-translate-y-1 hover:bg-white hover:shadow-xl">
              <div class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-blue-600 to-violet-600 shadow-lg shadow-blue-700/25">
                <%= image_tag marketing_asset_image(icon), alt: "", class: "h-7 w-7 brightness-0 invert", aria: { hidden: true } %>
              </div>
              <span class="mt-4 inline-flex h-6 w-6 items-center justify-center rounded-full bg-blue-600 text-[10px] font-black text-white"><%= index + 1 %></span>
              <h3 class="mt-3 text-base font-black text-slate-950"><%= title %></h3>
              <p class="mt-2 text-sm font-semibold leading-6 text-slate-500"><%= copy %></p>
            </div>
          <% end %>
        </div>

        <div class="rounded-[1.5rem] border border-white/90 bg-white/86 p-5 shadow-xl shadow-blue-950/8 ring-1 ring-blue-100/80">
          <h3 class="text-sm font-black text-slate-950">Move confidence</h3>
          <p class="mt-1 text-xs font-semibold text-slate-500">Built into every booking</p>
          <div class="mt-4 grid gap-3">
            <% marketing_benefits.each do |title, copy, icon| %>
              <div class="flex gap-3 rounded-2xl border border-transparent p-2">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-50">
                  <%= image_tag marketing_asset_image(icon), alt: "", class: "h-6 w-6", aria: { hidden: true } %>
                </span>
                <div>
                  <h4 class="text-sm font-black text-slate-950"><%= title %></h4>
                  <p class="mt-1 text-xs font-semibold leading-5 text-slate-500"><%= copy %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%= render "pages/marketing_cta" %>
</main>

<%= render "shared/marketing_footer" %>
