<% content_for :title, "How Removlo Works — Simple UK Removals in 3 Steps" %>
<% content_for :meta_description, "See how Removlo works: get a transparent quote, book your move date, and track your crew live with dedicated support from start to finish." %>

<main data-controller="reveal" class="relative flex-1 overflow-hidden bg-[#f7f9ff] text-slate-800">
  <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-[48rem] bg-[radial-gradient(circle_at_18%_20%,rgba(37,99,235,0.14),transparent_26%),radial-gradient(circle_at_80%_16%,rgba(124,58,237,0.13),transparent_28%),linear-gradient(180deg,#fbfdff_0%,#eef5ff_58%,#ffffff_100%)]"></div>

  <%= render "pages/marketing_hero",
    badge: "Simple process",
    title: "How it works",
    subtitle: "Three straightforward steps from quote to keys — with live updates and a dedicated coordinator throughout." %>

  <section class="relative z-10 px-4 pb-8 sm:px-6 lg:px-10 2xl:px-14">
    <div class="reveal mx-auto w-full max-w-[1600px] overflow-hidden rounded-[2rem] border border-white/90 bg-white/88 p-5 shadow-[0_24px_90px_rgba(30,64,175,0.12)] ring-1 ring-blue-100/70 backdrop-blur-xl sm:p-7">
      <div class="mb-6 grid gap-3 sm:grid-cols-3">
        <% [["Instant route check", "Google distance + ETA"], ["Coordinator review", "Final price set by people"], ["Live tracking", "ETA when the move starts"]].each do |title, copy| %>
          <div class="rounded-2xl border border-white/80 bg-white/70 px-4 py-3 shadow-sm shadow-blue-950/5 ring-1 ring-blue-50/80">
            <p class="text-xs font-black text-slate-950"><%= title %></p>
            <p class="mt-1 text-[11px] font-bold text-slate-500"><%= copy %></p>
          </div>
        <% end %>
      </div>

      <div class="grid gap-6 min-[1360px]:grid-cols-[1fr_20rem] min-[1360px]:items-stretch">
        <div>
          <div class="grid gap-5 md:grid-cols-3">
            <% [["Set your quote", "Postcodes, move size, date, and extras give us the route context.", "quote-document.svg", ["Route estimate", "Service options", "No obligation"]], ["Book your move", "A coordinator checks the route, confirms the plan, and sends clear next steps.", "calendar-check.svg", ["Human-reviewed quote", "Deposit protection", "Move-day schedule"]], ["We move you", "Your driver follows the route plan and shares live progress when the job starts.", "moving-truck.svg", ["Pickup navigation", "Customer ETA feed", "Delivery updates"]]].each_with_index do |(title, copy, icon, points), index| %>
              <div class="group relative overflow-hidden rounded-[1.65rem] border border-white/85 bg-white/78 p-5 shadow-lg shadow-blue-950/5 ring-1 ring-blue-50/80 transition duration-300 hover:-translate-y-1 hover:bg-white hover:shadow-xl">
                <div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-blue-50/80 to-transparent"></div>
                <div class="relative z-10 flex items-start justify-between gap-4">
                  <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-blue-100/80 shadow-[0_12px_30px_rgba(37,99,235,0.16)] ring-4 ring-blue-50">
                    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-blue-600 to-violet-600 shadow-lg shadow-blue-700/25">
                      <%= image_tag marketing_asset_image(icon), alt: "", class: "h-6 w-6 brightness-0 invert", aria: { hidden: true } %>
                    </div>
                  </div>
                  <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-blue-600 text-[10px] font-black text-white shadow-md shadow-blue-600/20"><%= index + 1 %></span>
                </div>
                <h3 class="relative z-10 mt-5 text-base font-black text-slate-950"><%= title %></h3>
                <p class="relative z-10 mt-2 text-xs font-semibold leading-5 text-slate-500"><%= copy %></p>
                <ul class="relative z-10 mt-4 space-y-2">
                  <% points.each do |point| %>
                    <li class="flex items-center gap-2 text-[11px] font-black text-slate-600">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_0_4px_rgba(52,211,153,0.10)]"></span>
                      <%= point %>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>

          <div class="mt-5 grid gap-3 rounded-[1.5rem] border border-white/80 bg-white/72 p-3 shadow-lg shadow-blue-950/5 ring-1 ring-blue-50/80 sm:grid-cols-3">
            <% [["Route", "Postcode to postcode mapped"], ["Quote", "Reviewed before pricing"], ["Tracking", "ETA visible when moving"]].each do |title, copy| %>
              <div class="flex items-center gap-3 rounded-2xl bg-slate-50/80 px-3 py-3">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white shadow-sm ring-1 ring-blue-100">
                  <%= image_tag marketing_asset_image("route-pin.svg"), alt: "", class: "h-5 w-5", aria: { hidden: true } %>
                </span>
                <div>
                  <p class="text-xs font-black text-slate-950"><%= title %></p>
                  <p class="mt-0.5 text-[11px] font-semibold text-slate-500"><%= copy %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="grid gap-4">
          <div class="rounded-[1.5rem] border border-white/90 bg-white/88 p-5 shadow-xl shadow-blue-950/8 ring-1 ring-blue-100/80">
            <h3 class="text-sm font-black text-slate-950">Live move plan</h3>
            <p class="mt-1 text-xs font-semibold text-slate-500">Route, ETA, and support in one flow.</p>
            <div class="mt-4 rounded-2xl bg-slate-950 p-4 text-white shadow-lg shadow-slate-950/15">
              <p class="text-[10px] font-black uppercase tracking-wide text-blue-200">Example route</p>
              <p class="mt-1 text-sm font-black">London to Leeds</p>
              <div class="mt-4 grid grid-cols-2 gap-3">
                <div class="rounded-xl bg-white/10 p-3">
                  <p class="text-[10px] font-bold text-slate-300">Drive ETA</p>
                  <p class="mt-1 text-lg font-black">3h 40m</p>
                </div>
                <div class="rounded-xl bg-white/10 p-3">
                  <p class="text-[10px] font-bold text-slate-300">Distance</p>
                  <p class="mt-1 text-lg font-black">195 mi</p>
                </div>
              </div>
            </div>
          </div>

          <div class="rounded-[1.5rem] border border-white/90 bg-white/86 p-5 shadow-xl shadow-blue-950/8 ring-1 ring-blue-100/80">
            <h3 class="text-sm font-black text-slate-950">Move confidence</h3>
            <p class="mt-1 text-xs font-semibold text-slate-500">Built into every booking</p>
            <div class="mt-4 grid gap-3">
              <% marketing_benefits.each do |title, copy, icon| %>
                <div class="flex gap-3 rounded-2xl border border-transparent p-2">
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-50">
                    <%= image_tag marketing_asset_image(icon), alt: "", class: "h-6 w-6", aria: { hidden: true } %>
                  </span>
                  <div>
                    <h4 class="text-sm font-black text-slate-950"><%= title %></h4>
                    <p class="mt-1 text-xs font-semibold leading-5 text-slate-500"><%= copy %></p>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%= render "pages/marketing_cta" %>
</main>

<%= render "shared/marketing_footer" %>
