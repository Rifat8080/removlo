<% badge ||= nil %>
<% subtitle ||= nil %>
<section class="relative isolate z-10 overflow-hidden px-4 pb-8 pt-28 sm:px-6 sm:pt-28 min-[1360px]:pt-32 lg:px-10 2xl:px-14">
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(37,99,235,0.055)_1px,transparent_1px),linear-gradient(to_bottom,rgba(37,99,235,0.055)_1px,transparent_1px)] bg-[size:3rem_3rem]"></div>
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_45%_24%,rgba(96,165,250,0.16),transparent_34%),radial-gradient(circle_at_78%_22%,rgba(124,58,237,0.10),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.30),rgba(239,246,255,0.25)_55%,rgba(255,255,255,0.65))]"></div>
  <div class="reveal mx-auto w-full max-w-[1600px]">
  <div class="rounded-[2rem] border border-white/90 bg-white/85 p-6 shadow-[0_24px_80px_rgba(30,64,175,0.10)] ring-1 ring-blue-100/70 backdrop-blur-xl sm:p-8 lg:p-10">
    <% if badge.present? %>
      <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.16em] text-blue-700 ring-1 ring-blue-100">
        <span class="h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_0_4px_rgba(52,211,153,0.14)]"></span>
        <%= badge %>
      </span>
    <% end %>
    <h1 class="mt-3 max-w-4xl text-3xl font-black tracking-[-0.04em] text-slate-950 sm:text-4xl lg:text-5xl"><%= title %></h1>
    <% if subtitle.present? %>
      <p class="mt-4 max-w-3xl text-sm font-medium leading-7 text-slate-600 sm:text-base"><%= subtitle %></p>
    <% end %>
    <% if local_assigns[:actions] %>
      <div class="mt-6 flex flex-wrap gap-3">
        <%= actions %>
      </div>
    <% end %>
  </div>
  </div>
</section>
