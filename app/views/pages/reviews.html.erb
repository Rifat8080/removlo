<% content_for :title, "Removlo Reviews — Trusted UK Removals Customer Stories" %>
<% content_for :meta_description, "Read Removlo customer reviews for home removals, office moves, packing, and storage across the UK. Transparent service, careful crews, and great communication." %>

<main data-controller="reveal" class="relative flex-1 overflow-hidden bg-[#f7f9ff] text-slate-800">
  <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-[48rem] bg-[radial-gradient(circle_at_18%_20%,rgba(37,99,235,0.14),transparent_26%),radial-gradient(circle_at_80%_16%,rgba(124,58,237,0.13),transparent_28%),linear-gradient(180deg,#fbfdff_0%,#eef5ff_58%,#ffffff_100%)]"></div>

  <%= render "pages/marketing_hero",
    badge: "Customer stories",
    title: "What our customers say",
    subtitle: "Real feedback from home movers, office relocations, and packing customers across the UK." %>

  <section class="relative z-10 px-4 pb-8 sm:px-6 lg:px-10 2xl:px-14">
    <div class="reveal mx-auto grid w-full max-w-[1600px] gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% marketing_reviews.each do |review| %>
        <article class="rounded-[1.5rem] border border-slate-200/80 bg-white p-5 shadow-sm shadow-blue-950/5 sm:p-6">
          <div class="flex text-amber-400" aria-label="Five star review">
            <% 5.times do %>
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.36 1.12l1.07 3.29c.3.92-.76 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.18 0l-2.8 2.03c-.78.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12l-2.8-2.03c-.78-.57-.38-1.81.59-1.81h3.46a1 1 0 00.95-.69l1.07-3.29z"/></svg>
            <% end %>
          </div>
          <blockquote class="mt-4 text-sm font-bold leading-6 text-slate-800"><%= review[:quote] %></blockquote>
          <div class="mt-5 flex items-center gap-3">
            <% initials = review[:name].split.map { |part| part.first }.join.first(2).upcase %>
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-blue-600 to-violet-600 text-xs font-black text-white"><%= initials %></span>
            <div>
              <p class="text-sm font-black text-slate-950"><%= review[:name] %></p>
              <p class="text-xs font-semibold text-slate-500"><%= review[:route] %></p>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </section>

  <%= render "pages/marketing_cta" %>
</main>

<%= render "shared/marketing_footer" %>
