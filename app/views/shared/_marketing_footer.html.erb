<footer class="relative z-10 overflow-hidden bg-[#eef4ff] px-4 sm:px-6 lg:px-10 2xl:px-14">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-48 bg-[radial-gradient(circle_at_18%_20%,rgba(37,99,235,0.14),transparent_30%),radial-gradient(circle_at_82%_18%,rgba(124,58,237,0.12),transparent_32%)]"></div>
  <div class="relative mx-auto w-full max-w-[1600px] py-8 lg:py-10">
    <div class="rounded-[2rem] border border-white/90 bg-white/72 p-5 shadow-[0_24px_80px_rgba(30,64,175,0.10)] ring-1 ring-blue-100/70 backdrop-blur-xl sm:p-7 lg:p-8">
      <div class="grid gap-10 lg:grid-cols-[1.2fr_2.8fr] lg:items-start xl:grid-cols-[1.05fr_3fr]">
        <div class="max-w-md">
          <%= link_to root_path, class: "group flex items-center" do %>
            <%= image_tag marketing_asset_image("logo.svg"), alt: "Removlo - Moving Made Simple", class: "h-auto w-44 transition duration-300 group-hover:-translate-y-0.5 sm:w-56" %>
          <% end %>
          <p class="mt-4 max-w-sm text-sm font-semibold leading-6 text-slate-500">
            Intelligent logistics, careful movers, live updates, and human support from quote to doorstep.
          </p>
          <%= link_to marketing_quote_path, class: "mt-5 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 px-4 py-2.5 text-xs font-black text-white shadow-lg shadow-blue-600/25 transition hover:-translate-y-0.5 hover:shadow-xl" do %>
            Get a quote
            <%= image_tag marketing_asset_image("arrow-right.svg"), alt: "", class: "h-4 w-4 brightness-0 invert", aria: { hidden: true } %>
          <% end %>
        </div>

        <div class="grid grid-cols-2 gap-x-8 gap-y-9 sm:grid-cols-3 lg:grid-cols-5 xl:gap-x-12">
          <% marketing_footer_columns.each do |heading, links| %>
            <div>
              <h2 class="mb-5 text-xs font-black uppercase tracking-[0.18em] text-slate-950"><%= heading %></h2>
              <ul class="font-semibold text-slate-500">
                <% links.each do |label, href| %>
                  <li class="mb-4 last:mb-0">
                    <%= link_to label, href, class: "transition hover:text-blue-700 hover:underline" %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      </div>

      <hr class="my-6 border-blue-100 sm:mx-auto lg:my-8" />

      <div class="sm:flex sm:items-center sm:justify-between">
        <span class="text-sm font-semibold text-slate-500 sm:text-center">
          © <%= Time.current.year %> <%= link_to "Removlo Ltd", root_path, class: "hover:text-blue-700 hover:underline" %>. All Rights Reserved.
        </span>

        <div class="mt-4 flex sm:mt-0 sm:justify-center">
          <a href="#" class="text-slate-500 transition hover:-translate-y-0.5 hover:text-blue-700">
            <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M13.135 6H15V3h-1.865a4.147 4.147 0 0 0-4.142 4.142V9H7v3h2v9.938h3V12h2.021l.592-3H12V6.591A.6.6 0 0 1 12.592 6h.543Z" clip-rule="evenodd"/></svg>
            <span class="sr-only">Facebook page</span>
          </a>
          <a href="#" class="ms-5 text-slate-500 transition hover:-translate-y-0.5 hover:text-blue-700">
            <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M18.942 5.556a16.3 16.3 0 0 0-4.126-1.3 12.04 12.04 0 0 0-.529 1.1 15.175 15.175 0 0 0-4.573 0 11.586 11.586 0 0 0-.535-1.1 16.274 16.274 0 0 0-4.129 1.3 17.392 17.392 0 0 0-2.868 11.662 15.785 15.785 0 0 0 4.963 2.521c.41-.564.773-1.16 1.084-1.785a10.638 10.638 0 0 1-1.706-.83c.143-.106.283-.217.418-.331a11.664 11.664 0 0 0 10.118 0c.137.114.277.225.418.331-.544.328-1.116.606-1.71.832a12.58 12.58 0 0 0 1.084 1.785 16.46 16.46 0 0 0 5.064-2.595 17.286 17.286 0 0 0-2.973-11.59ZM8.678 14.813a1.94 1.94 0 0 1-1.8-2.045 1.93 1.93 0 0 1 1.8-2.047 1.918 1.918 0 0 1 1.8 2.047 1.929 1.929 0 0 1-1.8 2.045Zm6.644 0a1.94 1.94 0 0 1-1.8-2.045 1.93 1.93 0 0 1 1.8-2.047 1.919 1.919 0 0 1 1.8 2.047 1.93 1.93 0 0 1-1.8 2.045Z"/></svg>
            <span class="sr-only">Discord community</span>
          </a>
          <a href="#" class="ms-5 text-slate-500 transition hover:-translate-y-0.5 hover:text-blue-700">
            <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M13.795 10.533 20.68 2h-3.073l-5.255 6.517L7.69 2H1l7.806 10.91L1.47 22h3.074l5.705-7.07L15.31 22H22l-8.205-11.467Zm-2.38 2.95L9.97 11.464 4.36 3.627h2.31l4.528 6.317 1.443 2.02 6.018 8.409h-2.31l-4.934-6.89Z"/></svg>
            <span class="sr-only">Twitter page</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
