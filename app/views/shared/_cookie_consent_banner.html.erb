<% if cookie_consent_banner_required? %>
  <div
    data-controller="cookie-consent"
    data-cookie-consent-storage-key-value="<%= AnalyticsHelper::CONSENT_STORAGE_KEY %>"
    data-cookie-consent-region-value="true"
    class="hidden"
    role="dialog"
    aria-live="polite"
    aria-label="Cookie consent"
    aria-modal="false"
  >
    <div
      data-cookie-consent-target="banner"
      class="fixed inset-x-0 bottom-0 z-[80] hidden border-t border-slate-200/80 bg-white/95 shadow-[0_-18px_60px_rgba(15,23,42,0.14)] backdrop-blur-xl"
    >
      <div class="mx-auto flex w-full max-w-[1600px] flex-col gap-5 px-4 py-5 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:gap-8 lg:px-10 lg:py-6">
        <div class="flex min-w-0 items-start gap-4">
          <span class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-600 to-violet-600 text-white shadow-lg shadow-blue-600/20">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </span>
          <div class="min-w-0">
            <p class="text-sm font-black text-slate-950 sm:text-base">Your privacy matters to us</p>
            <p class="mt-1 max-w-3xl text-sm font-medium leading-6 text-slate-600">
              We use analytics cookies to understand how visitors use Removlo and improve our removals service.
              You can accept analytics cookies or continue with essential cookies only.
              <%= link_to "Contact us", contact_path, class: "font-semibold text-blue-700 underline decoration-blue-700/30 underline-offset-2 transition hover:text-blue-800" %>
              if you have questions about how we use data.
            </p>
          </div>
        </div>

        <div class="flex shrink-0 flex-col gap-2 sm:flex-row sm:items-center">
          <button
            type="button"
            data-action="cookie-consent#reject"
            class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 focus:outline-none focus:ring-4 focus:ring-slate-200"
          >
            Essential only
          </button>
          <button
            type="button"
            data-action="cookie-consent#accept"
            class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600 px-5 py-3 text-sm font-extrabold text-white shadow-lg shadow-blue-600/20 transition hover:from-blue-700 hover:via-indigo-700 hover:to-violet-700 focus:outline-none focus:ring-4 focus:ring-blue-100"
          >
            Accept analytics
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
