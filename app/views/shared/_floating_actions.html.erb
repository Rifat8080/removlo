<% contact_phone = ENV.fetch("REMOVLO_CONTACT_PHONE", "+440000000000") %>
<% contact_phone_label = ENV.fetch("REMOVLO_CONTACT_PHONE_LABEL", "Call us") %>
<% whatsapp_number = ENV.fetch("REMOVLO_WHATSAPP_NUMBER", contact_phone).gsub(/\D/, "") %>
<% whatsapp_message = ERB::Util.url_encode("Hi Removlo, I would like help with my move.") %>

<div data-controller="scroll-top" class="fixed bottom-4 right-4 z-[70] flex flex-col items-end gap-3 sm:bottom-6 sm:right-6">
  <a
    href="https://wa.me/<%= whatsapp_number %>?text=<%= whatsapp_message %>"
    target="_blank"
    rel="noopener"
    aria-label="Chat with Removlo on WhatsApp"
    class="group inline-flex h-12 w-12 items-center justify-center rounded-full bg-[#25D366] text-white shadow-xl shadow-emerald-900/20 ring-1 ring-white/40 transition duration-200 hover:-translate-y-0.5 hover:shadow-2xl focus:outline-none focus:ring-4 focus:ring-emerald-200 sm:h-auto sm:w-auto sm:gap-2 sm:px-4 sm:py-3"
  >
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.52 3.48A11.86 11.86 0 0012.07 0C5.49 0 .14 5.35.14 11.93c0 2.1.55 4.16 1.6 5.97L0 24l6.25-1.64a11.9 11.9 0 005.82 1.48h.01c6.58 0 11.93-5.35 11.93-11.93a11.86 11.86 0 00-3.49-8.43zM12.08 21.82h-.01a9.9 9.9 0 01-5.04-1.38l-.36-.21-3.7.97.99-3.61-.24-.37a9.86 9.86 0 01-1.52-5.29c0-5.47 4.45-9.92 9.93-9.92a9.86 9.86 0 017.02 2.91 9.86 9.86 0 012.91 7.01c0 5.47-4.45 9.91-9.98 9.91zm5.44-7.43c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.25-.46-2.39-1.47-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2.01-1.42.25-.7.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35z"/>
    </svg>
    <span class="hidden text-sm font-bold sm:inline">WhatsApp</span>
  </a>

  <a
    href="tel:<%= contact_phone %>"
    aria-label="<%= contact_phone_label %>"
    class="group inline-flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-indigo-600 to-blue-600 text-white shadow-xl shadow-indigo-900/20 ring-1 ring-white/40 transition duration-200 hover:-translate-y-0.5 hover:shadow-2xl focus:outline-none focus:ring-4 focus:ring-indigo-200 sm:h-auto sm:w-auto sm:gap-2 sm:px-4 sm:py-3"
  >
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-2.26 1.13a11.04 11.04 0 005.52 5.52l1.13-2.26a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z"/>
    </svg>
    <span class="hidden text-sm font-bold sm:inline"><%= contact_phone_label %></span>
  </a>

  <button
    type="button"
    data-scroll-top-target="button"
    data-action="scroll-top#scroll"
    aria-label="Scroll to top"
    class="pointer-events-none inline-flex h-11 w-11 translate-y-2 items-center justify-center rounded-full border border-slate-200 bg-white/95 text-slate-700 opacity-0 shadow-xl shadow-slate-900/10 backdrop-blur transition duration-200 hover:-translate-y-0.5 hover:bg-slate-50 hover:text-indigo-700 focus:outline-none focus:ring-4 focus:ring-slate-200"
  >
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
    </svg>
  </button>
</div>
