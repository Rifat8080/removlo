<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <% seo_title = content_for(:title) || "Removlo — Smart UK Removals, Moving & Relocation Services" %>
    <% seo_description = content_for(:meta_description) || "Book trusted UK removals with Removlo. Get transparent moving quotes, professional home and office removals, packing services, storage, live tracking, and dedicated support." %>
    <% seo_image = image_url("images/logo-raster.png") %>
    <title><%= seo_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= seo_description %>">
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
    <meta name="theme-color" content="#2563eb">
    <link rel="canonical" href="<%= request.original_url.split('?').first %>">
    <meta property="og:site_name" content="Removlo">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= seo_title %>">
    <meta property="og:description" content="<%= seo_description %>">
    <meta property="og:url" content="<%= request.original_url.split('?').first %>">
    <meta property="og:image" content="<%= seo_image %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo_title %>">
    <meta name="twitter:description" content="<%= seo_description %>">
    <meta name="twitter:image" content="<%= seo_image %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= favicon_link_tag "images/icon-raster.png", type: "image/png" %>
    <link rel="apple-touch-icon" href="<%= asset_path("images/icon-raster.png") %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <% inter_font_href = "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" %>
    <link rel="stylesheet" href="<%= inter_font_href %>" media="print" onload="this.media='all'">
    <noscript><link href="<%= inter_font_href %>" rel="stylesheet"></noscript>
    <%= stylesheet_link_tag "builds/tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "stylesheets/application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="flex min-h-screen flex-col bg-[#f6f8ff] text-slate-700 antialiased">
    <!-- Navbar -->
    <nav id="site-nav" data-controller="nav-scroll" class="fixed top-0 z-50 w-full border-b border-slate-200 bg-white/95 px-4 py-3.5 shadow-sm backdrop-blur-xl transition-shadow duration-300 sm:px-6 lg:px-10 2xl:px-14">
      <div class="mx-auto flex w-full max-w-[1600px] items-center justify-between gap-4">
        <%= link_to root_path, class: "group flex shrink-0 items-center" do %>
          <%= image_tag marketing_asset_image("logo.svg"), alt: "Removlo - Moving Made Simple", class: "h-auto w-44 transition duration-300 group-hover:-translate-y-0.5 sm:w-56" %>
        <% end %>

        <div class="hidden items-center gap-1 min-[1180px]:flex" id="landing-navbar">
          <% marketing_nav_links.each do |label, href| %>
            <%= link_to href, class: "rounded-lg px-3 py-2 text-sm font-extrabold text-slate-700 transition hover:bg-slate-50 hover:text-blue-700 min-[1440px]:px-4" do %>
              <%= label %>
            <% end %>
          <% end %>
        </div>

        <div class="flex shrink-0 items-center gap-2 sm:gap-3">
          <% if user_signed_in? %>
            <%= link_to "Dashboard", dashboard_path, class: "hidden rounded-lg px-3 py-2 text-sm font-bold text-slate-700 transition hover:bg-slate-50 hover:text-blue-700 sm:inline-flex" %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, form: { class: "hidden sm:inline" }, class: "rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-bold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50" %>
          <% else %>
            <div class="hidden text-right min-[1280px]:block">
              <p class="text-[10px] font-bold uppercase tracking-[0.16em] text-slate-400">Need help?</p>
              <a href="tel:<%= ENV.fetch("REMOVLO_CONTACT_PHONE", "+440000000000") %>" class="text-sm font-extrabold text-slate-800 transition hover:text-blue-700">Speak to us</a>
            </div>
            <%= link_to "Sign in", new_user_session_path, class: "hidden rounded-lg px-3 py-2 text-sm font-extrabold text-slate-800 transition hover:bg-slate-50 hover:text-blue-700 sm:inline-flex" %>
            <%= link_to marketing_quote_path, class: "inline-flex items-center gap-1.5 rounded-lg bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600 px-4 py-2.5 text-sm font-extrabold leading-none text-white shadow-md shadow-blue-600/20 transition hover:from-blue-700 hover:via-indigo-700 hover:to-violet-700 focus:outline-none focus:ring-4 focus:ring-blue-100 sm:gap-2 sm:px-5 sm:py-3 sm:text-base" do %>
              <span class="sm:hidden">Quote</span>
              <span class="hidden sm:inline">Get a quote</span>
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            <% end %>
          <% end %>

          <button data-collapse-toggle="landing-navbar-mobile" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-700 transition hover:bg-slate-50 hover:text-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-100 sm:h-10 sm:w-10 min-[1180px]:hidden" aria-controls="landing-navbar-mobile" aria-expanded="false">
            <span class="sr-only">Open main menu</span>
            <svg class="h-5 w-5" aria-hidden="true" fill="none" viewBox="0 0 17 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/></svg>
          </button>
        </div>
      </div>

      <div class="hidden px-4 pt-3 sm:px-6 lg:px-10 2xl:px-14 min-[1180px]:hidden" id="landing-navbar-mobile">
        <div class="mx-auto flex w-full max-w-[1600px] flex-col gap-1 rounded-xl border border-slate-200 bg-white p-3 shadow-lg shadow-slate-950/5">
          <% marketing_nav_links.each do |label, href| %>
            <%= link_to label, href, class: "rounded-lg px-3 py-2.5 text-base font-bold text-slate-700 transition hover:bg-slate-50 hover:text-blue-700" %>
          <% end %>
          <% if user_signed_in? %>
            <%= link_to "Dashboard", dashboard_path, class: "mt-2 rounded-lg bg-slate-950 px-3 py-2.5 text-center text-sm font-bold text-white" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "mt-2 rounded-lg px-3 py-2.5 text-base font-bold text-slate-700 transition hover:bg-slate-50 hover:text-blue-700" %>
            <%= link_to "Get a quote", marketing_quote_path, class: "rounded-lg bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600 px-3 py-3 text-center text-base font-extrabold text-white shadow-md shadow-blue-600/20" %>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Flash -->
    <% if notice.present? %>
      <div class="fixed left-1/2 top-20 z-[60] w-[calc(100%-2rem)] max-w-lg -translate-x-1/2" role="alert">
        <div class="flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm font-medium text-emerald-800 shadow-lg">
          <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="fixed left-1/2 top-20 z-[60] w-[calc(100%-2rem)] max-w-lg -translate-x-1/2" role="alert">
        <div class="flex items-center gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-medium text-red-800 shadow-lg">
          <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <%= alert %>
        </div>
      </div>
    <% end %>

    <div class="flex flex-1 flex-col">
      <%= yield %>
    </div>
    <%= render "shared/floating_actions" %>
  </body>
</html>
