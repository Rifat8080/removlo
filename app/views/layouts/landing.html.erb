<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <% seo_title = content_for(:title) || "Removlo — Smart UK Removals, Moving & Relocation Services" %>
    <% seo_description = content_for(:meta_description) || "Book trusted UK removals with Removlo. Get transparent moving quotes, professional home and office removals, packing services, storage, live tracking, and dedicated support." %>
    <% seo_image = image_url("images/logo.svg") %>
    <title><%= seo_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= seo_description %>">
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
    <meta name="theme-color" content="#2563eb">
    <link rel="canonical" href="<%= request.original_url.split('?').first %>">
    <meta property="og:site_name" content="Removlo">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= seo_title %>">
    <meta property="og:description" content="<%= seo_description %>">
    <meta property="og:url" content="<%= request.original_url.split('?').first %>">
    <meta property="og:image" content="<%= seo_image %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo_title %>">
    <meta name="twitter:description" content="<%= seo_description %>">
    <meta name="twitter:image" content="<%= seo_image %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= favicon_link_tag "images/icon.svg", type: "image/svg+xml" %>
    <link rel="apple-touch-icon" href="<%= asset_path("images/icon.svg") %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="flex min-h-screen flex-col bg-[#f6f8ff] text-slate-700 antialiased">
    <!-- Navbar -->
    <nav id="site-nav" data-controller="nav-scroll" class="fixed top-0 z-50 w-full border-b border-slate-200/80 bg-white/96 px-4 shadow-sm shadow-slate-900/5 backdrop-blur-xl transition-[background-color,box-shadow,border-color] duration-300 sm:px-6 lg:px-10 2xl:px-14">
      <div class="mx-auto flex w-full max-w-[1600px] items-center justify-between gap-6 py-2.5">
        <%= link_to root_path, class: "group flex h-12 w-48 shrink-0 items-center overflow-hidden sm:h-14 sm:w-56" do %>
          <%= image_tag "images/logo.svg", alt: "Removlo - Moving Made Simple", class: "h-full w-full object-cover object-center transition duration-300 group-hover:opacity-90" %>
        <% end %>

        <div class="hidden items-center gap-7 min-[1280px]:flex" id="landing-navbar">
          <% [["Services", "#{root_path}#services"], ["How it works", "#{root_path}#how-it-works"], ["About us", "#{root_path}#how-it-works"], ["Reviews", "#{root_path}#reviews"], ["Resources", blog_posts_path], ["Shop", shop_products_path], ["Contact", "#{root_path}#contact"]].each do |label, href| %>
            <%= link_to href, class: "group relative py-2 text-sm font-semibold text-slate-600 transition hover:text-blue-700" do %>
              <%= label %>
              <span class="absolute -bottom-0.5 left-0 h-0.5 w-0 rounded-full bg-blue-600 transition-all duration-200 group-hover:w-full"></span>
            <% end %>
          <% end %>
        </div>

        <div class="flex items-center gap-2 sm:gap-3">
          <% if user_signed_in? %>
            <%= link_to "Dashboard", dashboard_path, class: "hidden rounded-lg px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-blue-700 sm:inline-flex" %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, form: { class: "hidden sm:inline" }, class: "rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "hidden rounded-lg px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-blue-700 sm:inline-flex" %>
            <%= link_to "#quote", class: "inline-flex items-center gap-2 rounded-lg bg-slate-950 px-5 py-2.5 text-sm font-bold text-white shadow-lg shadow-slate-950/15 transition hover:-translate-y-0.5 hover:bg-blue-700 hover:shadow-blue-700/25 focus:outline-none focus:ring-4 focus:ring-blue-200" do %>
              Get a quote
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            <% end %>
          <% end %>

          <button data-collapse-toggle="landing-navbar-mobile" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-700 shadow-sm transition hover:bg-slate-50 hover:text-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-100 min-[1280px]:hidden" aria-controls="landing-navbar-mobile" aria-expanded="false">
            <span class="sr-only">Open main menu</span>
            <svg class="h-5 w-5" aria-hidden="true" fill="none" viewBox="0 0 17 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/></svg>
          </button>
        </div>
      </div>

      <div class="hidden border-t border-slate-100 bg-white px-4 py-4 sm:px-6 min-[1280px]:hidden" id="landing-navbar-mobile">
        <div class="mx-auto flex w-full max-w-[1600px] flex-col gap-1">
          <% [["Services", "#{root_path}#services"], ["How it works", "#{root_path}#how-it-works"], ["About us", "#{root_path}#how-it-works"], ["Reviews", "#{root_path}#reviews"], ["Resources", blog_posts_path], ["Shop", shop_products_path], ["Contact", "#{root_path}#contact"]].each do |label, href| %>
            <%= link_to label, href, class: "rounded-lg px-3 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 hover:text-blue-700" %>
          <% end %>
          <% if user_signed_in? %>
            <%= link_to "Dashboard", dashboard_path, class: "mt-2 rounded-lg bg-blue-600 px-3 py-2.5 text-center text-sm font-semibold text-white" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "mt-2 rounded-lg px-3 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 hover:text-blue-700" %>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Flash -->
    <% if notice.present? %>
      <div class="fixed left-1/2 top-20 z-[60] w-[calc(100%-2rem)] max-w-lg -translate-x-1/2" role="alert">
        <div class="flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm font-medium text-emerald-800 shadow-lg">
          <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="fixed left-1/2 top-20 z-[60] w-[calc(100%-2rem)] max-w-lg -translate-x-1/2" role="alert">
        <div class="flex items-center gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-medium text-red-800 shadow-lg">
          <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <%= alert %>
        </div>
      </div>
    <% end %>

    <div class="flex flex-1 flex-col">
      <%= yield %>
    </div>
    <%= render "shared/floating_actions" %>
  </body>
</html>
