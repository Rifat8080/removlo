<!DOCTYPE html>
<html>
  <head>
    <%= render "shared/google_analytics" %>
    <title><%= content_for(:title) || "Removlo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "images/icon.svg", type: "image/svg+xml" %>
    <link rel="apple-touch-icon" href="<%= asset_path("images/icon.svg") %>">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "builds/tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "stylesheets/application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-900">
    <!-- Modern Navigation -->
    <nav class="sticky top-0 z-50 bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 border-b border-slate-700 shadow-lg">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <div class="flex-shrink-0">
            <%= link_to root_path, class: "flex items-center group" do %>
              <%= image_tag "images/logo.svg", alt: "Removlo - Moving Made Simple", class: "h-auto w-32 brightness-0 invert transition duration-300 group-hover:-translate-y-0.5 sm:w-40 lg:w-44" %>
            <% end %>
          </div>

          <!-- Center Navigation Links -->
          <div class="hidden md:flex items-center gap-8">
            <%= link_to "Home", root_path, class: "text-slate-300 hover:text-white transition-colors duration-200" %>
            <%= link_to "Services", "#services", class: "text-slate-300 hover:text-white transition-colors duration-200" %>
            <%= link_to "About", "#about", class: "text-slate-300 hover:text-white transition-colors duration-200" %>
            <%= link_to "Contact", "#contact", class: "text-slate-300 hover:text-white transition-colors duration-200" %>
          </div>

          <!-- Right Side - Auth Buttons -->
          <div class="flex items-center gap-3">
            <% if user_signed_in? %>
              <%= link_to "Dashboard", dashboard_path, class: "px-4 py-2 text-slate-300 hover:text-white transition-colors" %>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete, form: { class: 'inline' }, class: "px-4 py-2 rounded-lg bg-red-600/20 text-red-400 border border-red-500/30 hover:bg-red-600/30 transition-all" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "px-4 py-2 text-slate-300 hover:text-white transition-colors" %>
              <%= link_to "Get Started", new_user_registration_path, class: "px-6 py-2 rounded-lg bg-gradient-to-r from-cyan-400 to-blue-500 text-white font-semibold hover:shadow-lg hover:shadow-cyan-500/20 transition-all" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if notice.present? %>
      <p class="notice bg-green-900 border border-green-700 text-green-200 px-4 py-3 rounded-lg m-4"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="alert bg-red-900 border border-red-700 text-red-200 px-4 py-3 rounded-lg m-4"><%= alert %></p>
    <% end %>

    <%= yield %>
    <%= render "shared/floating_actions" %>
    <%= render "shared/cookie_consent_banner" %>
  </body>
</html>
