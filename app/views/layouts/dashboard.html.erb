<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "Dashboard — Removlo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <% google_maps_browser_key = ENV["GOOGLE_MAPS_BROWSER_KEY"].presence %>
    <% if google_maps_browser_key.present? %>
      <meta name="google-maps-browser-key" content="<%= google_maps_browser_key %>">
    <% end %>
    <%= favicon_link_tag "images/icon.svg", type: "image/svg+xml" %>
    <link rel="apple-touch-icon" href="<%= asset_path("images/icon.svg") %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-100 text-slate-700 antialiased">
    <%= turbo_stream_from current_user, :notifications %>
    <!-- Top navbar -->
    <nav class="fixed top-0 z-50 w-full border-b border-slate-200 bg-white">
      <div class="px-3 py-3 min-[1025px]:px-5">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <button data-drawer-target="dashboard-sidebar" data-drawer-toggle="dashboard-sidebar" aria-controls="dashboard-sidebar" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-slate-500 hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-200 min-[1025px]:hidden">
              <span class="sr-only">Open sidebar</span>
              <svg class="h-5 w-5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20"><path clip-rule="evenodd" fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zm0 10.5a.75.75 0 01.75-.75h7.5a.75.75 0 010 1.5h-7.5a.75.75 0 01-.75-.75zM2 10a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 10z"/></svg>
            </button>
            <%= link_to root_path, class: "flex h-10 w-40 shrink-0 items-center overflow-hidden min-[1025px]:w-44" do %>
              <%= image_tag "images/logo.svg", alt: "Removlo - Moving Made Simple", class: "h-full w-full object-cover object-center" %>
            <% end %>
          </div>

          <div class="flex items-center gap-3">
            <% primary_path = current_user.customer? ? new_quotation_path : (current_user.driver? ? driver_jobs_path : new_admin_quotation_path) %>
            <%= link_to(primary_path, class: "hidden items-center gap-2 rounded-lg bg-gradient-to-br from-indigo-600 to-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30 transition hover:shadow-xl min-[1025px]:inline-flex") do %>
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              <%= current_user.customer? ? "Request quote" : (current_user.driver? ? "My jobs" : "New quote") %>
            <% end %>
            <%= link_to notifications_path, class: "relative flex h-10 w-10 items-center justify-center rounded-full text-slate-500 transition hover:bg-slate-100 hover:text-indigo-700" do %>
              <span class="sr-only">Notifications</span>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0h6z"/></svg>
              <%= render "notifications/top_badge", user: current_user %>
            <% end %>
            <button type="button" class="flex items-center gap-2 rounded-full p-1 pr-3 text-sm transition hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-200" data-dropdown-toggle="user-dropdown">
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-indigo-600 to-blue-600 text-sm font-bold text-white">
                <%= current_user.email.to_s[0, 1].upcase %>
              </span>
              <span class="hidden max-w-[10rem] truncate font-medium text-slate-700 min-[1025px]:block"><%= current_user.email %></span>
              <svg class="hidden h-3 w-3 text-slate-400 min-[1025px]:block" fill="none" viewBox="0 0 10 6"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1l4 4 4-4"/></svg>
            </button>
            <div id="user-dropdown" class="z-50 hidden w-56 list-none divide-y divide-slate-100 rounded-xl border border-slate-200 bg-white text-base shadow-xl">
              <div class="px-4 py-3">
                <p class="text-sm text-slate-500">Signed in as</p>
                <p class="truncate text-sm font-semibold text-slate-900"><%= current_user.email %></p>
              </div>
              <ul class="py-1">
                <li><%= link_to "Dashboard", dashboard_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Messages", conversations_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Notifications", notifications_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                <% if current_user.customer? %>
                  <li><%= link_to "My quotations", quotations_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "My invoices", customer_invoices_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Material orders", material_orders_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Shop materials", shop_products_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                <% end %>
                <% if current_user.driver? %>
                  <li><%= link_to "My jobs", driver_jobs_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Availability", driver_availabilities_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Wallet", driver_wallet_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                <% end %>
                <% if current_user.admin? || current_user.staff? || current_user.driver? %>
                  <li><%= link_to "My payslips", payslips_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                <% end %>
                <% if current_user.operator? %>
                  <li><%= link_to "Control panel", admin_root_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Quotations", admin_quotations_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Support panel", admin_support_conversations_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                <% end %>
                <% if current_user.admin? %>
                  <li><%= link_to "Accounting", admin_accounting_root_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Shop products", admin_shop_products_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Shop orders", admin_shop_material_orders_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Blog posts", admin_blog_posts_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                  <li><%= link_to "Users", admin_users_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
                <% end %>
                <li><%= link_to "Account settings", edit_user_registration_path, class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %></li>
              </ul>
              <div class="py-1">
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, form: { class: "block" }, class: "block w-full px-4 py-2 text-left text-sm text-red-600 hover:bg-red-50" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Sidebar -->
    <aside id="dashboard-sidebar" class="fixed left-0 top-0 z-40 h-screen w-72 -translate-x-full border-r border-slate-200 bg-white pt-16 shadow-xl shadow-slate-900/5 transition-transform min-[1025px]:translate-x-0 min-[1025px]:shadow-none" aria-label="Sidebar">
      <div class="flex h-full flex-col px-4 py-5">
        <% nav_groups = [
          ["Main", [
            ["Overview", dashboard_path, "grid", current_page?(dashboard_path)],
            ["Messages", conversations_path, "chat", controller_path == "conversations" || controller_path == "messages"],
            ["Notifications", notifications_path, "bell", controller_path == "notifications"]
          ]]
        ] %>
        <% work_links = [] %>
        <% work_links << ["My quotations", quotations_path, "doc", controller_path == "quotations"] if current_user.customer? %>
        <% work_links << ["My invoices", customer_invoices_path, "invoice", controller_path == "customer_invoices"] if current_user.customer? %>
        <% work_links << ["Material orders", material_orders_path, "shop", controller_path == "material_orders"] if current_user.customer? %>
        <% work_links << ["Shop", shop_products_path, "shop", controller_path.start_with?("shop/")] if current_user.customer? %>
        <% work_links << ["My jobs", driver_jobs_path, "truck", controller_path == "driver/jobs"] if current_user.driver? %>
        <% work_links << ["Availability", driver_availabilities_path, "calendar", controller_path == "driver/availabilities"] if current_user.driver? %>
        <% work_links << ["Wallet", driver_wallet_path, "invoice", controller_path == "driver/wallets"] if current_user.driver? %>
        <% work_links << ["My payslips", payslips_path, "invoice", controller_path == "payslips"] if current_user.admin? || current_user.staff? || current_user.driver? %>
        <% work_links << ["Control panel", admin_root_path, "grid", controller_path == "admin/dashboard"] if current_user.operator? %>
        <% work_links << ["Quotations", admin_quotations_path, "doc", controller_path.start_with?("admin/quotation")] if current_user.operator? %>
        <% work_links << ["Driver performance", admin_driver_performances_path, "users", controller_path == "admin/driver_performances"] if current_user.operator? %>
        <% work_links << ["Wallet payouts", admin_wallet_payouts_path, "invoice", controller_path == "admin/wallet_payouts"] if current_user.operator? %>
        <% work_links << ["Support panel", admin_support_conversations_path, "chat", controller_path == "admin/support_conversations"] if current_user.operator? %>
        <% work_links << ["Accounting", admin_accounting_root_path, "chart", controller_path.start_with?("admin/accounting")] if current_user.admin? %>
        <% nav_groups << ["Work", work_links] if work_links.any? %>
        <% admin_links = [] %>
        <% admin_links << ["Users", admin_users_path, "users", controller_path == "admin/users"] if current_user.admin? %>
        <% admin_links << ["Shop products", admin_shop_products_path, "shop", controller_path == "admin/shop/products"] if current_user.admin? %>
        <% admin_links << ["Shop orders", admin_shop_material_orders_path, "shop", controller_path == "admin/shop/material_orders"] if current_user.admin? %>
        <% admin_links << ["Blog posts", admin_blog_posts_path, "book", controller_path == "admin/blog_posts"] if current_user.admin? %>
        <% nav_groups << ["Admin", admin_links] if admin_links.any? %>
        <% nav_groups << ["Account", [["Settings", edit_user_registration_path, "cog", current_page?(edit_user_registration_path)]]] %>

        <div class="min-h-0 flex-1 space-y-5 overflow-y-auto pr-1">
          <% nav_groups.each do |group_label, links| %>
            <div>
              <p class="mb-2 px-2 text-[11px] font-black uppercase tracking-[0.2em] text-slate-400"><%= group_label %></p>
              <ul class="space-y-1.5">
                <% links.each do |label, href, icon, active| %>
                  <li>
                    <%= link_to href, class: "group flex items-center gap-3 rounded-2xl px-3 py-2.5 text-sm font-semibold transition #{active ? 'bg-gradient-to-r from-indigo-600 to-blue-600 text-white shadow-lg shadow-indigo-600/25' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-950'}" do %>
                      <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl <%= active ? 'bg-white/15 text-white' : 'bg-slate-50 text-slate-400 group-hover:bg-indigo-50 group-hover:text-indigo-600' %>">
                        <% case icon
                           when "grid" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                        <% when "truck" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8h4l3 3v5a1 1 0 01-1 1h-1"/></svg>
                        <% when "doc" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        <% when "invoice" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14h6m-6 4h6M7 4h10a2 2 0 012 2v14l-3-2-3 2-3-2-3 2V6a2 2 0 012-2z"/></svg>
                        <% when "users" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1m0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                        <% when "bell" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0h6z"/></svg>
                        <% when "chart" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3v18m4-14v14m4-10v10M7 13v8M3 17v4"/></svg>
                        <% when "shop" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                        <% when "book" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18s-3.332.477-4.5 1.253"/></svg>
                        <% when "cog" %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <% else %><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        <% end %>
                      </span>
                      <span class="min-w-0 flex-1 truncate"><%= label %></span>
                      <%= render "notifications/sidebar_badge", user: current_user if label == "Notifications" %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>

        <div class="mt-4 shrink-0 rounded-2xl bg-gradient-to-br from-indigo-600 to-blue-600 p-4 text-white shadow-lg shadow-indigo-600/25">
          <p class="text-sm font-semibold">Need a hand?</p>
          <p class="mt-1 text-xs text-indigo-100">Your coordinator is one message away.</p>
          <a href="mailto:hello@removlo.co.uk" class="mt-3 inline-flex w-full items-center justify-center rounded-lg bg-white/15 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white/25">Contact support</a>
        </div>
        <div data-controller="push-notifications" class="mt-3 shrink-0 rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-900">Background alerts</p>
          <p class="mt-1 text-xs leading-5 text-slate-500">Get native browser alerts for jobs, payments, quotes, and account activity even when Removlo is closed.</p>
          <button data-push-notifications-target="button" data-action="push-notifications#subscribe" type="button" class="mt-3 inline-flex w-full items-center justify-center rounded-lg bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm ring-1 ring-slate-200 transition hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-60">
            <span data-push-notifications-target="status">Enable alerts</span>
          </button>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <div class="p-4 pt-20 min-[1025px]:ml-72">
      <% if notice.present? %>
        <div class="mb-4 flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm font-medium text-emerald-800" role="alert">
          <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 flex items-center gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-medium text-red-800" role="alert">
          <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </div>
    <%= render "shared/floating_actions" %>
  </body>
</html>
