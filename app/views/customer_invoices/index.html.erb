<% content_for(:title, "My invoices — Removlo") %>

<div class="mb-6">
  <h1 class="text-2xl font-extrabold text-slate-900">My invoices</h1>
  <p class="mt-1 text-sm text-slate-500">Payment invoices and refund invoices for your moves.</p>
</div>

<div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm">
  <div class="divide-y divide-slate-100">
    <% @invoices.each do |invoice| %>
      <div class="grid gap-3 px-5 py-4 min-[1025px]:grid-cols-[1fr_auto_auto] min-[1025px]:items-center">
        <div>
          <div class="flex flex-wrap items-center gap-2">
            <p class="font-semibold text-slate-900"><%= invoice.invoice_number %></p>
            <%= invoice_status_badge(invoice.status) %>
            <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-semibold text-slate-600"><%= invoice.invoice_type.humanize %></span>
          </div>
          <p class="mt-1 text-xs text-slate-400"><%= invoice.issued_on.strftime("%d %b %Y") %><% if invoice.quotation.present? %> · <%= invoice.quotation.reference %><% end %></p>
        </div>
        <span class="font-semibold text-slate-900"><%= money_from_cents(invoice.amount_cents) %></span>
        <div class="flex flex-wrap gap-2">
          <%= link_to "PDF", pdf_customer_invoice_path(invoice), class: "rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-800" %>
          <%= link_to "View", customer_invoice_path(invoice), class: "rounded-lg border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
        </div>
      </div>
    <% end %>
    <% if @invoices.empty? %>
      <div class="px-5 py-12 text-center">
        <p class="font-semibold text-slate-900">No invoices yet</p>
        <p class="mt-1 text-sm text-slate-500">Invoices appear here when payments are recorded on your quotations.</p>
      </div>
    <% end %>
  </div>
</div>
