<% content_for :title, "My jobs — Removlo" %>

<div class="mx-auto max-w-7xl space-y-6">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl">
    <h1 class="text-3xl font-black">Driver workspace</h1>
    <p class="mt-2 text-sm text-slate-300">Open jobs for offers and your assigned confirmed moves.</p>
  </div>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-black text-slate-900">Open jobs</h2>
    <div class="mt-4 divide-y divide-slate-100">
      <% @open_jobs.each do |job| %>
        <div class="flex items-center justify-between gap-3 py-4">
          <div>
            <p class="font-bold text-slate-900"><%= job.reference %></p>
            <p class="text-sm text-slate-500"><%= job.driver_visible_collection_label %> → <%= job.driver_visible_delivery_label %></p>
            <p class="text-xs text-slate-500"><%= job.preferred_move_date&.to_fs(:long) || "Date TBC" %> · <%= job.vehicle_required&.humanize || "Vehicle TBC" %></p>
          </div>
          <%= link_to "Submit offer", driver_job_path(job), class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-bold text-white" %>
        </div>
      <% end %>
      <% if @open_jobs.empty? %>
        <p class="py-4 text-sm text-slate-500">No open jobs right now.</p>
      <% end %>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-black text-slate-900">Assigned jobs</h2>
    <div class="mt-4 divide-y divide-slate-100">
      <% @assigned_jobs.each do |job| %>
        <div class="flex items-center justify-between gap-3 py-4">
          <div>
            <p class="font-bold text-slate-900"><%= job.reference %></p>
            <p class="text-sm text-slate-500"><%= job.driver_visible_collection_label %> → <%= job.driver_visible_delivery_label %></p>
          </div>
          <%= link_to "Open", driver_job_path(job), class: "rounded-lg bg-slate-900 px-4 py-2 text-sm font-bold text-white" %>
        </div>
      <% end %>
      <% if @assigned_jobs.empty? %>
        <p class="py-4 text-sm text-slate-500">No assigned jobs yet.</p>
      <% end %>
    </div>
  </section>
</div>
