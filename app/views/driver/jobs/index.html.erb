<% content_for :title, "My jobs — Removlo" %>

<div class="mx-auto max-w-7xl">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-indigo-200">Driver workspace</p>
    <h1 class="mt-3 text-3xl font-black tracking-tight min-[1025px]:text-5xl">My assigned jobs</h1>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">Review confirmed moving jobs assigned to you by the operations team.</p>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white shadow-sm">
    <% if @jobs.any? %>
      <div class="divide-y divide-slate-100">
        <% @jobs.each do |job| %>
          <div class="grid gap-4 p-5 transition hover:bg-slate-50 min-[1025px]:grid-cols-[1.2fr_1fr_1fr_auto] min-[1025px]:items-center">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <%= quotation_status_badge(job.status) %>
                <%= quotation_payment_badge(job.payment_status) %>
              </div>
              <%= link_to job.reference, driver_job_path(job), class: "mt-3 block text-lg font-black text-slate-900 hover:text-indigo-700" %>
              <p class="mt-1 text-sm text-slate-500"><%= job.customer.email %></p>
            </div>

            <div class="text-sm text-slate-600">
              <p class="font-semibold text-slate-900"><%= job.pickup_postcode.presence || "Pickup" %> to <%= job.delivery_postcode.presence || "Delivery" %></p>
              <p class="mt-1"><%= job.move_size.humanize %> · <%= job.service_level.humanize %></p>
            </div>

            <div class="text-sm text-slate-600">
              <p class="font-semibold text-slate-900"><%= job.scheduled_at&.to_fs(:long) || job.preferred_move_date&.to_fs(:long) || "Schedule pending" %></p>
              <p class="mt-1">Assigned <%= job.updated_at.to_fs(:long) %></p>
            </div>

            <%= link_to "Open", driver_job_path(job), class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-indigo-700" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-10 text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8h4l3 3v5a1 1 0 01-1 1h-1"/></svg>
        </div>
        <h2 class="mt-4 text-xl font-black text-slate-900">No assigned jobs yet</h2>
        <p class="mt-2 text-sm text-slate-500">Confirmed jobs will appear here when operations assigns them to you.</p>
      </div>
    <% end %>
  </div>
</div>
