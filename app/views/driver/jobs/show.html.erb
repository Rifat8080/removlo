<% content_for :title, "#{@job.reference} — Driver job" %>

<div class="mx-auto max-w-7xl">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl">
    <h1 class="text-3xl font-black"><%= @job.reference %></h1>
    <p class="mt-2 text-sm text-slate-300">Customer details hidden until booking is confirmed and paid.</p>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 min-[1025px]:grid-cols-5">
    <div class="rounded-2xl border bg-white p-4"><p class="text-xs uppercase text-slate-400">Collection</p><p class="mt-2 font-black"><%= @job.driver_visible_collection_label %></p></div>
    <div class="rounded-2xl border bg-white p-4"><p class="text-xs uppercase text-slate-400">Delivery</p><p class="mt-2 font-black"><%= @job.driver_visible_delivery_label %></p></div>
    <div class="rounded-2xl border bg-white p-4"><p class="text-xs uppercase text-slate-400">Date</p><p class="mt-2 font-black"><%= @job.preferred_move_date&.to_fs(:long) || @job.scheduled_at&.to_fs(:long) || "TBC" %></p></div>
    <div class="rounded-2xl border bg-white p-4"><p class="text-xs uppercase text-slate-400">Property</p><p class="mt-2 font-black"><%= @job.property_type&.humanize || @job.move_size.humanize %></p></div>
    <div class="rounded-2xl border bg-white p-4"><p class="text-xs uppercase text-slate-400">Expected duration</p><p class="mt-2 font-black"><%= @job.expected_duration_hours.present? ? "#{@job.expected_duration_hours} hours" : "TBC" %></p></div>
  </div>

  <% if @job.assigned_driver == current_user && (@job.scheduled? || @job.in_progress? || @job.completed?) %>
    <section class="mt-6 rounded-2xl border border-indigo-200 bg-indigo-50 p-5 shadow-sm">
      <div class="flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.16em] text-indigo-700">Move workflow</p>
          <h2 class="mt-1 text-lg font-black text-slate-950"><%= @job.status.humanize %></h2>
          <p class="mt-1 text-sm font-semibold text-slate-600">Drivers control live job progress from here.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
          <% if @job.ready_to_start? %>
            <%= button_to "Start move", start_driver_job_path(@job), method: :patch, class: "inline-flex w-full items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-indigo-600/20 transition hover:-translate-y-0.5 hover:bg-indigo-700 sm:w-auto" %>
          <% elsif @job.ready_to_complete? %>
            <div data-controller="modal">
              <button type="button" data-action="modal#open" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-emerald-600/20 transition hover:-translate-y-0.5 hover:bg-emerald-700 sm:w-auto">
                Complete move
              </button>

              <dialog data-modal-target="dialog" data-action="click->modal#closeOnBackdrop" class="w-[min(92vw,32rem)] rounded-[1.75rem] border border-white/80 bg-white p-0 text-left shadow-2xl shadow-slate-950/25 backdrop:bg-slate-950/55">
                <div class="p-6">
                  <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m5 13 4 4L19 7"/></svg>
                  </div>
                  <h3 class="mt-4 text-2xl font-black tracking-[-0.03em] text-slate-950">Complete this move?</h3>
                  <p class="mt-2 text-sm font-medium leading-6 text-slate-600">
                    This will mark <span class="font-black text-slate-900"><%= @job.reference %></span> as completed, notify the customer, and record your job earning.
                  </p>
                  <div class="mt-6 flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
                    <button type="button" data-action="modal#close" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-black text-slate-700 transition hover:bg-slate-50">
                      Keep in progress
                    </button>
                    <%= button_to "Yes, complete move", complete_driver_job_path(@job), method: :patch, class: "inline-flex w-full items-center justify-center rounded-xl bg-emerald-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-emerald-600/20 transition hover:bg-emerald-700 sm:w-auto" %>
                  </div>
                </div>
              </dialog>
            </div>
          <% elsif @job.completed? %>
            <span class="inline-flex rounded-xl bg-emerald-100 px-5 py-3 text-sm font-black text-emerald-700 ring-1 ring-emerald-200">Completed</span>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <div class="mt-6 grid gap-6 min-[1025px]:grid-cols-[1.2fr_0.8fr]">
    <%= render "quotations/route_estimate", quotation: @job %>

    <% if @job.tracking_active? && @job.assigned_driver == current_user %>
      <%= turbo_stream_from @job, :driver_tracking %>
      <div
        class="min-[1025px]:col-span-2"
        data-controller="driver-tracking"
        data-driver-tracking-url-value="<%= driver_job_location_path(@job) %>"
        data-driver-tracking-auto-start-value="<%= @job.in_progress? %>"
        data-driver-tracking-locked-value="<%= @job.in_progress? %>">
        <%= render "driver/jobs/tracking_panel", quotation: @job, location: @job.latest_driver_location %>
      </div>
    <% end %>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm min-[1025px]:col-span-2">
      <h2 class="text-lg font-black text-slate-900">Route and access</h2>
      <div class="mt-4 grid gap-4 min-[1025px]:grid-cols-2">
        <div class="rounded-2xl bg-slate-50 p-4">
          <p class="text-xs font-semibold uppercase text-slate-400">Pickup</p>
          <p class="mt-2 text-sm font-semibold text-slate-900"><%= @job.driver_visible_pickup_address %></p>
          <% if (pickup_url = safe_google_url(@job.google_maps_pickup_url)).present? %>
            <%= link_to "Directions to pickup", pickup_url, target: "_blank", rel: "noopener", class: "mt-3 inline-flex text-xs font-black text-indigo-700 hover:underline" %>
          <% end %>
        </div>
        <div class="rounded-2xl bg-slate-50 p-4">
          <p class="text-xs font-semibold uppercase text-slate-400">Delivery</p>
          <p class="mt-2 text-sm font-semibold text-slate-900"><%= @job.driver_visible_delivery_address %></p>
          <% if (delivery_url = safe_google_url(@job.google_maps_delivery_url)).present? %>
            <%= link_to "Directions to delivery", delivery_url, target: "_blank", rel: "noopener", class: "mt-3 inline-flex text-xs font-black text-indigo-700 hover:underline" %>
          <% end %>
        </div>
      </div>
      <% if (directions_url = safe_google_url(@job.google_directions_url)).present? %>
        <%= link_to "Open full route in Google Maps", directions_url, target: "_blank", rel: "noopener", class: "mt-4 inline-flex rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-black text-white" %>
      <% end %>
      <p class="mt-4 text-sm text-slate-600"><%= @job.access_notes.presence || "No access notes recorded." %></p>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm min-[1025px]:col-span-2">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-lg font-black text-slate-900">Item list</h2>
          <p class="mt-1 text-sm text-slate-500">Review the items the customer listed for this move.</p>
        </div>
        <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-black text-indigo-700"><%= pluralize(@job.quotation_items.count, "item") %></span>
      </div>

      <% items = @job.quotation_items.order(created_at: :asc) %>
      <% if items.any? %>
        <div class="mt-5 grid gap-3 min-[1025px]:grid-cols-2">
          <% items.each do |item| %>
            <div class="rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-100">
              <div class="flex flex-wrap items-center gap-2">
                <p class="font-black text-slate-900"><%= item.quantity %> x <%= item.name %></p>
                <% if item.fragile? %>
                  <span class="rounded-full bg-rose-100 px-2 py-0.5 text-xs font-black text-rose-700">Fragile</span>
                <% end %>
              </div>
              <p class="mt-2 text-sm text-slate-500"><%= item.notes.presence || "No item notes." %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-5 rounded-2xl bg-slate-50 p-4 text-sm font-semibold text-slate-500 ring-1 ring-slate-100">No item list has been added yet.</p>
      <% end %>
    </section>

    <% if @job.awaiting_driver_offers? %>
      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-black text-slate-900">Submit offer</h2>
        <p class="mt-1 text-sm text-slate-500">Your bid is private. Other drivers cannot see it. Bidding stays open even while negotiated prices are being confirmed.</p>
        <% if @offer.pending_renegotiation? %>
          <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 p-4">
            <p class="text-xs font-black uppercase tracking-wide text-amber-700">Negotiated price request</p>
            <p class="mt-2 text-sm font-semibold text-amber-900">The customer negotiation is approved at <span class="font-black"><%= money_from_cents(@offer.renegotiation_price_cents) %></span>. Accept to update your bid to this amount.</p>
            <%= button_to "Accept negotiated price", accept_negotiation_driver_job_offer_path(@job, @offer), method: :patch, class: "mt-3 inline-flex w-full items-center justify-center rounded-xl bg-amber-600 px-4 py-2.5 text-sm font-black text-white transition hover:bg-amber-700" %>
          </div>
        <% elsif @offer.accepted_renegotiation? %>
          <div class="mt-4 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-sm font-semibold text-emerald-800">
            Negotiated price accepted. Your current bid is <%= money_from_cents(@offer.amount_cents) %>.
          </div>
        <% end %>
        <% offer_path = @offer.persisted? ? driver_job_offer_path(@job, @offer) : driver_job_offers_path(@job) %>
        <% offer_method = @offer.persisted? ? :patch : :post %>
        <%= form_with(model: @offer, url: offer_path, method: offer_method, scope: :driver_offer, class: "mt-4 space-y-3") do |form| %>
          <%= form.label :amount, "Your offer (£)", class: "text-sm font-semibold text-slate-700" %>
          <%= form.number_field :amount, value: @offer.amount_cents.to_i.positive? ? @offer.amount : nil, min: 1, step: "0.01", class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm" %>
          <%= form.submit @offer.persisted? ? "Update offer" : "Submit offer", class: "w-full rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white" %>
        <% end %>
      </section>
    <% end %>

    <% if @job_chat_available %>
      <% if @job_conversation %>
        <%= render "conversations/chat_panel", conversation: @job_conversation, messages: @job_chat_messages %>
      <% else %>
        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-lg font-black text-slate-900">Job chat</h2>
          <p class="mt-1 text-sm text-slate-500">Message the customer through the platform without sharing contact details.</p>
          <%= button_to "Open job chat", conversations_path(quotation_id: @job.id), method: :post, class: "mt-4 rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white" %>
        </section>
      <% end %>
    <% end %>
  </div>
</div>
