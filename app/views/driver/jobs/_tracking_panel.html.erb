<% location ||= quotation.latest_driver_location %>
<% recent_locations = quotation.driver_locations.recent.limit(5) %>

<section id="<%= dom_id(quotation, :driver_tracking_panel) %>" class="rounded-2xl border border-indigo-200 bg-indigo-50/70 p-5 shadow-sm">
  <div class="flex flex-col gap-3 min-[1025px]:flex-row min-[1025px]:items-start min-[1025px]:justify-between">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.16em] text-indigo-700">Live tracking</p>
      <h2 class="mt-1 text-lg font-black text-slate-950">Share location with customer</h2>
      <p class="mt-2 text-sm font-medium text-slate-600">Start sharing while this job is scheduled or in progress.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <% if quotation.google_maps_pickup_url %>
        <%= link_to "Pickup", quotation.google_maps_pickup_url, target: "_blank", rel: "noopener", class: "rounded-lg bg-white px-3 py-2 text-xs font-black text-slate-700 ring-1 ring-indigo-200" %>
      <% end %>
      <% if quotation.google_maps_delivery_url %>
        <%= link_to "Delivery", quotation.google_maps_delivery_url, target: "_blank", rel: "noopener", class: "rounded-lg bg-white px-3 py-2 text-xs font-black text-slate-700 ring-1 ring-indigo-200" %>
      <% end %>
      <% if quotation.google_directions_url %>
        <%= link_to "Full route", quotation.google_directions_url, target: "_blank", rel: "noopener", class: "rounded-lg bg-indigo-600 px-3 py-2 text-xs font-black text-white" %>
      <% end %>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    <button type="button" data-driver-tracking-target="startButton" data-action="driver-tracking#start" class="rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-black text-white">Start sharing</button>
    <button type="button" data-driver-tracking-target="stopButton" data-action="driver-tracking#stop" class="rounded-xl border border-indigo-200 bg-white px-4 py-2.5 text-sm font-black text-indigo-700">Stop sharing</button>
  </div>
  <p data-driver-tracking-target="status" class="mt-3 text-xs font-bold text-slate-500">Location sharing is off.</p>

  <div class="mt-5 grid gap-3 sm:grid-cols-3">
    <div class="rounded-xl bg-white p-4 ring-1 ring-indigo-100">
      <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Current ETA</p>
      <p class="mt-2 text-xl font-black text-indigo-700"><%= location&.eta_label || "—" %></p>
    </div>
    <div class="rounded-xl bg-white p-4 ring-1 ring-indigo-100">
      <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Destination</p>
      <p class="mt-2 text-sm font-black text-slate-950"><%= location&.eta_destination || (quotation.in_progress? ? "Delivery" : "Pickup") %></p>
    </div>
    <div class="rounded-xl bg-white p-4 ring-1 ring-indigo-100">
      <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Last update</p>
      <p class="mt-2 text-sm font-black text-slate-950"><%= location&.recorded_at&.to_fs(:long) || "Not yet" %></p>
    </div>
  </div>

  <% if recent_locations.any? %>
    <div class="mt-5">
      <p class="text-xs font-black uppercase tracking-wide text-slate-500">Tracking feed</p>
      <ul class="mt-3 space-y-2">
        <% recent_locations.each do |entry| %>
          <li class="rounded-xl bg-white px-3 py-2 text-xs font-semibold text-slate-600 ring-1 ring-indigo-100">
            <%= entry.recorded_at.to_fs(:long) %> · <%= entry.latitude.round(5) %>, <%= entry.longitude.round(5) %> · ETA <%= entry.eta_label %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</section>
