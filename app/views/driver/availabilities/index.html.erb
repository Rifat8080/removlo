<% content_for :title, "Availability — Removlo" %>

<div class="mx-auto max-w-4xl space-y-6">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white">
    <h1 class="text-3xl font-black">Availability calendar</h1>
    <p class="mt-2 text-sm text-slate-300">Keep your calendar up to date so you can respond quickly to new job alerts.</p>
  </div>

  <%= form_with(model: @availability, url: driver_availabilities_path, class: "rounded-2xl border bg-white p-5 shadow-sm space-y-3") do |form| %>
    <div class="grid gap-3 min-[1025px]:grid-cols-3">
      <%= form.date_field :available_on, class: "rounded-xl border px-3 py-2 text-sm" %>
      <%= form.select :status, DriverAvailability::STATUSES.keys.map { |s| [s.humanize, s] }, {}, class: "rounded-xl border px-3 py-2 text-sm" %>
      <%= form.text_field :notes, placeholder: "Notes", class: "rounded-xl border px-3 py-2 text-sm" %>
    </div>
    <%= form.submit "Save availability", class: "rounded-xl bg-indigo-600 px-4 py-2 text-sm font-bold text-white" %>
  <% end %>

  <div class="rounded-2xl border bg-white p-5 shadow-sm">
    <h2 class="text-lg font-black text-slate-900"><%= @month.strftime("%B %Y") %></h2>
    <div class="mt-4 space-y-2">
      <% @availabilities.each do |availability| %>
        <div class="flex items-center justify-between rounded-xl bg-slate-50 p-3">
          <div>
            <p class="font-semibold text-slate-900"><%= availability.available_on.to_fs(:long) %></p>
            <p class="text-sm text-slate-500"><%= availability.status.humanize %><% if availability.notes.present? %> · <%= availability.notes %><% end %></p>
          </div>
          <%= button_to "Remove", driver_availability_path(availability), method: :delete, class: "text-sm font-bold text-rose-600" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
