<% content_for :title, "#{@job.reference} — Driver job alert" %>
<% driver_view = user_signed_in? && current_user.driver? %>

<div class="relative overflow-hidden bg-[#f7f9ff] px-4 pb-12 pt-28 sm:px-6 lg:px-10 2xl:px-14">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-[28rem] bg-[radial-gradient(circle_at_18%_16%,rgba(37,99,235,0.14),transparent_28%),radial-gradient(circle_at_80%_10%,rgba(124,58,237,0.12),transparent_30%)]"></div>

  <div class="relative mx-auto w-full max-w-[1180px]">
    <div class="overflow-hidden rounded-[2rem] bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 text-white shadow-2xl shadow-indigo-950/20">
      <div class="grid gap-6 p-6 sm:p-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-3 py-1.5 text-xs font-black uppercase tracking-[0.16em] text-indigo-100">
            <span class="h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_0_4px_rgba(52,211,153,0.14)]"></span>
            Open job alert
          </span>
          <h1 class="mt-5 break-words text-3xl font-black tracking-tight sm:text-4xl lg:text-5xl"><%= @job.reference %></h1>
          <p class="mt-3 max-w-2xl text-sm font-medium leading-6 text-slate-300">Review the move details, sign in as a driver, and submit a private offer through Removlo.</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
          <p class="text-xs font-black uppercase tracking-wide text-indigo-100">Bidding status</p>
          <p class="mt-2 text-lg font-black">Accepting offers</p>
          <p class="mt-1 text-xs text-slate-300">Driver bids are private.</p>
        </div>
      </div>
    </div>

    <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_22rem] lg:items-start">
      <div class="space-y-6">
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          <% [
            ["Move date", @job.preferred_move_date&.to_fs(:long) || @job.scheduled_at&.to_fs(:long) || "TBC"],
            ["Property", @job.property_type&.humanize || @job.move_size.humanize],
            ["Vehicle", @job.vehicle_required&.humanize || "TBC"],
            ["Duration", @job.expected_duration_hours.present? ? "#{@job.expected_duration_hours} hours" : "TBC"]
          ].each do |label, value| %>
            <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-900/5">
              <p class="text-[11px] font-black uppercase tracking-[0.16em] text-slate-400"><%= label %></p>
              <p class="mt-3 text-lg font-black text-slate-950"><%= value %></p>
            </div>
          <% end %>
        </div>

        <section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-900/5 sm:p-6">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.16em] text-indigo-600">Route details</p>
              <h2 class="mt-2 text-2xl font-black text-slate-950">Pickup and delivery</h2>
            </div>
            <p class="text-sm font-semibold text-slate-500"><%= driver_view ? "Detailed notes are shown after driver sign-in." : "Sign in as a driver to see protected job notes." %></p>
          </div>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="rounded-3xl border border-slate-100 bg-slate-50 p-5">
              <p class="text-[11px] font-black uppercase tracking-[0.16em] text-slate-400">Pickup</p>
              <p class="mt-3 whitespace-pre-line break-words text-sm font-bold leading-6 text-slate-950"><%= driver_view ? @job.driver_visible_pickup_address : @job.driver_visible_collection_label %></p>
              <% if @job.pickup_postcode.present? %>
                <span class="mt-3 inline-flex rounded-full bg-white px-3 py-1 text-xs font-black text-slate-600 ring-1 ring-slate-200">Postcode: <%= @job.pickup_postcode %></span>
              <% end %>
            </div>
            <div class="rounded-3xl border border-slate-100 bg-slate-50 p-5">
              <p class="text-[11px] font-black uppercase tracking-[0.16em] text-slate-400">Delivery</p>
              <p class="mt-3 whitespace-pre-line break-words text-sm font-bold leading-6 text-slate-950"><%= driver_view ? @job.driver_visible_delivery_address : @job.driver_visible_delivery_label %></p>
              <% if @job.delivery_postcode.present? %>
                <span class="mt-3 inline-flex rounded-full bg-white px-3 py-1 text-xs font-black text-slate-600 ring-1 ring-slate-200">Postcode: <%= @job.delivery_postcode %></span>
              <% end %>
            </div>
          </div>

          <div class="mt-6">
            <% if driver_view %>
              <div class="grid gap-4 md:grid-cols-2">
                <div class="rounded-2xl border border-slate-100 p-4">
                  <p class="text-sm font-black text-slate-950">Access notes</p>
                  <p class="mt-2 whitespace-pre-line break-words text-sm leading-6 text-slate-600"><%= @job.access_notes.presence || "No access notes recorded." %></p>
                </div>
                <div class="rounded-2xl border border-slate-100 p-4">
                  <p class="text-sm font-black text-slate-950">Customer notes</p>
                  <p class="mt-2 whitespace-pre-line break-words text-sm leading-6 text-slate-600"><%= @job.customer_notes.presence || "No customer notes recorded." %></p>
                </div>
              </div>
            <% else %>
              <div class="rounded-2xl border border-indigo-100 bg-indigo-50 p-4">
                <p class="text-sm font-black text-slate-950">Protected job details</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">Access notes and customer notes are available after signing in with a driver account.</p>
              </div>
            <% end %>
            </div>
          </div>
        </section>
      </div>

      <aside class="rounded-3xl border border-indigo-100 bg-white p-5 shadow-xl shadow-indigo-950/10 lg:sticky lg:top-24">
        <% if user_signed_in? && current_user.driver? %>
          <p class="text-xs font-black uppercase tracking-[0.16em] text-indigo-600">Driver offer</p>
          <h2 class="mt-2 text-2xl font-black text-slate-950">Submit your bid</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">Your bid is private. Other drivers cannot see it.</p>
          <% offer_path = @offer.persisted? ? driver_job_offer_path(@job, @offer) : driver_job_offers_path(@job) %>
          <% offer_method = @offer.persisted? ? :patch : :post %>
          <%= form_with(model: @offer, url: offer_path, method: offer_method, scope: :driver_offer, class: "mt-5 space-y-4") do |form| %>
            <div>
              <%= form.label :amount, "Your offer (£)", class: "text-sm font-black text-slate-800" %>
              <%= form.number_field :amount, value: @offer.amount_cents.to_i.positive? ? @offer.amount : nil, min: 1, step: "0.01", placeholder: "Example: 350.00", class: "mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-950 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-4 focus:ring-indigo-100" %>
            </div>
            <%= form.submit @offer.persisted? ? "Update offer" : "Submit offer", class: "w-full cursor-pointer rounded-2xl bg-gradient-to-r from-indigo-600 to-blue-600 px-4 py-3 text-sm font-black text-white shadow-lg shadow-indigo-600/25 transition hover:-translate-y-0.5 hover:shadow-xl" %>
          <% end %>
        <% elsif user_signed_in? %>
          <p class="text-xs font-black uppercase tracking-[0.16em] text-indigo-600">Driver access</p>
          <h2 class="mt-2 text-2xl font-black text-slate-950">Driver account required</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">Sign in with a driver account to submit a bid for this job.</p>
          <%= link_to "Open driver workspace", driver_jobs_path, class: "mt-5 inline-flex w-full items-center justify-center rounded-2xl bg-gradient-to-r from-indigo-600 to-blue-600 px-4 py-3 text-sm font-black text-white shadow-lg shadow-indigo-600/25 transition hover:-translate-y-0.5" %>
        <% else %>
          <p class="text-xs font-black uppercase tracking-[0.16em] text-indigo-600">Start bidding</p>
          <h2 class="mt-2 text-2xl font-black text-slate-950">Sign up as a driver</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">Create a free driver account, then return here to submit your offer.</p>
          <%= link_to "Create driver account",
              new_user_registration_path(role: "driver", return_to: public_job_path(@job.public_share_token)),
              class: "mt-5 inline-flex w-full items-center justify-center rounded-2xl bg-gradient-to-r from-indigo-600 to-blue-600 px-4 py-3 text-sm font-black text-white shadow-lg shadow-indigo-600/25 transition hover:-translate-y-0.5" %>
          <p class="mt-4 text-center text-sm text-slate-500">
            Already have an account?
            <%= link_to "Sign in", new_user_session_path, class: "font-black text-indigo-700 hover:text-indigo-800" %>
          </p>
        <% end %>
      </aside>
    </div>
  </div>
</div>
