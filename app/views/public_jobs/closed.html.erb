<% content_for :title, "Job closed — Removlo" %>

<div class="relative overflow-hidden bg-[#f7f9ff] px-4 pb-12 pt-28 sm:px-6 lg:px-10 2xl:px-14">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-[24rem] bg-[radial-gradient(circle_at_18%_16%,rgba(37,99,235,0.14),transparent_28%),radial-gradient(circle_at_80%_10%,rgba(124,58,237,0.12),transparent_30%)]"></div>

  <div class="relative mx-auto max-w-2xl rounded-[2rem] border border-slate-200 bg-white p-8 text-center shadow-2xl shadow-slate-900/10 sm:p-10">
    <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100 text-slate-500">
      <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </span>
    <h1 class="mt-5 text-3xl font-black text-slate-950">This job is no longer open</h1>
    <p class="mt-3 text-sm leading-6 text-slate-600">Bids are closed for <span class="font-black text-slate-900"><%= @job.reference %></span>. Contact Removlo if you still need help.</p>
    <%= link_to "Back to Removlo", root_path, class: "mt-6 inline-flex items-center justify-center rounded-2xl bg-gradient-to-r from-indigo-600 to-blue-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-indigo-600/25 transition hover:-translate-y-0.5" %>
  </div>
</div>
