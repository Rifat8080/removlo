<% content_for(:title, "Cart — Removlo") %>

<section class="bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 min-[1025px]:px-8 min-[1025px]:py-14">
  <div class="mb-8 flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-end min-[1025px]:justify-between">
    <div>
      <%= link_to "← Continue shopping", shop_products_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-700" %>
      <h1 class="mt-2 text-4xl font-black tracking-tight text-slate-900">Your cart</h1>
      <p class="mt-2 text-sm text-slate-500"><%= pluralize(@cart.item_count, "item") %> ready for checkout.</p>
    </div>
  </div>

  <% if @cart_items.any? %>
    <div class="grid gap-6 min-[1025px]:grid-cols-[1fr_380px]">
      <div class="space-y-4">
        <% @cart_items.each do |item| %>
          <div class="overflow-hidden rounded-3xl border border-slate-200/80 bg-white shadow-sm">
            <div class="grid gap-4 p-4 sm:grid-cols-[120px_1fr] min-[1025px]:items-center">
              <%= link_to shop_product_path(item.product), class: "aspect-square overflow-hidden rounded-2xl bg-slate-100" do %>
                <% if item.product.image.attached? %>
                  <%= image_tag item.product.image, class: "h-full w-full object-cover" %>
                <% else %>
                  <div class="flex h-full items-center justify-center text-slate-400">
                    <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  </div>
                <% end %>
              <% end %>

              <div class="min-w-0">
                <div class="flex flex-col gap-3 min-[1025px]:flex-row min-[1025px]:items-start min-[1025px]:justify-between">
                  <div>
                    <%= link_to item.product.name, shop_product_path(item.product), class: "text-lg font-extrabold text-slate-900 hover:text-indigo-700" %>
                    <p class="mt-1 text-sm text-slate-500"><%= item.product.product_category&.name || "Moving material" %> · <%= money_from_cents(item.unit_price_cents) %> each</p>
                  </div>
                  <p class="text-xl font-black text-slate-900"><%= money_from_cents(item.line_total_cents) %></p>
                </div>

                <div class="mt-4 flex flex-wrap items-center gap-3">
                  <%= form_with url: cart_item_path(item), method: :patch, local: true, class: "flex items-center overflow-hidden rounded-xl bg-slate-50 p-1 ring-1 ring-slate-200" do %>
                    <%= button_tag "-", name: "quantity", value: item.quantity - 1, type: "submit", aria: { label: "Decrease quantity for #{item.product.name}" }, class: "flex h-10 w-10 items-center justify-center rounded-lg text-lg font-black text-slate-700 transition hover:bg-white hover:text-indigo-700 hover:shadow-sm" %>
                    <span class="min-w-12 px-3 text-center text-sm font-black text-slate-900"><%= item.quantity %></span>
                    <%= button_tag "+", name: "quantity", value: item.quantity + 1, type: "submit", disabled: item.quantity >= item.product.stock_quantity, aria: { label: "Increase quantity for #{item.product.name}" }, class: "flex h-10 w-10 items-center justify-center rounded-lg text-lg font-black text-slate-700 transition hover:bg-white hover:text-indigo-700 hover:shadow-sm disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:bg-transparent disabled:hover:text-slate-700 disabled:hover:shadow-none" %>
                  <% end %>
                  <%= button_to "Remove", remove_cart_item_path(item), method: :delete, class: "rounded-lg px-3 py-2 text-sm font-bold text-rose-600 transition hover:bg-rose-50" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <aside class="h-fit rounded-3xl border border-slate-200/80 bg-white p-6 shadow-xl shadow-slate-900/5 min-[1025px]:sticky min-[1025px]:top-24">
        <h2 class="text-lg font-black text-slate-900">Order summary</h2>
        <div class="mt-5 space-y-3 text-sm">
          <div class="flex justify-between text-slate-600">
            <span>Subtotal</span>
            <span class="font-semibold text-slate-900"><%= money_from_cents(@cart.subtotal_cents) %></span>
          </div>
          <div class="flex justify-between text-slate-600">
            <span>Delivery</span>
            <span class="font-semibold text-slate-900">Choose at checkout</span>
          </div>
          <div class="border-t border-slate-100 pt-3">
            <div class="flex justify-between">
              <span class="font-bold text-slate-900">Total today</span>
              <span class="text-xl font-black text-indigo-700"><%= money_from_cents(@cart.subtotal_cents) %>+</span>
            </div>
          </div>
        </div>
        <%= link_to "Proceed to checkout", checkout_path, class: "mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-600 to-blue-600 px-6 py-4 text-sm font-black text-white shadow-lg shadow-indigo-600/30 transition hover:-translate-y-0.5 hover:shadow-xl" %>
        <p class="mt-3 text-center text-xs text-slate-400">Secure card payment. Collection is free; delivery is calculated next.</p>
      </aside>
    </div>
  <% else %>
    <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white/70 p-10 text-center shadow-sm">
      <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      </span>
      <h2 class="mt-4 text-xl font-black text-slate-900">Your cart is empty</h2>
      <p class="mx-auto mt-2 max-w-md text-sm text-slate-500">Add boxes, tape, bubble wrap, or a moving kit and come back here to checkout.</p>
      <%= link_to "Browse shop", shop_products_path, class: "mt-5 inline-flex rounded-2xl bg-gradient-to-br from-indigo-600 to-blue-600 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-600/30" %>
    </div>
  <% end %>
  </div>
</section>
