<% content_for :title, "Notifications — Removlo" %>

<div class="mx-auto max-w-5xl">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
    <div class="flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-indigo-200">Activity center</p>
        <h1 class="mt-3 text-3xl font-black tracking-tight min-[1025px]:text-5xl">Notifications</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">Track quotation, negotiation, payment, document, and account activity in one place.</p>
      </div>
      <% if current_user.notifications.unread.exists? %>
        <%= button_to "Mark all read", read_all_notifications_path, method: :patch, class: "inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 shadow-lg transition hover:bg-indigo-50" %>
      <% end %>
    </div>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white shadow-sm">
    <% if @notifications.any? %>
      <div class="divide-y divide-slate-100">
        <% @notifications.each do |notification| %>
          <div class="flex flex-col gap-4 p-5 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between <%= notification.read? ? 'bg-white' : 'bg-indigo-50/50' %>">
            <div class="flex gap-4">
              <span class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl <%= notification.read? ? 'bg-slate-100 text-slate-500' : 'bg-indigo-600 text-white' %>">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0h6z"/></svg>
              </span>
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <h2 class="font-black text-slate-900"><%= notification.title %></h2>
                  <% unless notification.read? %>
                    <span class="rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-bold text-indigo-700">New</span>
                  <% end %>
                </div>
                <% if notification.body.present? %>
                  <p class="mt-1 text-sm text-slate-600"><%= notification.body %></p>
                <% end %>
                <p class="mt-2 text-xs text-slate-400"><%= notification.event_type.humanize %> · <%= notification.created_at.to_fs(:long) %></p>
              </div>
            </div>
            <div class="flex gap-2 min-[1025px]:justify-end">
              <%= button_to notification.read? ? "Open" : "Read and open", read_notification_path(notification), method: :patch, class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-indigo-700" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-10 text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0h6z"/></svg>
        </div>
        <h2 class="mt-4 text-xl font-black text-slate-900">No notifications yet</h2>
        <p class="mt-2 text-sm text-slate-500">Important move activity will appear here as it happens.</p>
      </div>
    <% end %>
  </div>
</div>
