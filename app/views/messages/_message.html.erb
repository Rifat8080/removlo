<% viewer = local_assigns.key?(:viewer) ? local_assigns[:viewer] : nil %>
<% viewer ||= current_user if respond_to?(:current_user, true) %>
<% sent_by_viewer = message.sender_id == viewer&.id %>
<% sender_label = message.sender_label %>

<div id="<%= dom_id(message) %>" class="group flex items-end gap-2 <%= sent_by_viewer ? 'justify-end' : 'justify-start' %>">
  <% unless sent_by_viewer %>
    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-200 text-xs font-black uppercase text-slate-600">
      <%= sender_label.first %>
    </div>
  <% end %>

  <div class="max-w-[min(82%,42rem)]">
    <div class="mb-1 flex items-center gap-2 <%= sent_by_viewer ? 'justify-end' : 'justify-start' %>">
      <span class="text-xs font-bold text-slate-500"><%= sent_by_viewer ? "You" : sender_label %></span>
      <% if message.internal_only? %>
        <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-black uppercase tracking-wide text-amber-700">Internal</span>
      <% end %>
    </div>

    <div class="rounded-3xl px-4 py-3 shadow-sm ring-1 <%= sent_by_viewer ? 'rounded-br-md bg-gradient-to-br from-indigo-600 to-blue-600 text-white shadow-indigo-600/15 ring-indigo-500/20' : 'rounded-bl-md bg-white text-slate-800 ring-slate-200' %>">
      <p class="whitespace-pre-line break-words text-sm leading-6"><%= message.body %></p>
      <% if message.attachments.attached? %>
        <div class="mt-3 space-y-2">
          <% message.attachments.each do |attachment| %>
            <%= link_to attachment.filename.to_s, rails_blob_path(attachment, disposition: "attachment"), class: "block rounded-2xl px-3 py-2 text-xs font-bold #{sent_by_viewer ? 'bg-white/10 text-white hover:bg-white/20' : 'bg-slate-50 text-indigo-700 hover:bg-indigo-50'}" %>
          <% end %>
        </div>
      <% end %>
      <p class="mt-2 text-right text-[11px] <%= sent_by_viewer ? 'text-indigo-100' : 'text-slate-400' %>"><%= message.created_at.to_fs(:short) %></p>
    </div>
  </div>

  <% if sent_by_viewer %>
    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-xs font-black uppercase text-indigo-700">
      <%= viewer&.email&.first || "Y" %>
    </div>
  <% end %>
</div>
