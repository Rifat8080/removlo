<div id="<%= dom_id(message) %>" class="flex <%= message.sender_id == current_user&.id ? 'justify-end' : 'justify-start' %>">
  <div class="max-w-[80%] rounded-2xl px-4 py-3 <%= message.sender_id == current_user&.id ? 'bg-indigo-600 text-white' : 'bg-slate-100 text-slate-800' %>">
    <p class="text-xs font-bold opacity-80"><%= message.sender_label %></p>
    <p class="mt-1 whitespace-pre-line text-sm"><%= message.body %></p>
    <p class="mt-2 text-[11px] opacity-70"><%= message.created_at.to_fs(:short) %></p>
  </div>
</div>
