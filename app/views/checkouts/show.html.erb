<% content_for(:title, "Checkout — Removlo") %>

<section class="bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 min-[1025px]:px-8 min-[1025px]:py-14">
  <div class="mb-8">
    <%= link_to "← Back to cart", cart_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-700" %>
    <h1 class="mt-2 text-4xl font-black tracking-tight text-slate-900">Checkout</h1>
    <p class="mt-2 text-sm text-slate-500">Choose delivery or collection, then pay securely by card.</p>
  </div>

  <%= form_with model: @order, url: checkout_path, class: "grid gap-6 min-[1025px]:grid-cols-[1fr_380px]" do |f| %>
    <div class="space-y-6">
    <% if @order.errors.any? %>
      <div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800"><%= @order.errors.full_messages.to_sentence %></div>
    <% end %>

    <section class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-black text-slate-900">Contact</h2>
      <p class="mt-1 text-sm text-slate-500">We’ll send your receipt and order updates here.</p>
      <div class="mt-5">
        <%= f.label :customer_email, "Email address", class: "mb-2 block text-sm font-semibold text-slate-900" %>
        <%= f.email_field :customer_email, required: true, autocomplete: "email", placeholder: "you@example.com", class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
      </div>
    </section>

    <section class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-black text-slate-900">Fulfillment</h2>
      <p class="mt-1 text-sm text-slate-500">Pick delivery to your address or free collection.</p>

      <div class="mt-5">
        <%= f.label :fulfillment_type, "Delivery method", class: "mb-2 block text-sm font-semibold text-slate-900" %>
        <%= f.select :fulfillment_type, [["Delivery (+£5.00)", "delivery"], ["Collection (free)", "collection"]], {}, class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
      </div>

      <div class="mt-5 grid gap-4 min-[1025px]:grid-cols-2">
        <div>
          <%= f.label :delivery_name, "Full name", class: "mb-2 block text-sm font-semibold text-slate-900" %>
          <%= f.text_field :delivery_name, placeholder: "Mahadi Hasan", class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
        </div>
        <div>
          <%= f.label :delivery_phone, "Phone", class: "mb-2 block text-sm font-semibold text-slate-900" %>
          <%= f.telephone_field :delivery_phone, placeholder: "+44...", class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
        </div>
        <div class="min-[1025px]:col-span-2">
          <%= f.label :delivery_address, "Delivery address", class: "mb-2 block text-sm font-semibold text-slate-900" %>
          <%= f.text_area :delivery_address, placeholder: "Street, city, building notes", rows: 3, class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
        </div>
        <div>
          <%= f.label :delivery_postcode, "Postcode", class: "mb-2 block text-sm font-semibold text-slate-900" %>
          <%= f.text_field :delivery_postcode, placeholder: "SW1A 1AA", class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm uppercase transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
        </div>
        <div>
          <%= f.label :preferred_date, "Preferred date", class: "mb-2 block text-sm font-semibold text-slate-900" %>
          <%= f.date_field :preferred_date, class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
        </div>
        <div class="min-[1025px]:col-span-2">
          <%= f.label :preferred_window, "Preferred time window", class: "mb-2 block text-sm font-semibold text-slate-900" %>
          <%= f.text_field :preferred_window, placeholder: "Morning, afternoon, or any specific window", class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
        </div>
      </div>
    </section>

    <section class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-black text-slate-900">Notes</h2>
      <div class="mt-5 space-y-4">
        <div>
          <%= f.label :collection_instructions, "Collection notes", class: "mb-2 block text-sm font-semibold text-slate-900" %>
          <%= f.text_area :collection_instructions, rows: 2, placeholder: "Collection contact or timing notes if applicable", class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
        </div>
        <div>
          <%= f.label :customer_notes, "Order notes", class: "mb-2 block text-sm font-semibold text-slate-900" %>
          <%= f.text_area :customer_notes, rows: 2, placeholder: "Anything else we should know?", class: "block w-full rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
        </div>
      </div>
    </section>
    </div>

    <aside class="h-fit rounded-3xl border border-slate-200/80 bg-white p-6 shadow-xl shadow-slate-900/5 min-[1025px]:sticky min-[1025px]:top-24">
      <h2 class="text-lg font-black text-slate-900">Payment summary</h2>
      <div class="mt-5 space-y-3 text-sm">
        <div class="flex justify-between text-slate-600">
          <span>Items</span>
          <span class="font-semibold text-slate-900"><%= money_from_cents(@cart.subtotal_cents) %></span>
        </div>
        <div class="flex justify-between text-slate-600">
          <span>Delivery</span>
          <span class="font-semibold text-slate-900">£5.00 or free collection</span>
        </div>
        <div class="border-t border-slate-100 pt-3">
          <div class="flex justify-between">
            <span class="font-bold text-slate-900">Pay from</span>
            <span class="text-xl font-black text-indigo-700"><%= money_from_cents(@cart.subtotal_cents) %></span>
          </div>
        </div>
      </div>
      <%= f.submit "Pay securely with card", class: "mt-6 w-full cursor-pointer rounded-2xl bg-gradient-to-br from-indigo-600 to-blue-600 py-4 text-sm font-black text-white shadow-lg shadow-indigo-600/30 transition hover:-translate-y-0.5 hover:shadow-xl" %>
      <p class="mt-3 text-center text-xs text-slate-400">You’ll be redirected to Stripe Checkout.</p>
    </aside>
  <% end %>
  </div>
</section>
