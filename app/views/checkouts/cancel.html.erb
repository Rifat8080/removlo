<section class="mx-auto max-w-xl px-4 py-16 text-center">
  <h1 class="text-2xl font-bold text-slate-900">Checkout cancelled</h1>
  <p class="mt-2 text-slate-500">Your payment was not completed<% if @order.present? %> for order <%= @order.order_number %><% end %>.</p>
  <%= link_to "Return to cart", cart_path, class: "mt-6 inline-flex rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white" %>
</section>
