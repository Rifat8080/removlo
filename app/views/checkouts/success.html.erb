<% content_for(:title, "Order confirmed — Removlo") %>

<section class="mx-auto max-w-2xl px-4 py-16 text-center">
  <h1 class="text-3xl font-black text-emerald-700">Order confirmed</h1>
  <p class="mt-3 text-slate-600">Thank you! Your order <strong><%= @order.order_number %></strong> has been received.</p>
  <p class="mt-2 text-lg font-bold text-slate-900"><%= money_from_cents(@order.total_cents) %></p>
  <div class="mt-8 flex flex-wrap justify-center gap-3">
    <% if user_signed_in? %>
      <%= link_to "View my orders", material_orders_path, class: "rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white" %>
      <%= link_to "Download receipt", pdf_material_order_path(@order), class: "rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700" if @order.customer_id == current_user.id %>
    <% end %>
    <%= link_to "Continue shopping", shop_products_path, class: "rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700" %>
  </div>
</section>
