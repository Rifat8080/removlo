<% content_for :title, "Blog — Removlo" %>

<main class="pt-20">
  <section class="relative overflow-hidden px-4 pb-14 pt-8 sm:px-6 min-[1025px]:px-8 min-[1025px]:pb-20 min-[1025px]:pt-14">
    <div class="pointer-events-none absolute left-1/2 top-0 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-indigo-200/40 blur-3xl"></div>
    <div class="mx-auto max-w-screen-xl">
      <div class="overflow-hidden rounded-[2rem] border border-white/70 bg-white/75 shadow-2xl shadow-indigo-900/5 backdrop-blur-xl">
        <div class="grid gap-8 p-6 sm:p-8 min-[1025px]:grid-cols-[1.15fr_0.85fr] min-[1025px]:items-center min-[1025px]:p-12">
          <div>
            <span class="inline-flex items-center gap-2 rounded-full border border-indigo-100 bg-indigo-50 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.22em] text-indigo-700">
              <span class="h-2 w-2 rounded-full bg-indigo-600"></span>
              Removlo journal
            </span>
            <h1 class="mt-5 max-w-3xl text-balance text-4xl font-black tracking-tight text-slate-950 sm:text-5xl min-[1025px]:text-6xl">Moving advice that makes every step clearer.</h1>
            <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">Practical guides, checklists, and Removlo updates for planning a smoother UK move from first quote to moving day.</p>
            <div class="mt-6 flex flex-wrap gap-2">
              <% ["Packing", "Planning", "Costs", "Moving day"].each do |topic| %>
                <span class="rounded-full bg-slate-100 px-3 py-1.5 text-xs font-bold text-slate-600"><%= topic %></span>
              <% end %>
            </div>
          </div>

          <div class="rounded-3xl bg-gradient-to-br from-indigo-600 via-blue-600 to-sky-500 p-6 text-white shadow-xl shadow-indigo-900/20">
            <p class="text-sm font-bold uppercase tracking-[0.25em] text-indigo-100">Featured workflow</p>
            <h2 class="mt-4 text-2xl font-black">Request, negotiate, confirm, move.</h2>
            <p class="mt-3 text-sm leading-6 text-indigo-50">Our blog will explain how to prepare details before requesting a quotation, what to check during negotiation, and how to get ready once your move is confirmed.</p>
            <div class="mt-6 grid grid-cols-2 gap-3">
              <% [["24h", "quote response"], ["4", "move stages"]].each do |value, label| %>
                <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                  <p class="text-2xl font-black"><%= value %></p>
                  <p class="mt-1 text-xs font-semibold text-indigo-100"><%= label %></p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <% if @blog_posts.any? %>
        <div class="mt-10 grid gap-6 min-[1025px]:grid-cols-3">
          <% @blog_posts.each do |post| %>
            <article class="soft-shine group flex h-full flex-col overflow-hidden rounded-3xl border border-slate-200/80 bg-white shadow-sm transition duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-indigo-900/5">
              <% if post.cover_image.attached? %>
                <div class="h-52 overflow-hidden bg-slate-100">
                  <%= image_tag post.cover_image, alt: post.title, class: "h-full w-full object-cover transition duration-500 group-hover:scale-105" %>
                </div>
              <% else %>
                <div class="flex h-52 items-center justify-center bg-gradient-to-br from-indigo-100 via-blue-50 to-sky-100 text-indigo-600">
                  <svg class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v8a2 2 0 01-2 2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20v-8h-6V4"/></svg>
                </div>
              <% end %>

              <div class="flex flex-1 flex-col p-6">
                <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600"><%= post.published_at.to_fs(:long) %></p>
                <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-900 transition group-hover:text-indigo-700"><%= link_to post.title, blog_post_path(post) %></h2>
                <p class="mt-3 flex-1 text-sm leading-6 text-slate-600"><%= post.excerpt.presence || truncate(strip_tags(post.body), length: 150) %></p>
                <div class="mt-6 flex items-center justify-between border-t border-slate-100 pt-4">
                  <span class="text-sm font-semibold text-slate-500">By <%= post.author.email %></span>
                  <%= link_to "Read", blog_post_path(post), class: "text-sm font-bold text-indigo-600 hover:text-indigo-700" %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="mt-10 grid gap-6 min-[1025px]:grid-cols-[0.9fr_1.1fr]">
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
              <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v8a2 2 0 01-2 2z"/></svg>
            </div>
            <h2 class="mt-5 text-2xl font-black tracking-tight text-slate-900">No posts published yet</h2>
            <p class="mt-3 text-sm leading-6 text-slate-500">This space is ready for moving guides, checklists, quotation tips, and operational updates from the Removlo team.</p>
            <% if user_signed_in? && current_user.admin? %>
              <%= link_to "Create the first post", new_admin_blog_post_path, class: "mt-6 inline-flex items-center justify-center rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-600/25 transition hover:shadow-xl" %>
            <% end %>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <% [
              ["Before you request a quote", "What information helps the operations team prepare an accurate estimate."],
              ["How negotiation works", "What customers can ask about before accepting a quotation."],
              ["Preparing for moving day", "Access notes, packing priorities, and handover planning."],
              ["After your move is confirmed", "How driver assignment, schedule, and job updates come together."]
            ].each do |title, copy| %>
              <div class="rounded-3xl border border-slate-200/80 bg-white/80 p-6 shadow-sm backdrop-blur">
                <p class="text-sm font-black text-slate-900"><%= title %></p>
                <p class="mt-2 text-sm leading-6 text-slate-500"><%= copy %></p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</main>
