<% content_for :title, "#{@blog_post.title} — Removlo Blog" %>

<main class="pt-24">
  <article class="px-4 pb-16 pt-10 sm:px-6 min-[1025px]:px-8">
    <div class="mx-auto max-w-4xl">
      <%= link_to "Back to blog", blog_posts_path, class: "inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-600 shadow-sm transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" %>

      <header class="mt-8">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-indigo-600">Removlo journal</p>
        <h1 class="mt-4 text-balance text-4xl font-black tracking-tight text-slate-900 min-[1025px]:text-6xl"><%= @blog_post.title %></h1>
        <div class="mt-6 flex flex-wrap items-center gap-3 text-sm font-medium text-slate-500">
          <span>By <%= @blog_post.author.email %></span>
          <span class="h-1 w-1 rounded-full bg-slate-300"></span>
          <span><%= @blog_post.published_at.to_fs(:long) %></span>
        </div>
        <% if @blog_post.excerpt.present? %>
          <p class="mt-6 text-xl leading-8 text-slate-600"><%= @blog_post.excerpt %></p>
        <% end %>
      </header>

      <% if @blog_post.cover_image.attached? %>
        <div class="mt-10 overflow-hidden rounded-3xl border border-slate-200 bg-slate-100 shadow-xl shadow-indigo-900/5">
          <%= image_tag @blog_post.cover_image, alt: @blog_post.title, class: "max-h-[34rem] w-full object-cover" %>
        </div>
      <% end %>

      <div class="mt-10 rounded-3xl border border-slate-200 bg-white p-6 text-slate-700 shadow-sm sm:p-8 min-[1025px]:p-10">
        <div class="prose max-w-none">
          <%= simple_format(@blog_post.body, {}, wrapper_tag: "p") %>
        </div>
      </div>
    </div>
  </article>

  <% if @more_posts.any? %>
    <section class="border-t border-slate-200 bg-white/60 px-4 py-16 sm:px-6 min-[1025px]:px-8">
      <div class="mx-auto max-w-screen-xl">
        <div class="flex flex-col gap-3 min-[1025px]:flex-row min-[1025px]:items-end min-[1025px]:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-indigo-600">Related posts</p>
            <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-900">More moving advice</h2>
          </div>
          <%= link_to "View all posts", blog_posts_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-700" %>
        </div>

        <div class="mt-8 grid gap-6 min-[1025px]:grid-cols-3">
          <% @more_posts.each do |post| %>
            <article class="group overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-900/5">
              <% if post.cover_image.attached? %>
                <div class="h-44 overflow-hidden bg-slate-100">
                  <%= image_tag post.cover_image, alt: post.title, class: "h-full w-full object-cover transition duration-500 group-hover:scale-105" %>
                </div>
              <% else %>
                <div class="flex h-44 items-center justify-center bg-gradient-to-br from-indigo-100 via-blue-50 to-sky-100 text-indigo-600">
                  <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v8a2 2 0 01-2 2z"/></svg>
                </div>
              <% end %>
              <div class="p-6">
                <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600"><%= post.published_at.to_fs(:long) %></p>
                <h3 class="mt-3 text-xl font-black text-slate-900"><%= link_to post.title, blog_post_path(post), class: "hover:text-indigo-700" %></h3>
                <p class="mt-3 text-sm leading-6 text-slate-600"><%= post.excerpt.presence || truncate(strip_tags(post.body), length: 120) %></p>
                <%= link_to "Read related post", blog_post_path(post), class: "mt-5 inline-flex text-sm font-bold text-indigo-600 hover:text-indigo-700" %>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</main>
