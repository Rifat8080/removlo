<% if quotation.route_estimated? %>
  <section class="overflow-hidden rounded-[1.75rem] border border-blue-100 bg-gradient-to-br from-blue-50 via-white to-indigo-50 p-5 shadow-[0_18px_60px_rgba(30,64,175,0.10)]">
    <div class="flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-start min-[1025px]:justify-between">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.16em] text-blue-700">Route estimate</p>
        <h2 class="mt-1 text-lg font-black text-slate-950">Google route context</h2>
        <p class="mt-2 text-sm font-medium text-slate-600">Distance and drive time for staff pricing. Final quote price is set manually.</p>
      </div>
      <% if quotation.google_directions_url %>
        <%= link_to "Open full route", quotation.google_directions_url, target: "_blank", rel: "noopener", class: "inline-flex items-center justify-center rounded-xl bg-white px-4 py-2.5 text-sm font-black text-blue-700 ring-1 ring-blue-200 transition hover:bg-blue-100" %>
      <% end %>
    </div>
    <div class="mt-5 grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-white p-4 ring-1 ring-blue-100">
        <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Distance</p>
        <p class="mt-2 text-xl font-black text-slate-950"><%= quotation.route_distance_miles %> miles</p>
      </div>
      <div class="rounded-xl bg-white p-4 ring-1 ring-blue-100">
        <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Drive time</p>
        <p class="mt-2 text-xl font-black text-slate-950"><%= quotation.route_duration_label %></p>
      </div>
      <div class="rounded-xl bg-white p-4 ring-1 ring-blue-100">
        <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Route</p>
        <p class="mt-2 text-sm font-bold text-slate-700"><%= quotation.route_summary.presence || "Via Google Maps" %></p>
      </div>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      <% if quotation.google_maps_pickup_url %>
        <%= link_to "Navigate pickup", quotation.google_maps_pickup_url, target: "_blank", rel: "noopener", class: "rounded-lg bg-white px-3 py-2 text-xs font-black text-slate-700 ring-1 ring-slate-200 hover:text-blue-700" %>
      <% end %>
      <% if quotation.google_maps_delivery_url %>
        <%= link_to "Navigate delivery", quotation.google_maps_delivery_url, target: "_blank", rel: "noopener", class: "rounded-lg bg-white px-3 py-2 text-xs font-black text-slate-700 ring-1 ring-slate-200 hover:text-blue-700" %>
      <% end %>
    </div>
    <p class="mt-3 text-[11px] font-semibold text-slate-500">Estimated <%= quotation.route_estimated_at.to_fs(:long) %></p>
  </section>
<% elsif quotation.route_estimate_error.present? %>
  <section class="overflow-hidden rounded-[1.5rem] border border-amber-200 bg-gradient-to-br from-amber-50 to-white p-5 shadow-sm">
    <div class="flex items-start gap-3">
      <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/></svg>
      </span>
      <div>
        <p class="text-sm font-black text-amber-950">Route estimate is not ready yet</p>
        <p class="mt-1 text-sm font-medium leading-6 text-amber-800"><%= quotation.route_estimate_error %>. Your request is still saved and the team can review it manually.</p>
      </div>
    </div>
  </section>
<% end %>
