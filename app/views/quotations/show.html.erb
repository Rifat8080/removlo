<% content_for :title, "#{@quotation.reference} — Removlo" %>

<div class="mx-auto max-w-7xl">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
    <div class="flex flex-col gap-6 min-[1025px]:flex-row min-[1025px]:items-start min-[1025px]:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <%= quotation_status_badge(@quotation.status) %>
          <%= quotation_payment_badge(@quotation.payment_status) %>
        </div>
        <h1 class="mt-4 text-3xl font-black tracking-tight min-[1025px]:text-5xl"><%= @quotation.reference %></h1>
        <p class="mt-3 text-sm text-slate-300"><%= @quotation.pickup_postcode.presence || "Pickup" %> to <%= @quotation.delivery_postcode.presence || "Delivery" %></p>
      </div>
      <%= link_to "Back to my quotations", quotations_path, class: "inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 transition hover:bg-indigo-50" %>
    </div>

    <div class="mt-8 grid gap-3 sm:grid-cols-2 min-[1025px]:grid-cols-4">
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Quote price</p>
        <p class="mt-2 text-2xl font-black"><%= @quotation.quoted_price_cents.positive? ? money_from_cents(@quotation.quoted_price_cents) : "Pending" %></p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Deposit</p>
        <p class="mt-2 text-2xl font-black"><%= @quotation.deposit_cents.positive? ? money_from_cents(@quotation.deposit_cents) : "Pending" %></p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Move date</p>
        <p class="mt-2 text-lg font-black"><%= @quotation.preferred_move_date&.to_fs(:long) || @quotation.scheduled_at&.to_fs(:long) || "Not set" %></p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Booking status</p>
        <p class="mt-2 text-lg font-black"><%= @quotation.status.humanize %></p>
      </div>
    </div>
  </div>

  <div class="mt-6 space-y-6">
    <%= render "quotations/workflow_stepper", workflow_step: @workflow_step %>

    <div class="grid gap-6 min-[1025px]:grid-cols-[1.2fr_0.8fr]">
      <div class="space-y-6">
        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-lg font-black text-slate-900">Quote decision</h2>
          <p class="mt-1 text-sm text-slate-500">Once the team sends a price, you can accept, reject, or negotiate changes.</p>
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <%= button_to "Accept quote", accept_quotation_path(@quotation), method: :patch, disabled: !@quotation.quoted_price_cents.positive?, class: "inline-flex w-full items-center justify-center rounded-xl bg-emerald-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-700 disabled:cursor-not-allowed disabled:bg-slate-300" %>
            <%= button_to "Reject quote", reject_quotation_path(@quotation), method: :patch, disabled: !@quotation.quoted_price_cents.positive?, class: "inline-flex w-full items-center justify-center rounded-xl bg-rose-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-rose-700 disabled:cursor-not-allowed disabled:bg-slate-300" %>
            <a href="#negotiate" class="inline-flex w-full items-center justify-center rounded-xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm font-bold text-indigo-700 transition hover:bg-indigo-100">Negotiate</a>
          </div>
        </section>

        <% if @quotation.accepted? && @quotation.deposit_cents.positive? && !@quotation.deposit_protected? %>
          <section class="rounded-2xl border border-amber-200 bg-amber-50 p-5 shadow-sm">
            <h2 class="text-lg font-black text-amber-900">Pay deposit</h2>
            <p class="mt-1 text-sm text-amber-800">Secure your booking with a <%= money_from_cents(@quotation.deposit_cents) %> deposit. Your driver is assigned after payment.</p>
            <%= button_to "Pay deposit", deposit_checkout_quotation_path(@quotation), method: :post, class: "mt-4 inline-flex rounded-xl bg-amber-600 px-5 py-3 text-sm font-bold text-white" %>
          </section>
        <% end %>

        <% if @job_chat_available %>
          <% if @job_conversation %>
            <%= render "conversations/chat_panel", conversation: @job_conversation, messages: @job_chat_messages %>
          <% else %>
            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <h2 class="text-lg font-black text-slate-900">Job chat</h2>
              <p class="mt-1 text-sm text-slate-500">Message your assigned driver through the platform. No phone numbers shared.</p>
              <%= button_to "Open job chat", conversations_path(quotation_id: @quotation.id), method: :post, class: "mt-4 rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white" %>
            </section>
          <% end %>
        <% end %>

        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-lg font-black text-slate-900">Move details</h2>
          <div class="mt-5 grid gap-4 min-[1025px]:grid-cols-2">
            <div class="rounded-2xl bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Pickup</p>
              <p class="mt-2 whitespace-pre-line text-sm font-semibold text-slate-900"><%= @quotation.pickup_address %></p>
            </div>
            <div class="rounded-2xl bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Delivery</p>
              <p class="mt-2 whitespace-pre-line text-sm font-semibold text-slate-900"><%= @quotation.delivery_address %></p>
            </div>
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <section id="negotiate" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-lg font-black text-slate-900">Negotiation</h2>
          <%= form_with(url: request_changes_quotation_path(@quotation), method: :patch, scope: :quotation_note, class: "mt-4 space-y-3") do |form| %>
            <%= form.text_area :content, rows: 4, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm", placeholder: "Can we adjust the price, date, service, or inventory?" %>
            <%= form.submit "Send negotiation request", class: "inline-flex w-full items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white" %>
          <% end %>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-lg font-black text-slate-900">Invoices</h2>
          <div class="mt-5 space-y-3">
            <% @invoices.each do |invoice| %>
              <div class="flex items-center justify-between rounded-2xl bg-slate-50 p-4">
                <div>
                  <p class="font-semibold text-slate-900"><%= invoice.invoice_number %></p>
                  <p class="text-xs text-slate-500"><%= money_from_cents(invoice.amount_cents) %></p>
                </div>
                <%= link_to "View", customer_invoice_path(invoice), class: "text-xs font-semibold text-indigo-600" %>
              </div>
            <% end %>
            <% if @invoices.empty? %>
              <p class="rounded-2xl bg-slate-50 p-4 text-sm text-slate-500">Invoices will appear here when payments are recorded.</p>
            <% end %>
          </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-lg font-black text-slate-900">Messages</h2>
          <div class="mt-5 space-y-3">
            <% @quotation.quotation_notes.where(internal: false).order(created_at: :desc).each do |note| %>
              <div class="rounded-2xl bg-slate-50 p-4">
                <p class="whitespace-pre-line text-sm text-slate-700"><%= note.content %></p>
                <p class="mt-3 text-xs text-slate-500">Removlo team · <%= note.created_at.to_fs(:long) %></p>
              </div>
            <% end %>
          </div>
        </section>
      </aside>
    </div>
  </div>
</div>
