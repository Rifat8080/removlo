<% content_for :title, "My quotations — Removlo" %>

<div class="mx-auto max-w-7xl">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
    <div class="flex flex-col gap-5 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-indigo-200">Customer quotes</p>
        <h1 class="mt-3 text-3xl font-black tracking-tight min-[1025px]:text-5xl">My quotations</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">Track your move requests, review prices, negotiate changes, and accept your quote when you are ready.</p>
      </div>
      <%= link_to "Request quotation", new_quotation_path, class: "inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 shadow-lg transition hover:bg-indigo-50" %>
    </div>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white shadow-sm">
    <% if @quotations.any? %>
      <div class="divide-y divide-slate-100">
        <% @quotations.each do |quotation| %>
          <div class="grid gap-4 p-5 transition hover:bg-slate-50 min-[1025px]:grid-cols-[1.2fr_1fr_1fr_auto] min-[1025px]:items-center">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <%= quotation_status_badge(quotation.status) %>
                <%= quotation_payment_badge(quotation.payment_status) %>
              </div>
              <%= link_to quotation.reference, quotation_path(quotation), class: "mt-3 block text-lg font-black text-slate-900 hover:text-indigo-700" %>
              <p class="mt-1 text-sm text-slate-500">Requested <%= quotation.created_at.to_fs(:long) %></p>
            </div>

            <div class="text-sm text-slate-600">
              <p class="font-semibold text-slate-900"><%= quotation.pickup_postcode.presence || "Pickup" %> to <%= quotation.delivery_postcode.presence || "Delivery" %></p>
              <p class="mt-1"><%= quotation.move_size.humanize %> · <%= quotation.service_level.humanize %></p>
            </div>

            <div class="text-sm text-slate-600">
              <p class="font-semibold text-slate-900"><%= quotation.quoted_price_cents.positive? ? money_from_cents(quotation.quoted_price_cents) : "Awaiting quote" %></p>
              <p class="mt-1">Preferred: <%= quotation.preferred_move_date&.to_fs(:long) || "Not set" %></p>
            </div>

            <%= link_to "View", quotation_path(quotation), class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-indigo-700" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-10 text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h2 class="mt-4 text-xl font-black text-slate-900">No quotation requests yet</h2>
        <p class="mt-2 text-sm text-slate-500">Start with your move details and our team will prepare the quote.</p>
        <%= link_to "Request quotation", new_quotation_path, class: "mt-5 inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-indigo-700" %>
      </div>
    <% end %>
  </div>
</div>
