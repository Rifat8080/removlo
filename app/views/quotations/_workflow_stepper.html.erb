<section class="overflow-hidden rounded-[1.75rem] border border-white/80 bg-white p-5 shadow-[0_18px_60px_rgba(15,23,42,0.08)] ring-1 ring-slate-200/70">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.18em] text-indigo-600">Move journey</p>
      <h2 class="mt-1 text-xl font-black tracking-[-0.03em] text-slate-950">Your booking progress</h2>
    </div>
    <p class="text-xs font-bold text-slate-500">Step <%= customer_workflow_step_index(workflow_step) + 1 %> of <%= customer_workflow_steps.size %></p>
  </div>
  <% current_index = customer_workflow_step_index(workflow_step) %>
  <div class="mt-5 grid gap-3 sm:grid-cols-5">
    <% customer_workflow_steps.each_with_index do |(key, label), index| %>
      <% active = index == current_index %>
      <% complete = index < current_index %>
      <div class="relative overflow-hidden rounded-2xl border px-3 py-4 text-center transition <%= active ? 'border-indigo-300 bg-indigo-50 shadow-lg shadow-indigo-600/10' : (complete ? 'border-emerald-200 bg-emerald-50' : 'border-slate-200 bg-slate-50/80') %>">
        <span class="mx-auto flex h-8 w-8 items-center justify-center rounded-full text-xs font-black <%= active ? 'bg-indigo-600 text-white' : (complete ? 'bg-emerald-500 text-white' : 'bg-white text-slate-500 ring-1 ring-slate-200') %>">
          <%= complete ? "✓" : index + 1 %>
        </span>
        <p class="mt-2 text-sm font-black <%= active ? 'text-indigo-700' : 'text-slate-900' %>"><%= label %></p>
        <p class="mt-1 text-[10px] font-bold uppercase tracking-wide <%= active ? 'text-indigo-500' : 'text-slate-400' %>"><%= active ? "Current" : (complete ? "Done" : "Upcoming") %></p>
      </div>
    <% end %>
  </div>
</section>
