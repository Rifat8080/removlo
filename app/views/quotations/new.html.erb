<% content_for :title, "Request a quotation — Removlo" %>
<% if ENV["GOOGLE_MAPS_BROWSER_KEY"].present? %>
  <% content_for :head do %>
    <meta name="google-maps-browser-key" content="<%= ENV.fetch("GOOGLE_MAPS_BROWSER_KEY") %>">
  <% end %>
<% end %>

<div class="mx-auto max-w-7xl">
  <div class="mb-6 flex flex-col gap-3 min-[1025px]:flex-row min-[1025px]:items-end min-[1025px]:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-indigo-600">Customer request</p>
      <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900">Request a quotation</h1>
      <p class="mt-2 text-sm text-slate-500">Send your move details and our team will prepare a tailored quote.</p>
    </div>
    <%= link_to "My quotations", quotations_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50" %>
  </div>

  <%= render "form", quotation: @quotation %>
</div>
