<%= form_with(model: quotation, data: { controller: "google-places quotation-items" }, class: "space-y-6") do |form| %>
  <% if quotation.errors.any? %>
    <div class="rounded-2xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      <p class="font-semibold"><%= pluralize(quotation.errors.count, "error") %> stopped this request from being sent:</p>
      <ul class="mt-2 list-inside list-disc">
        <% quotation.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-6 min-[1025px]:grid-cols-[1.3fr_0.8fr]">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-black text-slate-900">Tell us about your move</h2>
      <p class="mt-1 text-sm text-slate-500">Share enough detail for the team to prepare an accurate quote.</p>
      <p data-google-places-target="status" class="mt-2 text-xs font-bold text-slate-500">Start typing a postcode or use current location.</p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div>
          <%= form.label :move_size, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= form.select :move_size, Quotation::MOVE_SIZES.map { |size| [size.humanize, size] }, {}, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= form.label :service_level, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= form.select :service_level, Quotation::SERVICE_LEVELS.map { |level| [level.humanize, level] }, {}, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= form.label :preferred_move_date, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= form.date_field :preferred_move_date, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <div class="mb-2 flex items-center justify-between gap-3">
            <%= form.label :pickup_postcode, class: "block text-sm font-semibold text-slate-700" %>
            <button type="button" data-action="google-places#useCurrentLocation" data-google-places-input-param="quotation_pickup_postcode" class="text-[10px] font-black uppercase tracking-wide text-indigo-700 transition hover:text-indigo-900">Use current</button>
          </div>
          <%= form.text_field :pickup_postcode, data: { google_places_target: "postcode", google_places_address_field_id: "quotation_pickup_address" }, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "SW1A 1AA" %>
        </div>
        <div>
          <div class="mb-2 flex items-center justify-between gap-3">
            <%= form.label :delivery_postcode, class: "block text-sm font-semibold text-slate-700" %>
            <button type="button" data-action="google-places#useCurrentLocation" data-google-places-input-param="quotation_delivery_postcode" class="text-[10px] font-black uppercase tracking-wide text-indigo-700 transition hover:text-indigo-900">Use current</button>
          </div>
          <%= form.text_field :delivery_postcode, data: { google_places_target: "postcode", google_places_address_field_id: "quotation_delivery_address" }, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "M1 1AE" %>
        </div>
      </div>

      <div class="mt-4 grid gap-4 min-[1025px]:grid-cols-2">
        <div>
          <%= form.label :pickup_address, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= form.text_area :pickup_address, rows: 4, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Full pickup address" %>
        </div>
        <div>
          <%= form.label :delivery_address, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= form.text_area :delivery_address, rows: 4, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Full delivery address" %>
        </div>
      </div>

      <div class="mt-4 grid gap-4 min-[1025px]:grid-cols-2">
        <div>
          <%= form.label :access_notes, class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= form.text_area :access_notes, rows: 4, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Parking, stairs, lift access, timing limits" %>
        </div>
        <div>
          <%= form.label :customer_notes, "Inventory and special requirements", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= form.text_area :customer_notes, rows: 4, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Large items, fragile items, packing needs, storage needs" %>
        </div>
      </div>

      <div class="mt-6 rounded-2xl border border-indigo-100 bg-indigo-50/40 p-4">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h3 class="text-base font-black text-slate-900">Item list</h3>
            <p class="mt-1 text-sm text-slate-500">Add each item so the team can price your move more accurately.</p>
          </div>
          <button type="button" data-action="quotation-items#add" class="inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-indigo-700">Add item</button>
        </div>

        <div data-quotation-items-target="list" class="mt-4 space-y-3">
          <%= form.fields_for :quotation_items do |item_form| %>
            <div data-quotation-items-target="row" class="grid gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm min-[1025px]:grid-cols-[1fr_100px_auto_auto] min-[1025px]:items-end">
              <%= item_form.hidden_field :id if item_form.object.persisted? %>
              <%= item_form.hidden_field :_destroy, value: "0", data: { quotation_items_target: "destroyField" } %>
              <div>
                <%= item_form.label :name, "Item", class: "mb-2 block text-sm font-semibold text-slate-700" %>
                <%= item_form.text_field :name, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Sofa, boxes, piano" %>
              </div>
              <div>
                <%= item_form.label :quantity, class: "mb-2 block text-sm font-semibold text-slate-700" %>
                <%= item_form.number_field :quantity, min: 1, value: item_form.object.quantity || 1, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500" %>
              </div>
              <label class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-700">
                <%= item_form.check_box :fragile, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
                Fragile
              </label>
              <button type="button" data-action="quotation-items#remove" class="inline-flex items-center justify-center rounded-xl border border-rose-200 px-4 py-2.5 text-sm font-bold text-rose-600 transition hover:bg-rose-50">Remove</button>
              <div class="min-[1025px]:col-span-4">
                <%= item_form.label :notes, "Notes", class: "mb-2 block text-sm font-semibold text-slate-700" %>
                <%= item_form.text_field :notes, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Approx size, dismantling, special handling" %>
              </div>
            </div>
          <% end %>
        </div>

        <template data-quotation-items-target="template">
          <%= form.fields_for :quotation_items, QuotationItem.new(quantity: 1), child_index: "NEW_RECORD" do |item_form| %>
            <div data-quotation-items-target="row" class="grid gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm min-[1025px]:grid-cols-[1fr_100px_auto_auto] min-[1025px]:items-end">
              <%= item_form.hidden_field :_destroy, value: "0", data: { quotation_items_target: "destroyField" } %>
              <div>
                <%= item_form.label :name, "Item", class: "mb-2 block text-sm font-semibold text-slate-700" %>
                <%= item_form.text_field :name, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Sofa, boxes, piano" %>
              </div>
              <div>
                <%= item_form.label :quantity, class: "mb-2 block text-sm font-semibold text-slate-700" %>
                <%= item_form.number_field :quantity, min: 1, value: 1, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500" %>
              </div>
              <label class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-700">
                <%= item_form.check_box :fragile, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
                Fragile
              </label>
              <button type="button" data-action="quotation-items#remove" class="inline-flex items-center justify-center rounded-xl border border-rose-200 px-4 py-2.5 text-sm font-bold text-rose-600 transition hover:bg-rose-50">Remove</button>
              <div class="min-[1025px]:col-span-4">
                <%= item_form.label :notes, "Notes", class: "mb-2 block text-sm font-semibold text-slate-700" %>
                <%= item_form.text_field :notes, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Approx size, dismantling, special handling" %>
              </div>
            </div>
          <% end %>
        </template>
      </div>
    </div>

    <aside class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-black text-slate-900">What happens next?</h2>
      <div class="mt-5 space-y-4">
        <% [["1", "Request received", "Your request is sent to our operations team."], ["2", "Quote prepared", "Staff review the move details and send a price."], ["3", "Negotiate if needed", "You can ask questions or request changes before accepting."], ["4", "Move confirmed", "Once accepted, we schedule and complete your move."]].each do |step, title, copy| %>
          <div class="flex gap-3">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-indigo-50 text-sm font-black text-indigo-700"><%= step %></span>
            <div>
              <p class="text-sm font-bold text-slate-900"><%= title %></p>
              <p class="mt-1 text-sm text-slate-500"><%= copy %></p>
            </div>
          </div>
        <% end %>
      </div>
      <%= form.submit local_assigns.fetch(:submit_label, "Request quotation"), class: "mt-6 inline-flex w-full items-center justify-center rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-600/25 transition hover:shadow-xl" %>
    </aside>
  </div>
<% end %>
