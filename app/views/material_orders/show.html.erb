<% content_for(:title, "#{@order.order_number} — Removlo") %>

<div class="mb-6 overflow-hidden rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
  <div class="flex flex-col gap-5 min-[1025px]:flex-row min-[1025px]:items-start min-[1025px]:justify-between">
    <div>
      <%= link_to "← My orders", material_orders_path, class: "text-sm font-bold text-indigo-200 hover:text-white" %>
      <h1 class="mt-3 text-3xl font-black tracking-tight min-[1025px]:text-5xl"><%= @order.order_number %></h1>
      <p class="mt-2 text-sm text-slate-300">Ordered <%= @order.created_at.strftime("%d %b %Y") %> · <%= @order.fulfillment_type.humanize %></p>
      <div class="mt-4 flex flex-wrap gap-2">
        <%= material_order_status_badge(@order.status) %>
        <%= shop_payment_badge(@order.payment_status) %>
      </div>
    </div>
    <%= link_to "Export PDF", pdf_material_order_path(@order), class: "inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 shadow-lg transition hover:bg-indigo-50" %>
  </div>
</div>

<div class="grid gap-6 min-[1025px]:grid-cols-[0.9fr_1.1fr]">
  <div class="space-y-6">
    <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-black text-slate-900">Order summary</h2>
      <dl class="mt-5 space-y-4 text-sm">
        <div class="flex items-center justify-between gap-4"><dt class="text-slate-500">Subtotal</dt><dd class="font-bold text-slate-900"><%= money_from_cents(@order.subtotal_cents) %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="text-slate-500">Delivery fee</dt><dd class="font-bold text-slate-900"><%= money_from_cents(@order.delivery_fee_cents) %></dd></div>
        <div class="border-t border-slate-100 pt-4">
          <div class="flex items-center justify-between gap-4"><dt class="font-bold text-slate-900">Total</dt><dd class="text-2xl font-black text-indigo-700"><%= money_from_cents(@order.total_cents) %></dd></div>
        </div>
      </dl>
    </div>

    <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-black text-slate-900">Fulfillment</h2>
      <dl class="mt-5 space-y-3 text-sm">
        <div><dt class="text-slate-500">Method</dt><dd class="mt-1 font-semibold capitalize text-slate-900"><%= @order.fulfillment_type %></dd></div>
      <% if @order.delivery? %>
          <div><dt class="text-slate-500">Name</dt><dd class="mt-1 font-semibold text-slate-900"><%= @order.delivery_name.presence || "Not provided" %></dd></div>
          <div><dt class="text-slate-500">Address</dt><dd class="mt-1 text-slate-700"><%= @order.delivery_address %>, <%= @order.delivery_postcode %></dd></div>
          <div><dt class="text-slate-500">Preferred date</dt><dd class="mt-1 font-semibold text-slate-900"><%= @order.preferred_date&.strftime("%d %b %Y") || "Flexible" %></dd></div>
      <% else %>
          <div><dt class="text-slate-500">Collection notes</dt><dd class="mt-1 text-slate-700"><%= @order.collection_instructions.presence || "See confirmation email" %></dd></div>
      <% end %>
      </dl>
    </div>
  </div>

  <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-black text-slate-900">Items</h2>
    <ul class="mt-5 divide-y divide-slate-100">
      <% @order.material_order_items.each do |item| %>
        <li class="flex items-center justify-between gap-4 py-4 first:pt-0 last:pb-0">
          <div>
            <p class="font-bold text-slate-900"><%= item.product_name %></p>
            <p class="mt-1 text-sm text-slate-500"><%= item.product_sku %> · Qty <%= item.quantity %> · <%= money_from_cents(item.unit_price_cents) %> each</p>
          </div>
          <span class="font-black text-slate-900"><%= money_from_cents(item.line_total_cents) %></span>
        </li>
      <% end %>
    </ul>
  </div>
</div>
