<% content_for(:title, "My material orders — Removlo") %>

<div class="mb-6 overflow-hidden rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
  <div class="flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
    <div>
      <p class="text-sm font-black uppercase tracking-[0.2em] text-indigo-200">Shop orders</p>
      <h1 class="mt-2 text-3xl font-black tracking-tight min-[1025px]:text-5xl">My material orders</h1>
      <p class="mt-3 max-w-2xl text-sm text-slate-300">Track your packing materials, receipts, delivery, and collection progress.</p>
    </div>
    <%= link_to "Shop more materials", shop_products_path, class: "inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 shadow-lg transition hover:bg-indigo-50" %>
  </div>
</div>

<div class="overflow-hidden rounded-3xl border border-slate-200/80 bg-white shadow-sm">
  <div class="divide-y divide-slate-100">
    <% @orders.each do |order| %>
      <div class="grid gap-4 px-5 py-5 min-[1025px]:grid-cols-[1fr_auto_auto] min-[1025px]:items-center">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <p class="font-extrabold text-slate-900"><%= order.order_number %></p>
            <%= material_order_status_badge(order.status) %>
            <%= shop_payment_badge(order.payment_status) %>
          </div>
          <p class="mt-2 text-sm text-slate-500">
            <%= pluralize(order.material_order_items.sum(:quantity), "item") %> · <%= order.fulfillment_type.humanize %> · Ordered <%= order.created_at.strftime("%d %b %Y") %>
          </p>
        </div>
        <p class="text-xl font-black text-indigo-700"><%= money_from_cents(order.total_cents) %></p>
        <%= link_to "View order", material_order_path(order), class: "inline-flex items-center justify-center rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50" %>
      </div>
    <% end %>
    <% if @orders.empty? %>
      <div class="px-5 py-14 text-center">
        <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        </span>
        <p class="mt-4 font-bold text-slate-900">No material orders yet</p>
        <p class="mt-1 text-sm text-slate-500">Buy boxes, tape, bubble wrap, or moving kits from the shop.</p>
        <%= link_to "Browse the shop", shop_products_path, class: "mt-5 inline-flex rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white" %>
      </div>
    <% end %>
  </div>
</div>
