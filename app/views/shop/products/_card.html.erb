<article class="group overflow-hidden rounded-3xl border border-slate-200/80 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:border-indigo-200 hover:shadow-xl hover:shadow-indigo-900/10">
  <%= link_to shop_product_path(product), class: "block" do %>
    <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-slate-100 to-indigo-50">
      <% if product.image.attached? %>
        <%= image_tag product.image, class: "h-full w-full object-cover transition duration-500 group-hover:scale-105" %>
      <% else %>
        <div class="flex h-full items-center justify-center">
          <span class="flex h-16 w-16 items-center justify-center rounded-2xl bg-white text-indigo-500 shadow-sm">
            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </span>
        </div>
      <% end %>
      <% if product.featured? %>
        <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-xs font-black uppercase tracking-wide text-indigo-700 shadow-sm backdrop-blur">Featured</span>
      <% end %>
      <span class="absolute right-4 top-4 rounded-full bg-slate-950/80 px-3 py-1 text-xs font-bold text-white backdrop-blur"><%= product.stock_quantity %> left</span>
    </div>
    <div class="p-5">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="truncate text-base font-extrabold text-slate-900"><%= product.name %></p>
          <p class="mt-1 text-sm font-medium text-slate-500"><%= product.product_category&.name || "Moving material" %></p>
        </div>
        <p class="shrink-0 text-lg font-black text-indigo-700"><%= money_from_cents(product.price_cents) %></p>
      </div>
      <p class="mt-3 line-clamp-2 text-sm leading-6 text-slate-500"><%= product.description.presence || "Quality moving material for your relocation." %></p>
    </div>
  <% end %>
  <div class="px-5 pb-5">
    <%= button_to add_cart_path(product_id: product.id), method: :post, form: { data: { turbo_submits_with: "Adding…" } }, class: "inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-gradient-to-br from-indigo-600 to-blue-600 px-4 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-600/25 transition hover:-translate-y-0.5 hover:shadow-xl hover:shadow-indigo-600/35" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add to cart
    <% end %>
  </div>
</article>
