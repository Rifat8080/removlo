<article class="group overflow-hidden rounded-[1.75rem] border border-white/90 bg-white/90 shadow-[0_16px_50px_rgba(30,64,175,0.07)] ring-1 ring-blue-100/60 backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-indigo-200 hover:bg-white hover:shadow-xl hover:shadow-indigo-900/10">
  <%= link_to shop_product_path(product), class: "block" do %>
    <div class="relative aspect-[4/3] overflow-hidden bg-[radial-gradient(circle_at_30%_20%,rgba(99,102,241,0.16),transparent_34%),linear-gradient(135deg,#f8fafc,#eef2ff_48%,#dbeafe)]">
      <% if product.image.attached? %>
        <%= image_tag product.image, class: "h-full w-full object-cover transition duration-500 group-hover:scale-105" %>
      <% else %>
        <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(37,99,235,0.05)_1px,transparent_1px),linear-gradient(to_bottom,rgba(37,99,235,0.05)_1px,transparent_1px)] bg-[size:2.5rem_2.5rem]"></div>
        <div class="relative flex h-full items-center justify-center p-8">
          <div class="absolute bottom-6 left-6 h-16 w-24 rounded-2xl bg-white/45 blur-xl"></div>
          <div class="absolute right-7 top-7 h-14 w-14 rounded-full bg-blue-200/55 blur-lg"></div>
          <span class="flex h-20 w-20 items-center justify-center rounded-[1.5rem] bg-white/95 text-indigo-500 shadow-xl shadow-indigo-950/10 ring-1 ring-white/80 transition duration-500 group-hover:scale-105">
            <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </span>
        </div>
      <% end %>
      <% if product.featured? %>
        <span class="absolute left-4 top-4 rounded-full bg-white/95 px-3 py-1 text-[10px] font-black uppercase tracking-[0.14em] text-indigo-700 shadow-sm ring-1 ring-white/80 backdrop-blur">Featured</span>
      <% end %>
      <span class="absolute right-4 top-4 rounded-full bg-slate-950/82 px-3 py-1 text-[10px] font-black text-white shadow-sm backdrop-blur"><%= product.stock_quantity %> left</span>
    </div>
    <div class="p-5">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="truncate text-base font-black tracking-[-0.02em] text-slate-950"><%= product.name %></p>
          <p class="mt-1 inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-bold text-slate-500"><%= product.product_category&.name || "Moving material" %></p>
        </div>
        <p class="shrink-0 rounded-2xl bg-indigo-50 px-3 py-2 text-base font-black text-indigo-700 ring-1 ring-indigo-100"><%= money_from_cents(product.price_cents) %></p>
      </div>
      <p class="mt-3 line-clamp-2 text-sm font-medium leading-6 text-slate-500"><%= product.description.presence || "Quality moving material for your relocation." %></p>
    </div>
  <% end %>
  <div class="px-5 pb-5">
    <%= button_to add_cart_path(product_id: product.id), method: :post, form: { data: { turbo_submits_with: "Adding…" } }, class: "inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-gradient-to-br from-indigo-600 to-blue-600 px-4 py-3 text-sm font-black text-white shadow-lg shadow-indigo-600/25 transition hover:-translate-y-0.5 hover:shadow-xl hover:shadow-indigo-600/35" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add to cart
    <% end %>
  </div>
</article>
