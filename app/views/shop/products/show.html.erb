<% content_for(:title, "#{@product.name} — Shop") %>

<section class="bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 min-[1025px]:px-8 min-[1025px]:py-14">
    <%= link_to "← Back to shop", shop_products_path, class: "inline-flex items-center rounded-full bg-white px-4 py-2 text-sm font-bold text-indigo-600 shadow-sm ring-1 ring-slate-200 transition hover:bg-indigo-50" %>

    <div class="mt-6 grid gap-8 min-[1025px]:grid-cols-[1.05fr_0.95fr] min-[1025px]:items-start">
      <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-gradient-to-br from-slate-100 to-indigo-50 shadow-sm">
        <div class="aspect-square min-[1025px]:aspect-[5/4]">
      <% if @product.image.attached? %>
            <%= image_tag @product.image, class: "h-full w-full object-cover" %>
          <% else %>
            <div class="flex h-full items-center justify-center">
              <span class="flex h-24 w-24 items-center justify-center rounded-3xl bg-white text-indigo-500 shadow-sm">
                <svg class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="rounded-[2rem] border border-slate-200/80 bg-white p-6 shadow-sm min-[1025px]:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-black uppercase tracking-wide text-indigo-700 ring-1 ring-indigo-100"><%= @product.product_category&.name || "Materials" %></span>
          <% if @product.featured? %>
            <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-black uppercase tracking-wide text-amber-700 ring-1 ring-amber-100">Featured</span>
          <% end %>
        </div>

        <h1 class="mt-4 text-3xl font-black tracking-tight text-slate-900 min-[1025px]:text-5xl"><%= @product.name %></h1>
        <p class="mt-3 text-3xl font-black text-indigo-700"><%= money_from_cents(@product.price_cents) %></p>
        <p class="mt-5 whitespace-pre-line text-base leading-7 text-slate-600"><%= @product.description.presence || "Quality moving material for your relocation." %></p>

        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">SKU</p>
            <p class="mt-1 font-bold text-slate-900"><%= @product.sku %></p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Stock</p>
            <p class="mt-1 font-bold text-slate-900"><%= @product.stock_quantity %> available</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Options</p>
            <p class="mt-1 font-bold text-slate-900">Delivery or pickup</p>
          </div>
        </div>

        <%= button_to add_cart_path(product_id: @product.id), method: :post, form: { data: { turbo_submits_with: "Adding…" } }, class: "mt-7 inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-gradient-to-br from-indigo-600 to-blue-600 px-6 py-4 text-sm font-black text-white shadow-lg shadow-indigo-600/30 transition hover:-translate-y-0.5 hover:shadow-xl hover:shadow-indigo-600/40" do %>
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add to cart
        <% end %>

        <div class="mt-4 rounded-2xl border border-indigo-100 bg-indigo-50 p-4 text-sm text-indigo-800">
          Secure checkout powered by Stripe. Choose delivery or collection at checkout.
        </div>
      </div>
    </div>

    <% if @related.any? %>
      <div class="mt-12">
        <h2 class="text-2xl font-black text-slate-900">Related materials</h2>
        <div class="mt-5 grid gap-5 sm:grid-cols-2 min-[1025px]:grid-cols-4">
          <% @related.each do |product| %>
            <%= render "shop/products/card", product: product %>
          <% end %>
        </div>
      </div>
      <% end %>
  </div>
</section>
