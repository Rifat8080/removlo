<% content_for(:title, "Payslip — Removlo") %>

<div class="mb-6 flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
  <div>
    <%= link_to "← My payslips", payslips_path, class: "text-sm font-semibold text-indigo-600" %>
    <h1 class="mt-2 text-2xl font-extrabold text-slate-900">Payslip</h1>
    <p class="mt-1 text-sm text-slate-500"><%= @payslip.payroll_run.period_label %></p>
  </div>
  <%= link_to "Export PDF", pdf_payslip_path(@payslip), class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-800" %>
</div>

<div class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm">
  <dl class="grid gap-4 min-[1025px]:grid-cols-2 text-sm">
    <div><dt class="text-slate-500">Employee</dt><dd class="mt-1 font-semibold text-slate-900"><%= @payslip.employee.email %></dd></div>
    <div><dt class="text-slate-500">Role</dt><dd class="mt-1 font-semibold capitalize text-slate-900"><%= @payslip.employee_role %></dd></div>
    <div><dt class="text-slate-500">Base salary</dt><dd class="mt-1 font-semibold text-slate-900"><%= money_from_cents(@payslip.base_salary_cents) %></dd></div>
    <div><dt class="text-slate-500">Bonus</dt><dd class="mt-1 font-semibold text-slate-900"><%= money_from_cents(@payslip.bonus_cents) %></dd></div>
    <div><dt class="text-slate-500">Commission</dt><dd class="mt-1 font-semibold text-slate-900"><%= money_from_cents(@payslip.commission_cents) %></dd></div>
    <div><dt class="text-slate-500">Deductions</dt><dd class="mt-1 font-semibold text-rose-700">-<%= money_from_cents(@payslip.deductions_cents) %></dd></div>
    <div class="min-[1025px]:col-span-2 rounded-xl bg-indigo-50 p-4">
      <dt class="text-sm text-indigo-600">Net pay</dt>
      <dd class="mt-1 text-3xl font-extrabold text-indigo-700"><%= money_from_cents(@payslip.net_pay_cents) %></dd>
    </div>
    <div><dt class="text-slate-500">Payment date</dt><dd class="mt-1 font-semibold text-slate-900"><%= @payslip.payment_date&.strftime("%d %b %Y") || "Pending" %></dd></div>
    <% if @payslip.notes.present? %>
      <div class="min-[1025px]:col-span-2"><dt class="text-slate-500">Notes</dt><dd class="mt-1 text-slate-700"><%= @payslip.notes %></dd></div>
    <% end %>
  </dl>
</div>
