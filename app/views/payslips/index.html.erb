<% content_for(:title, "My payslips — Removlo") %>

<div class="mb-6">
  <h1 class="text-2xl font-extrabold text-slate-900">My payslips</h1>
  <p class="mt-1 text-sm text-slate-500">View your salary and commission payslips.</p>
</div>

<div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm">
  <div class="divide-y divide-slate-100">
    <% @payslips.each do |payslip| %>
      <div class="grid gap-3 px-5 py-4 min-[1025px]:grid-cols-[1fr_auto_auto] min-[1025px]:items-center">
        <div>
          <p class="font-semibold text-slate-900"><%= payslip.payroll_run.period_label %></p>
          <p class="mt-1 text-xs text-slate-400 capitalize"><%= payslip.employee_role %> · Paid <%= payslip.payment_date&.strftime("%d %b %Y") || "Pending" %></p>
        </div>
        <span class="font-semibold text-indigo-700"><%= money_from_cents(payslip.net_pay_cents) %></span>
        <div class="flex flex-wrap gap-2">
          <%= link_to "PDF", pdf_payslip_path(payslip), class: "rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-800" %>
          <%= link_to "View", payslip_path(payslip), class: "rounded-lg border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
        </div>
      </div>
    <% end %>
    <% if @payslips.empty? %>
      <div class="px-5 py-12 text-center">
        <p class="font-semibold text-slate-900">No payslips yet</p>
        <p class="mt-1 text-sm text-slate-500">Payslips appear here after payroll is processed.</p>
      </div>
    <% end %>
  </div>
</div>
