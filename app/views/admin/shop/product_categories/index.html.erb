<% content_for(:title, "Categories — Shop") %>
<div class="mb-6 flex justify-between"><h1 class="text-2xl font-extrabold">Categories</h1><%= link_to "New", new_admin_shop_product_category_path, class: "rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white" %></div>
<div class="rounded-2xl border border-slate-200 bg-white divide-y">
  <% @categories.each do |cat| %>
    <div class="flex justify-between px-5 py-4"><span class="font-semibold"><%= cat.name %></span><%= link_to "Edit", edit_admin_shop_product_category_path(cat), class: "text-indigo-600 text-sm font-semibold" %></div>
  <% end %>
</div>
