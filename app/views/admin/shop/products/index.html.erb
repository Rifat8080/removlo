<% content_for(:title, "Shop products — Admin") %>
<div class="mb-6 flex justify-between gap-4">
  <div><h1 class="text-2xl font-extrabold text-slate-900">Products</h1></div>
  <%= link_to "New product", new_admin_shop_product_path, class: "rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white" %>
</div>
<div class="divide-y divide-slate-100 rounded-2xl border border-slate-200 bg-white shadow-sm">
  <% @products.each do |product| %>
    <div class="flex items-center justify-between gap-4 px-5 py-4">
      <div>
        <p class="font-semibold text-slate-900"><%= product.name %></p>
        <p class="text-xs text-slate-400"><%= product.sku %> · <%= money_from_cents(product.price_cents) %> · Stock <%= product.stock_quantity %></p>
      </div>
      <%= link_to "Edit", edit_admin_shop_product_path(product), class: "text-sm font-semibold text-indigo-600" %>
    </div>
  <% end %>
</div>
