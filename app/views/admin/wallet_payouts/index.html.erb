<% content_for :title, "Driver Wallet Payouts — Removlo" %>

<div class="mx-auto max-w-7xl">
  <h1 class="text-3xl font-black text-slate-900">Driver Wallet Payouts</h1>
  <div class="mt-6 space-y-3">
    <% @pending_entries.each do |entry| %>
      <div class="flex flex-col gap-3 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
        <div>
          <p class="font-bold text-slate-900"><%= entry.driver.email %></p>
          <p class="text-sm text-slate-500"><%= entry.entry_type.humanize %> · <%= entry.reference || entry.quotation&.reference %> · <%= entry.status.humanize %></p>
        </div>
        <div class="flex items-center gap-3">
          <p class="text-lg font-black text-emerald-700"><%= money_from_cents(entry.amount_cents) %></p>
          <% if entry.pending? && entry.amount_cents.positive? %>
            <%= button_to "Approve", approve_admin_wallet_payout_path(entry), method: :patch, class: "rounded-xl bg-indigo-600 px-4 py-2 text-sm font-bold text-white" %>
          <% end %>
          <% if entry.available? && entry.amount_cents.positive? %>
            <%= button_to "Payout", payout_admin_wallet_payout_path(entry), method: :patch, data: { turbo_confirm: "Process payout?" }, class: "rounded-xl bg-emerald-600 px-4 py-2 text-sm font-bold text-white" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
