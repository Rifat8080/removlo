<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="flex items-center justify-between gap-3">
    <div>
      <h2 class="text-lg font-black text-slate-900">Bid Comparison</h2>
      <p class="mt-1 text-sm text-slate-500"><%= current_user.admin? ? "Compare driver bids, ratings, and margins before selecting the best offer." : "Compare driver bids, ratings, and availability before selecting the best offer." %></p>
    </div>
    <% if comparison.best_value %>
      <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-700">Suggested: <%= comparison.best_value.driver.email %></span>
    <% end %>
  </div>

  <div class="mt-5 overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200 text-left text-slate-500">
          <th class="px-3 py-2">Driver</th>
          <th class="px-3 py-2">Bid</th>
          <th class="px-3 py-2">Rating</th>
          <th class="px-3 py-2">Jobs</th>
          <th class="px-3 py-2">Score</th>
          <th class="px-3 py-2">Highlights</th>
          <th class="px-3 py-2"></th>
        </tr>
      </thead>
      <tbody>
        <% comparison.offers.each do |entry| %>
          <% offer = entry[:offer] %>
          <% selected = quotation.selected_driver_offer_id == offer.id %>
          <tr class="border-b border-slate-100 <%= "bg-indigo-50/60" if selected %>">
            <td class="px-3 py-3 font-semibold text-slate-900">
              <div class="flex flex-wrap items-center gap-2">
                <span><%= offer.driver.email %></span>
                <% if selected %>
                  <span class="rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-bold text-indigo-700">Selected</span>
                <% end %>
                <% if offer.pending_renegotiation? %>
                  <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-bold text-amber-700">Awaiting driver</span>
                <% elsif offer.accepted_renegotiation? %>
                  <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-bold text-emerald-700">Negotiated accepted</span>
                <% end %>
              </div>
            </td>
            <td class="px-3 py-3"><%= money_from_cents(offer.amount_cents) %></td>
            <td class="px-3 py-3"><%= offer.driver_rating %></td>
            <td class="px-3 py-3"><%= offer.driver_jobs_count %></td>
            <td class="px-3 py-3"><%= offer.score || entry[:total_score] %></td>
            <td class="px-3 py-3">
              <div class="flex flex-wrap gap-1">
                <% if comparison.cheapest&.id == offer.id %><span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-bold text-blue-700">Cheapest</span><% end %>
                <% if comparison.highest_rated&.id == offer.id %><span class="rounded-full bg-violet-100 px-2 py-0.5 text-xs font-bold text-violet-700">Highest rated</span><% end %>
                <% if comparison.best_value&.id == offer.id %><span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-bold text-emerald-700">Best value</span><% end %>
              </div>
            </td>
            <td class="px-3 py-3 text-right">
              <%= button_to selected ? "Unselect" : "Select", select_admin_quotation_driver_offer_path(quotation, offer), method: :patch, params: { markup_percentage: quotation.markup_percentage }, class: "rounded-lg #{selected ? "bg-white text-indigo-700 ring-1 ring-indigo-200 hover:bg-indigo-50" : "bg-indigo-600 text-white hover:bg-indigo-700"} px-3 py-2 text-xs font-bold transition" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if comparison.offers.empty? %>
      <p class="mt-4 rounded-2xl bg-slate-50 p-4 text-sm text-slate-500">No driver offers yet. Drivers are alerted automatically when the job is posted.</p>
    <% end %>
  </div>
</section>
