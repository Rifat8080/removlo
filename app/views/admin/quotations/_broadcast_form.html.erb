<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <h2 class="text-lg font-black text-slate-900">Broadcast System</h2>
  <p class="mt-1 text-sm text-slate-500">Send this job to matching available drivers instead of WhatsApp.</p>
  <%= form_with(model: [:admin, quotation, broadcast], class: "mt-4 space-y-4") do |form| %>
    <div class="grid gap-3 min-[1025px]:grid-cols-2">
      <div>
        <p class="mb-2 text-sm font-semibold text-slate-700">Vehicle types</p>
        <% DriverProfile::VEHICLE_TYPES.each do |vehicle| %>
          <label class="mr-4 inline-flex items-center gap-2 text-sm">
            <%= check_box_tag "quotation_broadcast[vehicle_types][]", vehicle, broadcast.vehicle_types.include?(vehicle), class: "rounded border-slate-300 text-indigo-600" %>
            <%= vehicle.humanize %>
          </label>
        <% end %>
      </div>
      <div>
        <%= form.label :service_areas, "Service areas (postcode prefixes)", class: "mb-2 block text-sm font-semibold text-slate-700" %>
        <%= text_field_tag "quotation_broadcast[service_areas_text]", broadcast.service_areas.join(", "), class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm", placeholder: "M, B, LS" %>
      </div>
    </div>
    <div class="flex flex-wrap gap-4">
      <label class="inline-flex items-center gap-2 text-sm font-semibold text-slate-700">
        <%= form.check_box :require_available, class: "rounded border-slate-300 text-indigo-600" %>
        Only available drivers
      </label>
      <div>
        <%= form.label :minimum_rating, "Rated", class: "text-sm font-semibold text-slate-700" %>
        <%= form.number_field :minimum_rating, step: 0.1, min: 0, max: 5, class: "ml-2 w-20 rounded-lg border border-slate-200 px-2 py-1 text-sm" %>+
      </div>
    </div>
    <%= form.submit "Send job to drivers", class: "rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white" %>
  <% end %>
</section>
