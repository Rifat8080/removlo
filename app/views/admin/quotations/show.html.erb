<% content_for :title, "#{@quotation.reference} — Removlo" %>

<div class="mx-auto max-w-7xl">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
    <div class="flex flex-col gap-6 min-[1025px]:flex-row min-[1025px]:items-start min-[1025px]:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <%= quotation_status_badge(@quotation.status) %>
          <%= quotation_payment_badge(@quotation.payment_status) %>
        </div>
        <h1 class="mt-4 text-3xl font-black tracking-tight min-[1025px]:text-5xl"><%= @quotation.reference %></h1>
        <p class="mt-3 text-sm text-slate-300"><%= @quotation.customer.email %> · <%= @quotation.pickup_postcode.presence || "Pickup" %> to <%= @quotation.delivery_postcode.presence || "Delivery" %></p>
      </div>
      <div class="flex flex-col gap-2 sm:flex-row min-[1025px]:justify-end">
        <%= link_to "Edit", edit_admin_quotation_path(@quotation), class: "inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 transition hover:bg-indigo-50" %>
        <%= button_to "Delete", admin_quotation_path(@quotation), method: :delete, form: { data: { turbo_confirm: "Delete this quotation and all related records?" } }, class: "inline-flex w-full items-center justify-center rounded-xl bg-rose-500 px-5 py-3 text-sm font-bold text-white transition hover:bg-rose-600 sm:w-auto" %>
      </div>
    </div>

    <div class="mt-8 grid gap-3 sm:grid-cols-2 min-[1025px]:grid-cols-4">
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Quoted price</p>
        <p class="mt-2 text-2xl font-black"><%= money_from_cents(@quotation.quoted_price_cents) %></p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Deposit</p>
        <p class="mt-2 text-2xl font-black"><%= money_from_cents(@quotation.deposit_cents) %></p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Move date</p>
        <p class="mt-2 text-lg font-black"><%= @quotation.preferred_move_date&.to_fs(:long) || "Not set" %></p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Operator</p>
        <p class="mt-2 truncate text-lg font-black"><%= @quotation.assigned_staff&.email || "Unassigned" %></p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-200">Driver</p>
        <p class="mt-2 truncate text-lg font-black"><%= @quotation.assigned_driver&.email || "Unassigned" %></p>
      </div>
    </div>
  </div>

  <div class="mt-6 grid gap-6 min-[1025px]:grid-cols-[1.4fr_0.9fr]">
    <div class="space-y-6">
      <%= render "admin/quotations/margin_pricing", quotation: @quotation %>
      <%= render "admin/quotations/broadcast_form", quotation: @quotation, broadcast: @broadcast %>
      <%= render "admin/quotations/bid_comparison", quotation: @quotation, comparison: @comparison %>
      <%= render "admin/quotations/inventory_estimate", quotation: @quotation, inventory_estimate: @inventory_estimate %>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex flex-col gap-3 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
          <div>
            <h2 class="text-lg font-black text-slate-900">Workflow actions</h2>
            <p class="mt-1 text-sm text-slate-500">Move the quote through pricing, acceptance, schedule, delivery, and completion.</p>
          </div>
        </div>
        <div class="mt-5 grid gap-2 sm:grid-cols-2 min-[1025px]:grid-cols-4">
          <% [["quoted", "Send quote"], ["negotiating", "Start negotiation"], ["accepted", "Accept"], ["scheduled", "Schedule"], ["in_progress", "Start move"], ["completed", "Complete"], ["rejected", "Reject"], ["cancelled", "Cancel"]].each do |status, label| %>
            <%= button_to label, transition_admin_quotation_path(@quotation), method: :patch, params: { status: status, note: "Changed to #{status.humanize}" }, class: "inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" %>
          <% end %>
        </div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-black text-slate-900">Route and access</h2>
        <div class="mt-5 grid gap-4 min-[1025px]:grid-cols-2">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Pickup</p>
            <p class="mt-2 whitespace-pre-line text-sm font-semibold text-slate-900"><%= @quotation.pickup_address %></p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Delivery</p>
            <p class="mt-2 whitespace-pre-line text-sm font-semibold text-slate-900"><%= @quotation.delivery_address %></p>
          </div>
        </div>
        <div class="mt-4 grid gap-4 min-[1025px]:grid-cols-2">
          <div>
            <p class="text-sm font-bold text-slate-900">Access notes</p>
            <p class="mt-1 whitespace-pre-line text-sm text-slate-600"><%= @quotation.access_notes.presence || "No access notes recorded." %></p>
          </div>
          <div>
            <p class="text-sm font-bold text-slate-900">Customer notes</p>
            <p class="mt-1 whitespace-pre-line text-sm text-slate-600"><%= @quotation.customer_notes.presence || "No customer notes recorded." %></p>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-black text-slate-900">Inventory items</h2>
        <%= form_with(model: [:admin, @quotation, @item], class: "mt-4 grid gap-3 min-[1025px]:grid-cols-[1fr_120px_auto_auto] min-[1025px]:items-end") do |form| %>
          <div>
            <%= form.label :name, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= form.text_field :name, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Sofa, boxes, piano" %>
          </div>
          <div>
            <%= form.label :quantity, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= form.number_field :quantity, min: 1, value: 1, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
          </div>
          <label class="flex items-center gap-2 rounded-xl border border-slate-200 px-3 py-2.5 text-sm font-semibold text-slate-700">
            <%= form.check_box :fragile, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
            Fragile
          </label>
          <%= form.submit "Add item", class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-indigo-700" %>
        <% end %>

        <div class="mt-5 divide-y divide-slate-100">
          <% @quotation.quotation_items.order(created_at: :desc).each do |item| %>
            <div class="flex flex-col gap-3 py-3 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
              <div>
                <p class="font-bold text-slate-900"><%= item.quantity %> × <%= item.name %> <%= "· Fragile" if item.fragile? %></p>
                <p class="text-sm text-slate-500"><%= item.notes.presence || "No notes" %></p>
              </div>
              <%= button_to "Remove", admin_quotation_quotation_item_path(@quotation, item), method: :delete, class: "inline-flex items-center justify-center rounded-lg border border-rose-200 px-3 py-2 text-sm font-bold text-rose-600 transition hover:bg-rose-50" %>
            </div>
          <% end %>
        </div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-black text-slate-900">Payments</h2>
        <%= form_with(model: [:admin, @quotation, @payment], class: "mt-4 grid gap-3 min-[1025px]:grid-cols-[140px_1fr_1fr_auto] min-[1025px]:items-end") do |form| %>
          <div>
            <%= form.label :amount, "Amount (£)", class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= form.number_field :amount, min: 0, step: "0.01", class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= form.label :payment_method, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= form.text_field :payment_method, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Card, bank transfer, cash" %>
          </div>
          <div>
            <%= form.label :reference, class: "mb-2 block text-sm font-semibold text-slate-700" %>
            <%= form.text_field :reference, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Payment reference" %>
          </div>
          <%= form.submit "Record", class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-indigo-700" %>
        <% end %>

        <div class="mt-5 divide-y divide-slate-100">
          <% @quotation.quotation_payments.order(created_at: :desc).each do |payment| %>
            <div class="flex flex-col gap-3 py-3 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
              <div>
                <p class="font-bold text-slate-900"><%= money_from_cents(payment.amount_cents) %> · <%= payment.payment_method.humanize %></p>
                <p class="text-sm text-slate-500"><%= payment.reference.presence || "No reference" %> · <%= payment.paid_on&.to_fs(:long) || "No date" %></p>
              </div>
              <%= button_to "Remove", admin_quotation_quotation_payment_path(@quotation, payment), method: :delete, class: "inline-flex items-center justify-center rounded-lg border border-rose-200 px-3 py-2 text-sm font-bold text-rose-600 transition hover:bg-rose-50" %>
            </div>
          <% end %>
        </div>
      </section>
    </div>

    <aside class="space-y-6">
      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-black text-slate-900">Driver assignment</h2>
        <% if @quotation.confirmed_for_driver_assignment? %>
          <p class="mt-1 text-sm text-slate-500">Assign this confirmed job to a driver for move execution.</p>
          <%= form_with(model: [:admin, @quotation], class: "mt-4 space-y-3") do |form| %>
            <div>
              <%= form.label :assigned_driver_id, "Driver", class: "mb-2 block text-sm font-semibold text-slate-700" %>
              <%= form.collection_select :assigned_driver_id, User.drivers, :id, :email, { include_blank: "Unassigned" }, class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-indigo-500" %>
            </div>
            <%= form.submit "Assign driver", class: "inline-flex w-full items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-indigo-700" %>
          <% end %>
        <% else %>
          <div class="mt-4 rounded-2xl bg-amber-50 p-4 text-sm text-amber-800">
            Driver assignment unlocks after the quotation is accepted. Mark the quote as accepted first, then assign the confirmed job to a driver.
          </div>
        <% end %>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-black text-slate-900">Notes</h2>
        <%= form_with(model: [:admin, @quotation, @note], class: "mt-4 space-y-3") do |form| %>
          <%= form.text_area :content, rows: 4, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Add an operational note" %>
          <label class="flex items-center gap-2 text-sm font-semibold text-slate-700">
            <%= form.check_box :internal, checked: true, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
            Internal note
          </label>
          <%= form.submit "Add note", class: "inline-flex w-full items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-indigo-700" %>
        <% end %>
        <div class="mt-5 space-y-3">
          <% @quotation.quotation_notes.order(created_at: :desc).each do |note| %>
            <div class="rounded-2xl bg-slate-50 p-4">
              <p class="whitespace-pre-line text-sm text-slate-700"><%= note.content %></p>
              <div class="mt-3 flex items-center justify-between gap-2 text-xs text-slate-500">
                <span><%= note.user&.email || "System" %></span>
                <%= button_to "Delete", admin_quotation_quotation_note_path(@quotation, note), method: :delete, class: "font-bold text-rose-600 hover:text-rose-700" %>
              </div>
            </div>
          <% end %>
        </div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-black text-slate-900">Documents</h2>
        <%= form_with(model: [:admin, @quotation, @document], class: "mt-4 space-y-3") do |form| %>
          <%= form.text_field :title, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Document title" %>
          <%= form.select :document_type, QuotationDocument::DOCUMENT_TYPES.map { |type| [type.humanize, type] }, {}, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
          <%= form.url_field :url, class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "https://..." %>
          <%= form.submit "Add document", class: "inline-flex w-full items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-indigo-700" %>
        <% end %>
        <div class="mt-5 space-y-3">
          <% @quotation.quotation_documents.order(created_at: :desc).each do |document| %>
            <div class="rounded-2xl bg-slate-50 p-4">
              <p class="font-bold text-slate-900"><%= document.title %></p>
              <p class="mt-1 text-sm text-slate-500"><%= document.document_type.humanize %></p>
              <div class="mt-3 flex gap-2">
                <% if document.url.present? %>
                  <%= link_to "Open", document.url, target: "_blank", rel: "noopener", class: "text-sm font-bold text-indigo-600 hover:text-indigo-700" %>
                <% end %>
                <%= button_to "Remove", admin_quotation_quotation_document_path(@quotation, document), method: :delete, class: "text-sm font-bold text-rose-600 hover:text-rose-700" %>
              </div>
            </div>
          <% end %>
        </div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-black text-slate-900">Status history</h2>
        <div class="mt-5 space-y-4">
          <% @quotation.quotation_status_events.order(created_at: :desc).each do |event| %>
            <div class="border-l-2 border-indigo-200 pl-4">
              <p class="text-sm font-bold text-slate-900"><%= event.from_status.presence&.humanize || "Started" %> → <%= event.to_status.humanize %></p>
              <p class="mt-1 text-xs text-slate-500"><%= event.user&.email || "System" %> · <%= event.created_at.to_fs(:long) %></p>
              <% if event.note.present? %>
                <p class="mt-2 text-sm text-slate-600"><%= event.note %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    </aside>
  </div>
</div>
