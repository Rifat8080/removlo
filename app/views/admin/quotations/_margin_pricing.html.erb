<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-start min-[1025px]:justify-between">
    <div>
      <h2 class="text-lg font-black text-slate-900">Hidden Margin System</h2>
      <p class="mt-1 text-sm text-slate-500">Driver and customer never see each other's price. Operators can manage the internal margin here.</p>
    </div>
    <%= form_with(model: [:admin, quotation], class: "flex flex-col gap-2 sm:flex-row sm:items-end") do |form| %>
      <div>
        <%= form.label :markup_percentage, "Markup %", class: "mb-2 block text-xs font-bold uppercase tracking-wide text-slate-500" %>
        <%= form.number_field :markup_percentage, value: quotation.markup_percentage, min: 0, step: "0.1", class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-bold text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 sm:w-32" %>
      </div>
      <%= form.submit "Update markup", class: "inline-flex justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-indigo-700" %>
    <% end %>
  </div>

  <div class="mt-4 grid gap-3 sm:grid-cols-3">
    <div class="rounded-2xl bg-slate-50 p-4">
      <p class="text-xs uppercase text-slate-400">Driver bid / cost</p>
      <p class="mt-2 text-2xl font-black text-slate-900"><%= money_from_cents(quotation.driver_cost_cents) %></p>
    </div>
    <div class="rounded-2xl bg-slate-50 p-4">
      <p class="text-xs uppercase text-slate-400">Markup</p>
      <p class="mt-2 text-2xl font-black text-slate-900"><%= number_with_precision(quotation.markup_percentage, precision: 1, strip_insignificant_zeros: true) %>%</p>
    </div>
    <div class="rounded-2xl bg-slate-50 p-4">
      <p class="text-xs uppercase text-slate-400">Customer sees</p>
      <p class="mt-2 text-2xl font-black text-emerald-700"><%= money_from_cents(quotation.quoted_price_cents) %></p>
      <p class="text-xs text-slate-500">Margin: <%= money_from_cents(quotation.admin_margin_cents) %></p>
    </div>
  </div>
</section>
