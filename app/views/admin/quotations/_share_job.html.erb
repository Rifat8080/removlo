<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <h2 class="text-lg font-black text-slate-900">Share outside group</h2>
  <p class="mt-1 text-sm text-slate-500">Send this link to external driver groups. They can view full job details, sign up, and submit a bid.</p>

  <% if quotation.awaiting_driver_offers? %>
    <div class="mt-4 rounded-2xl border border-indigo-100 bg-indigo-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Public job link</p>
      <input type="text" readonly value="<%= public_job_url(quotation.public_share_token) %>" onclick="this.select()" class="mt-2 block w-full rounded-xl border border-indigo-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-900" />
      <div class="mt-3">
        <%= link_to "Open link", public_job_path(quotation.public_share_token), target: "_blank", rel: "noopener", class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-indigo-700" %>
      </div>
    </div>
  <% else %>
    <p class="mt-4 rounded-2xl bg-slate-50 p-4 text-sm text-slate-500">This job is no longer open for outside bids.</p>
  <% end %>
</section>
