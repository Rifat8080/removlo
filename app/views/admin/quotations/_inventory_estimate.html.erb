<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <h2 class="text-lg font-black text-slate-900">Customer Inventory AI</h2>
  <p class="mt-1 text-sm text-slate-500">Review uploaded photos and maintain the estimated inventory scaffold.</p>
  <div class="mt-3 flex flex-wrap items-center gap-2">
    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-700">Processing: <%= inventory_estimate.processing_status.humanize %></span>
    <span class="rounded-full bg-indigo-100 px-3 py-1 text-xs font-bold text-indigo-700"><%= inventory_estimate.ai_status_label %></span>
    <% if inventory_estimate.ai_error.present? %>
      <span class="rounded-full bg-rose-100 px-3 py-1 text-xs font-bold text-rose-700"><%= inventory_estimate.ai_error %></span>
    <% end %>
  </div>

  <% if inventory_estimate.photos.attached? %>
    <div class="mt-4 grid grid-cols-2 gap-3 min-[1025px]:grid-cols-4">
      <% inventory_estimate.photos.each do |photo| %>
        <%= image_tag photo, class: "h-28 w-full rounded-xl object-cover" %>
      <% end %>
    </div>
  <% else %>
    <p class="mt-4 rounded-2xl bg-slate-50 p-4 text-sm text-slate-500">No customer photos uploaded yet.</p>
  <% end %>

  <%= form_with(url: admin_quotation_inventory_estimate_path(quotation), method: :patch, class: "mt-4 space-y-3") do %>
    <div class="grid gap-3 min-[1025px]:grid-cols-3">
      <% 4.times do |index| %>
        <% item = inventory_estimate.estimated_inventory[index] || {} %>
        <div class="rounded-xl border border-slate-200 p-3">
          <input type="text" name="inventory_items[<%= index %>][name]" value="<%= item["name"] || item[:name] %>" placeholder="Item name" class="mb-2 w-full rounded-lg border px-2 py-1 text-sm">
          <input type="number" name="inventory_items[<%= index %>][quantity]" value="<%= item["quantity"] || item[:quantity] || 1 %>" min="1" class="w-full rounded-lg border px-2 py-1 text-sm">
        </div>
      <% end %>
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold text-slate-700">Suggested vehicle</label>
      <select name="quotation_inventory_estimate[suggested_vehicle]" class="rounded-xl border border-slate-200 px-3 py-2 text-sm">
        <option value="">Select vehicle</option>
        <% DriverProfile::VEHICLE_TYPES.each do |vehicle| %>
          <option value="<%= vehicle %>" <%= "selected" if inventory_estimate.suggested_vehicle == vehicle %>><%= vehicle.humanize %></option>
        <% end %>
      </select>
    </div>
    <textarea name="quotation_inventory_estimate[admin_notes]" rows="3" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm" placeholder="Admin notes for estimate"><%= inventory_estimate.admin_notes %></textarea>
    <button type="submit" class="rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white">Save estimate</button>
  <% end %>
</section>
