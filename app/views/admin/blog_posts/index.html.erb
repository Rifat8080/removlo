<% content_for :title, "Blog posts — Removlo" %>

<div class="mx-auto max-w-7xl">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
    <div class="flex flex-col gap-5 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-indigo-200">Content management</p>
        <h1 class="mt-3 text-3xl font-black tracking-tight min-[1025px]:text-5xl">Blog posts</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">Publish moving guides, company updates, and useful customer advice.</p>
      </div>
      <%= link_to "New post", new_admin_blog_post_path, class: "inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 shadow-lg transition hover:bg-indigo-50" %>
    </div>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white shadow-sm">
    <% if @blog_posts.any? %>
      <div class="divide-y divide-slate-100">
        <% @blog_posts.each do |post| %>
          <div class="grid gap-4 p-5 transition hover:bg-slate-50 min-[1025px]:grid-cols-[1.4fr_1fr_auto] min-[1025px]:items-center">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600"><%= post.published_at.to_fs(:long) %></p>
              <%= link_to post.title, admin_blog_post_path(post), class: "mt-2 block text-lg font-black text-slate-900 hover:text-indigo-700" %>
              <p class="mt-1 text-sm text-slate-500"><%= post.excerpt.presence || truncate(strip_tags(post.body), length: 120) %></p>
            </div>
            <div class="text-sm text-slate-600">
              <p class="font-semibold text-slate-900">Author</p>
              <p class="mt-1 truncate"><%= post.author.email %></p>
            </div>
            <div class="flex gap-2 min-[1025px]:justify-end">
              <%= link_to "View", blog_post_path(post), class: "inline-flex flex-1 items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700 transition hover:bg-slate-50 min-[1025px]:flex-none" %>
              <%= link_to "Edit", edit_admin_blog_post_path(post), class: "inline-flex flex-1 items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-indigo-700 min-[1025px]:flex-none" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-10 text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v8a2 2 0 01-2 2z"/></svg>
        </div>
        <h2 class="mt-4 text-xl font-black text-slate-900">No blog posts yet</h2>
        <p class="mt-2 text-sm text-slate-500">Create the first customer-facing guide for your moving blog.</p>
        <%= link_to "New post", new_admin_blog_post_path, class: "mt-5 inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-indigo-700" %>
      </div>
    <% end %>
  </div>
</div>
