<% content_for :title, "New blog post — Removlo" %>

<div class="mx-auto max-w-7xl">
  <div class="mb-6 flex flex-col gap-3 min-[1025px]:flex-row min-[1025px]:items-end min-[1025px]:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-indigo-600">Create content</p>
      <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900">New blog post</h1>
      <p class="mt-2 text-sm text-slate-500">Publish a customer-facing article to the public blog.</p>
    </div>
    <%= link_to "Back to posts", admin_blog_posts_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50" %>
  </div>

  <%= render "form", blog_post: @blog_post %>
</div>
