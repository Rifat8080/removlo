<% content_for :title, "#{@blog_post.title} — Blog admin" %>

<div class="mx-auto max-w-5xl">
  <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20 min-[1025px]:p-8">
    <div class="flex flex-col gap-5 min-[1025px]:flex-row min-[1025px]:items-start min-[1025px]:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-indigo-200">Blog post</p>
        <h1 class="mt-3 text-3xl font-black tracking-tight min-[1025px]:text-5xl"><%= @blog_post.title %></h1>
        <p class="mt-3 text-sm text-slate-300">Published <%= @blog_post.published_at.to_fs(:long) %> by <%= @blog_post.author.email %></p>
      </div>
      <div class="flex flex-col gap-2 sm:flex-row">
        <%= link_to "Public view", blog_post_path(@blog_post), class: "inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 transition hover:bg-indigo-50" %>
        <%= link_to "Edit", edit_admin_blog_post_path(@blog_post), class: "inline-flex items-center justify-center rounded-xl bg-indigo-500 px-5 py-3 text-sm font-bold text-white transition hover:bg-indigo-400" %>
      </div>
    </div>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm min-[1025px]:p-8">
    <% if @blog_post.cover_image.attached? %>
      <div class="mb-8 overflow-hidden rounded-2xl bg-slate-100">
        <%= image_tag @blog_post.cover_image, alt: @blog_post.title, class: "max-h-96 w-full object-cover" %>
      </div>
    <% end %>

    <% if @blog_post.excerpt.present? %>
      <p class="rounded-2xl bg-indigo-50 p-4 text-lg leading-8 text-indigo-950"><%= @blog_post.excerpt %></p>
    <% end %>

    <div class="mt-8 whitespace-pre-line text-sm leading-7 text-slate-700"><%= @blog_post.body %></div>

    <div class="mt-8 flex flex-col gap-3 border-t border-slate-100 pt-6 sm:flex-row">
      <%= link_to "Back to posts", admin_blog_posts_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-bold text-slate-700 transition hover:bg-slate-50" %>
      <%= button_to "Delete post", admin_blog_post_path(@blog_post), method: :delete, form: { data: { turbo_confirm: "Delete this blog post?" } }, class: "inline-flex w-full items-center justify-center rounded-xl bg-rose-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-rose-700 sm:w-auto" %>
    </div>
  </div>
</div>
