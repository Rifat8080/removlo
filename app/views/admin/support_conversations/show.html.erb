<% content_for :title, "Support chat — Removlo" %>

<div class="mx-auto max-w-4xl space-y-4">
  <div class="flex items-center justify-between">
    <%= link_to "Support panel", admin_support_conversations_path, class: "text-sm font-semibold text-indigo-600" %>
    <div class="flex gap-2">
      <% if @conversation.open? %>
        <%= button_to "Close", close_admin_support_conversation_path(@conversation), method: :patch, class: "rounded-lg border px-3 py-2 text-sm font-bold text-slate-700" %>
      <% else %>
        <%= button_to "Reopen", reopen_admin_support_conversation_path(@conversation), method: :patch, class: "rounded-lg border px-3 py-2 text-sm font-bold text-slate-700" %>
      <% end %>
    </div>
  </div>

  <section class="rounded-2xl border bg-white p-5 shadow-sm">
    <h1 class="text-2xl font-black text-slate-900"><%= @conversation.display_subject %></h1>
    <div id="messages" class="mt-4 max-h-[28rem] space-y-3 overflow-y-auto rounded-2xl bg-slate-50 p-4">
      <% @messages.each do |message| %>
        <%= render "messages/message", message: message %>
      <% end %>
    </div>
    <%= form_with(url: admin_support_conversation_messages_path(@conversation), model: @message, scope: :message, data: { turbo: true }, id: "message_form", class: "mt-4 space-y-3") do |form| %>
      <%= form.text_area :body, rows: 3, required: true, class: "block w-full rounded-xl border px-3 py-2.5 text-sm" %>
      <label class="flex items-center gap-2 text-sm font-semibold text-slate-700">
        <%= check_box_tag "message[internal_only]", "1", false, class: "rounded border-slate-300 text-indigo-600" %>
        Internal note (operators only)
      </label>
      <%= form.submit "Send reply", class: "rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white" %>
    <% end %>
  </section>
</div>
