<div class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm">
  <% form_url = @payslip.persisted? ? admin_accounting_payroll_run_payslip_path(@payroll_run, @payslip) : admin_accounting_payroll_run_payslips_path(@payroll_run) %>
  <%= form_with model: @payslip, url: form_url, class: "space-y-5" do |f| %>
    <% if @payslip.errors.any? %>
      <div class="rounded-xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800"><%= @payslip.errors.full_messages.to_sentence %></div>
    <% end %>

    <div class="grid gap-5 min-[1025px]:grid-cols-2">
      <div>
        <%= f.label :employee_id, "Employee", class: "mb-2 block text-sm font-medium text-slate-900" %>
        <%= f.collection_select :employee_id, @employees, :id, :email, { prompt: "Select employee" }, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
      </div>
      <div>
        <%= f.label :payment_date, class: "mb-2 block text-sm font-medium text-slate-900" %>
        <%= f.date_field :payment_date, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
      </div>
      <div>
        <%= f.label :base_salary, "Base salary (£)", class: "mb-2 block text-sm font-medium text-slate-900" %>
        <%= f.number_field :base_salary, step: 0.01, min: 0, value: (@payslip.base_salary if @payslip.persisted?), class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
      </div>
      <div>
        <%= f.label :bonus, "Bonus (£)", class: "mb-2 block text-sm font-medium text-slate-900" %>
        <%= f.number_field :bonus, step: 0.01, min: 0, value: (@payslip.bonus if @payslip.persisted?), class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
      </div>
      <div>
        <%= f.label :commission, "Commission (£)", class: "mb-2 block text-sm font-medium text-slate-900" %>
        <%= f.number_field :commission, step: 0.01, min: 0, value: (@payslip.commission if @payslip.persisted?), class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
      </div>
      <div>
        <%= f.label :deductions, "Deductions (£)", class: "mb-2 block text-sm font-medium text-slate-900" %>
        <%= f.number_field :deductions, step: 0.01, min: 0, value: (@payslip.deductions if @payslip.persisted?), class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :notes, class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.text_area :notes, rows: 2, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
    </div>

    <%= f.submit class: "rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30" %>
  <% end %>
</div>
