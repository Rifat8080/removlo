<div class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm">
  <% form_url = @category.persisted? ? admin_accounting_category_path(@category) : admin_accounting_categories_path %>
  <%= form_with model: @category, url: form_url, class: "space-y-5" do |f| %>
    <% if @category.errors.any? %>
      <div class="rounded-xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800"><%= @category.errors.full_messages.to_sentence %></div>
    <% end %>

    <div>
      <%= f.label :name, class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.text_field :name, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>

    <div>
      <%= f.label :slug, class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.text_field :slug, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>

    <div>
      <%= f.label :category_type, class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.select :category_type, AccountingCategory.category_types.keys.map { |k| [k.humanize, k] }, {}, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>

    <div>
      <%= f.label :description, class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.text_area :description, rows: 3, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>

    <%= f.submit class: "rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30" %>
  <% end %>
</div>
