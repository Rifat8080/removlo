<% content_for(:title, "Transactions — Accounting") %>

<div class="mb-6 flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
  <div>
    <%= link_to "← Accounting", admin_accounting_root_path, class: "text-sm font-semibold text-indigo-600" %>
    <h1 class="mt-2 text-2xl font-extrabold text-slate-900">Transactions</h1>
  </div>
  <%= link_to "New transaction", new_admin_accounting_transaction_path, class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30" %>
</div>

<div class="mb-6 rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm">
  <%= form_with url: admin_accounting_transactions_path, method: :get, local: true, class: "grid gap-4 min-[1025px]:grid-cols-4" do %>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase text-slate-500">Type</label>
      <%= select_tag :type, options_for_select([["All", ""]] + AccountingTransaction.transaction_types.keys.map { |k| [k.humanize, k] }, params[:type]), class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-2.5 text-sm" %>
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase text-slate-500">Category</label>
      <%= select_tag :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]), include_blank: "All", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-2.5 text-sm" %>
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase text-slate-500">Start date</label>
      <%= date_field_tag :start_date, params[:start_date], class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-2.5 text-sm" %>
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase text-slate-500">End date</label>
      <%= date_field_tag :end_date, params[:end_date], class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-2.5 text-sm" %>
    </div>
    <div class="min-[1025px]:col-span-4">
      <%= submit_tag "Filter", class: "rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white" %>
    </div>
  <% end %>
</div>

<% if @summary %>
  <div class="mb-6 grid gap-4 sm:grid-cols-2 min-[1025px]:grid-cols-4">
    <% [["Income", @summary[:income_cents], "text-emerald-700"], ["Expenses", @summary[:expense_cents], "text-rose-700"], ["Total revenue", @summary[:total_revenue_cents], "text-indigo-700"]].each do |label, cents, color| %>
      <div class="rounded-2xl border border-slate-200/80 bg-white p-4 shadow-sm">
        <p class="text-sm text-slate-500"><%= label %></p>
        <p class="mt-1 text-xl font-extrabold <%= color %>"><%= money_from_cents(cents) %></p>
      </div>
    <% end %>
  </div>
<% end %>

<div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm">
  <div class="divide-y divide-slate-100">
    <% @transactions.each do |transaction| %>
      <div class="grid gap-3 px-5 py-4 min-[1025px]:grid-cols-[1fr_auto_auto] min-[1025px]:items-center">
        <div>
          <div class="flex flex-wrap items-center gap-2">
            <%= accounting_transaction_badge(transaction.transaction_type) %>
            <p class="font-semibold text-slate-900"><%= transaction.description.presence || "Transaction" %></p>
          </div>
          <p class="mt-1 text-xs text-slate-400"><%= transaction.transaction_date.strftime("%d %b %Y") %> · <%= transaction.accounting_category&.name %></p>
        </div>
        <%= accounting_amount(transaction.amount_cents, transaction.transaction_type) %>
        <%= link_to "View", admin_accounting_transaction_path(transaction), class: "rounded-lg border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
      </div>
    <% end %>
    <% if @transactions.empty? %>
      <div class="px-5 py-12 text-center text-sm text-slate-500">No transactions found.</div>
    <% end %>
  </div>
</div>
