<% content_for(:title, "Accounting — Removlo") %>

<div class="mb-6 flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
  <div>
    <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Admin</p>
    <h1 class="mt-1 text-2xl font-extrabold tracking-tight text-slate-900">Accounting</h1>
    <p class="mt-1 text-sm text-slate-500">Track income, expenses, payroll, invoices, and profit.</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "New transaction", new_admin_accounting_transaction_path, class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30 transition hover:-translate-y-0.5" %>
    <%= link_to "Reports", admin_accounting_reports_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
  </div>
</div>

<div class="mb-6 grid gap-4 sm:grid-cols-2 min-[1025px]:grid-cols-4">
  <% [
    ["Total income", @summary[:income_cents], "text-emerald-700"],
    ["Total expenses", @summary[:expense_cents], "text-rose-700"],
    ["Payroll", @summary[:payroll_cents], "text-indigo-700"],
    ["Net profit / loss", @summary[:net_profit_cents], @summary[:net_profit_cents].to_i >= 0 ? "text-emerald-700" : "text-rose-700"]
  ].each do |label, cents, color| %>
    <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-slate-500"><%= label %></p>
      <p class="mt-2 text-2xl font-extrabold <%= color %>"><%= money_from_cents(cents) %></p>
    </div>
  <% end %>
</div>

<div class="mb-6 grid gap-4 min-[1025px]:grid-cols-3">
  <% [
    ["This month income", @month_summary[:income_cents], "text-emerald-700"],
    ["This month expenses", @month_summary[:expense_cents], "text-rose-700"],
    ["This month net", @month_summary[:net_profit_cents], @month_summary[:net_profit_cents].to_i >= 0 ? "text-emerald-700" : "text-rose-700"]
  ].each do |label, cents, color| %>
    <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-slate-500"><%= label %></p>
      <p class="mt-2 text-xl font-extrabold <%= color %>"><%= money_from_cents(cents) %></p>
    </div>
  <% end %>
</div>

<div class="mb-6 flex flex-wrap gap-2">
  <%= link_to "Transactions", admin_accounting_transactions_path, class: "rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
  <%= link_to "Categories", admin_accounting_categories_path, class: "rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
  <%= link_to "Invoices", admin_accounting_customer_invoices_path, class: "rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
  <%= link_to "Payroll", admin_accounting_payroll_runs_path, class: "rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
</div>

<div class="grid gap-6 min-[1025px]:grid-cols-2">
  <div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4 flex items-center justify-between">
      <h2 class="text-lg font-bold text-slate-900">Recent transactions</h2>
      <%= link_to "View all", admin_accounting_transactions_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-700" %>
    </div>
    <div class="divide-y divide-slate-100">
      <% @recent_transactions.each do |transaction| %>
        <div class="flex items-center justify-between gap-4 px-5 py-4">
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <%= accounting_transaction_badge(transaction.transaction_type) %>
              <p class="truncate font-semibold text-slate-900"><%= transaction.description.presence || transaction.reference %></p>
            </div>
            <p class="mt-1 text-xs text-slate-400"><%= transaction.transaction_date.strftime("%d %b %Y") %></p>
          </div>
          <%= accounting_amount(transaction.amount_cents, transaction.transaction_type) %>
        </div>
      <% end %>
      <% if @recent_transactions.empty? %>
        <div class="px-5 py-10 text-center text-sm text-slate-500">No transactions yet.</div>
      <% end %>
    </div>
  </div>

  <div class="space-y-6">
    <div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4 flex items-center justify-between">
        <h2 class="text-lg font-bold text-slate-900">Unpaid invoices</h2>
        <%= link_to "View all", admin_accounting_customer_invoices_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-700" %>
      </div>
      <div class="divide-y divide-slate-100">
        <% @unpaid_invoices.each do |invoice| %>
          <div class="flex items-center justify-between gap-4 px-5 py-4">
            <div>
              <p class="font-semibold text-slate-900"><%= invoice.invoice_number %></p>
              <p class="text-xs text-slate-400"><%= invoice.customer.email %></p>
            </div>
            <span class="font-semibold text-slate-900"><%= money_from_cents(invoice.amount_cents) %></span>
          </div>
        <% end %>
        <% if @unpaid_invoices.empty? %>
          <div class="px-5 py-10 text-center text-sm text-slate-500">No unpaid invoices.</div>
        <% end %>
      </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4 flex items-center justify-between">
        <h2 class="text-lg font-bold text-slate-900">Recent payslips</h2>
        <%= link_to "Payroll runs", admin_accounting_payroll_runs_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-700" %>
      </div>
      <div class="divide-y divide-slate-100">
        <% @recent_payslips.each do |payslip| %>
          <div class="flex items-center justify-between gap-4 px-5 py-4">
            <div>
              <p class="font-semibold text-slate-900"><%= payslip.employee.email %></p>
              <p class="text-xs text-slate-400"><%= payslip.payroll_run.period_label %></p>
            </div>
            <span class="font-semibold text-indigo-700"><%= money_from_cents(payslip.net_pay_cents) %></span>
          </div>
        <% end %>
        <% if @recent_payslips.empty? %>
          <div class="px-5 py-10 text-center text-sm text-slate-500">No payslips yet.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
