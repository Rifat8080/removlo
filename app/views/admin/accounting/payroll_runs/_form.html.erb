<div class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm">
  <% form_url = @payroll_run.persisted? ? admin_accounting_payroll_run_path(@payroll_run) : admin_accounting_payroll_runs_path %>
  <%= form_with model: @payroll_run, url: form_url, class: "space-y-5" do |f| %>
    <% if @payroll_run.errors.any? %>
      <div class="rounded-xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800"><%= @payroll_run.errors.full_messages.to_sentence %></div>
    <% end %>

    <div class="grid gap-5 min-[1025px]:grid-cols-2">
      <div>
        <%= f.label :period_start, class: "mb-2 block text-sm font-medium text-slate-900" %>
        <%= f.date_field :period_start, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
      </div>
      <div>
        <%= f.label :period_end, class: "mb-2 block text-sm font-medium text-slate-900" %>
        <%= f.date_field :period_end, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :notes, class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.text_area :notes, rows: 3, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm" %>
    </div>

    <%= f.submit class: "rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30" %>
  <% end %>
</div>
