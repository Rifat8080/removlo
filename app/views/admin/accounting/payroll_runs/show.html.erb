<% content_for(:title, "Payroll #{@payroll_run.period_label} — Accounting") %>

<div class="mb-6 flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
  <div>
    <%= link_to "← Payroll runs", admin_accounting_payroll_runs_path, class: "text-sm font-semibold text-indigo-600" %>
    <h1 class="mt-2 text-2xl font-extrabold text-slate-900"><%= @payroll_run.period_label %></h1>
    <div class="mt-2"><%= payroll_status_badge(@payroll_run.status) %></div>
  </div>
  <div class="flex flex-wrap gap-2">
    <% unless @payroll_run.paid? %>
      <%= link_to "Add payslip", new_admin_accounting_payroll_run_payslip_path(@payroll_run), class: "rounded-lg bg-indigo-50 px-3 py-2 text-sm font-semibold text-indigo-700" %>
      <%= link_to "Edit", edit_admin_accounting_payroll_run_path(@payroll_run), class: "rounded-lg border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700" %>
    <% end %>
    <% if @payroll_run.draft? %>
      <%= button_to "Finalize", finalize_admin_accounting_payroll_run_path(@payroll_run), method: :patch, class: "rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white" %>
    <% end %>
    <% if @payroll_run.finalized? %>
      <%= button_to "Mark as paid", mark_paid_admin_accounting_payroll_run_path(@payroll_run), method: :patch, data: { turbo_confirm: "Record payroll expenses and notify employees?" }, class: "rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white" %>
    <% end %>
  </div>
</div>

<div class="mb-6 rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm">
  <p class="text-sm text-slate-500">Total net pay</p>
  <p class="mt-1 text-3xl font-extrabold text-indigo-700"><%= money_from_cents(@payroll_run.total_net_pay_cents) %></p>
  <% if @payroll_run.notes.present? %>
    <p class="mt-3 text-sm text-slate-600"><%= @payroll_run.notes %></p>
  <% end %>
</div>

<div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm">
  <div class="border-b border-slate-100 px-5 py-4"><h2 class="text-lg font-bold text-slate-900">Payslips</h2></div>
  <div class="divide-y divide-slate-100">
    <% @payslips.each do |payslip| %>
      <div class="grid gap-3 px-5 py-4 min-[1025px]:grid-cols-[1fr_auto_auto] min-[1025px]:items-center">
        <div>
          <p class="font-semibold text-slate-900"><%= payslip.employee.email %></p>
          <p class="text-xs text-slate-400 capitalize"><%= payslip.employee_role %> · Base <%= money_from_cents(payslip.base_salary_cents) %> · Commission <%= money_from_cents(payslip.commission_cents) %></p>
        </div>
        <span class="font-semibold text-indigo-700"><%= money_from_cents(payslip.net_pay_cents) %></span>
        <div class="flex flex-wrap gap-2">
          <%= link_to "Export PDF", pdf_admin_accounting_payroll_run_payslip_path(@payroll_run, payslip), class: "rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-800" %>
          <% unless @payroll_run.paid? %>
            <%= link_to "Edit", edit_admin_accounting_payroll_run_payslip_path(@payroll_run, payslip), class: "rounded-lg border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
          <% end %>
        </div>
      </div>
    <% end %>
    <% if @payslips.empty? %>
      <div class="px-5 py-12 text-center text-sm text-slate-500">Add payslips to this run.</div>
    <% end %>
  </div>
</div>
