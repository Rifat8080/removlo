<% content_for(:title, "#{@user.email} — Removlo") %>

<div class="mb-6 flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
  <div>
    <%= link_to "← Back to users", admin_users_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-700" %>
    <h1 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900"><%= @user.email %></h1>
    <div class="mt-2 flex flex-wrap items-center gap-2">
      <%= render "role_badge", user: @user %>
      <% if @user == current_user %>
        <span class="rounded-full bg-indigo-50 px-2.5 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-indigo-200">Current user</span>
      <% end %>
    </div>
  </div>

  <div class="flex flex-col gap-2 min-[1025px]:flex-row">
    <%= link_to "Edit user", edit_admin_user_path(@user), class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30 transition hover:-translate-y-0.5 hover:shadow-xl" %>
    <%= link_to "All users", admin_users_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
  </div>
</div>

<div class="grid gap-6 min-[1025px]:grid-cols-3">
  <div class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm min-[1025px]:col-span-2">
    <h2 class="text-lg font-bold text-slate-900">Profile details</h2>

    <dl class="mt-6 grid gap-4">
      <div class="rounded-xl bg-slate-50 p-4">
        <dt class="text-xs font-semibold uppercase tracking-wide text-slate-400">Email</dt>
        <dd class="mt-1 font-semibold text-slate-900"><%= @user.email %></dd>
      </div>
      <div class="rounded-xl bg-slate-50 p-4">
        <dt class="text-xs font-semibold uppercase tracking-wide text-slate-400">Role</dt>
        <dd class="mt-2"><%= render "role_badge", user: @user %></dd>
      </div>
      <div class="rounded-xl bg-slate-50 p-4">
        <dt class="text-xs font-semibold uppercase tracking-wide text-slate-400">Created</dt>
        <dd class="mt-1 font-semibold text-slate-900"><%= @user.created_at.strftime("%d %B %Y, %H:%M") %></dd>
      </div>
      <div class="rounded-xl bg-slate-50 p-4">
        <dt class="text-xs font-semibold uppercase tracking-wide text-slate-400">Last updated</dt>
        <dd class="mt-1 font-semibold text-slate-900"><%= @user.updated_at.strftime("%d %B %Y, %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <div class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-bold text-slate-900">Danger zone</h2>
    <p class="mt-2 text-sm text-slate-500">Deleting a user removes their account permanently.</p>

    <%= button_to "Delete user", admin_user_path(@user), method: :delete, data: { turbo_confirm: "Delete #{@user.email}? This cannot be undone." }, disabled: @user == current_user, class: "mt-5 w-full cursor-pointer rounded-xl border border-red-200 bg-red-50 px-5 py-3 text-sm font-semibold text-red-700 transition hover:bg-red-600 hover:text-white disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:bg-red-50 disabled:hover:text-red-700" %>
    <% if @user == current_user %>
      <p class="mt-2 text-xs text-slate-400">You cannot delete your own admin account.</p>
    <% end %>
  </div>
</div>
