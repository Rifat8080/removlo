<%= form_with(model: [:admin, user], class: "space-y-6") do |f| %>
  <% if user.errors.any? %>
    <div class="rounded-2xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      <p class="font-semibold text-red-800"><%= pluralize(user.errors.count, "error") %> prevented this user from being saved:</p>
      <ul class="mt-2 list-inside list-disc space-y-1">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-5 min-[1025px]:grid-cols-2">
    <div>
      <%= f.label :email, "Email address", class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.email_field :email, autocomplete: "email", placeholder: "customer@example.com", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>

    <div>
      <%= f.label :role, class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.select :role, User.roles.keys.map { |role| [role.titleize, role] }, {}, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-3 text-sm capitalize text-slate-900 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>
  </div>

  <div class="grid gap-5 min-[1025px]:grid-cols-2">
    <div>
      <%= f.label :password, user.persisted? ? "New password" : "Password", class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: user.persisted? ? "Leave blank to keep current" : "Minimum 6 characters", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
      <% if user.persisted? %>
        <p class="mt-1.5 text-xs text-slate-400">Leave blank if you do not want to change the password.</p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm password", class: "mb-2 block text-sm font-medium text-slate-900" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Repeat password", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>
  </div>

  <div class="flex flex-col gap-3 border-t border-slate-100 pt-6 min-[1025px]:flex-row">
    <%= f.submit user.persisted? ? "Save changes" : "Create user", class: "cursor-pointer rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30 transition hover:-translate-y-0.5 hover:shadow-xl hover:shadow-indigo-600/40 focus:outline-none focus:ring-4 focus:ring-indigo-300 min-[1025px]:w-auto" %>
    <%= link_to "Cancel", admin_users_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
  </div>
<% end %>
