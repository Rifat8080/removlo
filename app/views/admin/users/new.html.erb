<% content_for(:title, "New user — Removlo") %>

<div class="mx-auto max-w-4xl">
  <div class="mb-6">
    <%= link_to "← Back to users", admin_users_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-700" %>
    <h1 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900">Create user</h1>
    <p class="mt-1 text-sm text-slate-500">Add a new admin, staff member, or customer account.</p>
  </div>

  <div class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm min-[1025px]:p-8">
    <%= render "form", user: @user %>
  </div>
</div>
