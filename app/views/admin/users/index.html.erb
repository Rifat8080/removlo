<% content_for(:title, "Users — Removlo") %>

<div class="mb-6 flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
  <div>
    <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Admin</p>
    <h1 class="mt-1 text-2xl font-extrabold tracking-tight text-slate-900">Users</h1>
    <p class="mt-1 text-sm text-slate-500">Manage admins, staff, and customers from one workspace.</p>
  </div>

  <%= link_to new_admin_user_path, class: "inline-flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30 transition hover:-translate-y-0.5 hover:shadow-xl min-[1025px]:w-auto" do %>
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New user
  <% end %>
</div>

<div class="mb-6 grid gap-4 min-[1025px]:grid-cols-3">
  <% User.roles.keys.each do |role| %>
    <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium capitalize text-slate-500"><%= role %></p>
      <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @role_counts.fetch(role, 0) %></p>
    </div>
  <% end %>
</div>

<div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm">
  <div class="border-b border-slate-100 px-5 py-4">
    <h2 class="text-lg font-bold text-slate-900">All users</h2>
  </div>

  <div class="divide-y divide-slate-100">
    <% @users.each do |user| %>
      <div class="grid gap-4 px-5 py-4 min-[1025px]:grid-cols-[1fr_auto_auto] min-[1025px]:items-center">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <p class="truncate font-semibold text-slate-900"><%= user.email %></p>
            <%= render "role_badge", user: user %>
            <% if user == current_user %>
              <span class="rounded-full bg-indigo-50 px-2.5 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-indigo-200">You</span>
            <% end %>
          </div>
          <p class="mt-1 text-xs text-slate-400">Joined <%= user.created_at.strftime("%d %b %Y") %></p>
        </div>

        <div class="text-sm text-slate-500">
          Updated <%= time_ago_in_words(user.updated_at) %> ago
        </div>

        <div class="flex flex-wrap gap-2">
          <%= link_to "View", admin_user_path(user), class: "rounded-lg border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
          <%= link_to "Edit", edit_admin_user_path(user), class: "rounded-lg bg-indigo-50 px-3 py-2 text-sm font-semibold text-indigo-700 transition hover:bg-indigo-100" %>
        </div>
      </div>
    <% end %>

    <% if @users.empty? %>
      <div class="px-5 py-12 text-center">
        <p class="font-semibold text-slate-900">No users yet</p>
        <p class="mt-1 text-sm text-slate-500">Create the first account to start managing access.</p>
      </div>
    <% end %>
  </div>
</div>
