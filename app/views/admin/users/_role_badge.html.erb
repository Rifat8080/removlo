<% badge_classes = {
  "admin" => "bg-red-50 text-red-700 ring-red-200",
  "staff" => "bg-amber-50 text-amber-700 ring-amber-200",
  "customer" => "bg-emerald-50 text-emerald-700 ring-emerald-200"
} %>

<span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold capitalize ring-1 <%= badge_classes.fetch(user.role, 'bg-slate-50 text-slate-700 ring-slate-200') %>">
  <%= user.role %>
</span>
