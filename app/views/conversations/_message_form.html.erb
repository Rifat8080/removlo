<%= form_with(model: [conversation, message], data: { turbo: true }, id: "message_form", class: "mt-4 flex gap-2") do |form| %>
  <%= form.text_area :body, rows: 2, required: true, placeholder: "Type your message...", class: "block w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  <%= form.submit "Send", class: "shrink-0 rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white" %>
<% end %>
