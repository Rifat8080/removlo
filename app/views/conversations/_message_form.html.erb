<% form_url = local_assigns[:url] || [conversation, message] %>
<% show_internal_option = local_assigns.fetch(:internal_only_option, false) %>

<%= form_with(model: message, url: form_url, scope: :message, data: { turbo: true }, id: dom_id(conversation, :message_form), class: "mt-4 space-y-3") do |form| %>
  <% if message.errors.any? %>
    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">
      <%= message.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="rounded-3xl border border-slate-200 bg-white p-2 shadow-sm transition focus-within:border-indigo-300 focus-within:ring-4 focus-within:ring-indigo-100">
    <%= form.text_area :body, rows: 2, required: true, maxlength: 4000, placeholder: "Write a message...", class: "block max-h-40 min-h-20 w-full resize-y rounded-2xl border-0 bg-slate-50 px-4 py-3 text-sm leading-6 text-slate-900 placeholder-slate-400 focus:bg-white focus:ring-0" %>
    <div class="mt-2 flex flex-col gap-3 border-t border-slate-100 pt-2 sm:flex-row sm:items-center sm:justify-between">
      <p class="px-2 text-xs font-medium text-slate-400">Messages are private to this conversation.</p>
      <%= form.submit "Send message", class: "inline-flex cursor-pointer items-center justify-center rounded-2xl bg-indigo-600 px-5 py-2.5 text-sm font-black text-white shadow-lg shadow-indigo-600/20 transition hover:-translate-y-0.5 hover:bg-indigo-700 focus:outline-none focus:ring-4 focus:ring-indigo-200" %>
    </div>
  </div>

  <% if show_internal_option %>
    <label class="inline-flex items-center gap-2 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-800">
      <%= check_box_tag "message[internal_only]", "1", false, class: "rounded border-slate-300 text-indigo-600" %>
      Internal note (operators only)
    </label>
  <% end %>
<% end %>
