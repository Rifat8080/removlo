<% content_for :title, "Messages — Removlo" %>
<%= render "messages/alert_stream" %>

<div class="mx-auto max-w-5xl space-y-6">
  <div class="overflow-hidden rounded-3xl bg-gradient-to-br from-slate-950 via-indigo-950 to-blue-900 p-6 text-white shadow-2xl shadow-indigo-950/20">
    <div class="flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-indigo-200">Inbox</p>
        <h1 class="mt-2 text-3xl font-black tracking-tight">Messages</h1>
        <p class="mt-2 text-sm text-slate-300">Job chat and support conversations in one place.</p>
      </div>
      <%= button_to "Contact support", conversations_path, method: :post, params: { conversation: { subject: "Support request" } }, class: "rounded-xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 transition hover:bg-indigo-50" %>
    </div>
  </div>

  <div class="space-y-3">
    <% @conversations.each do |conversation| %>
      <% visible_messages = conversation.messages.reject(&:internal_only?) %>
      <% last_message = visible_messages.max_by(&:created_at) %>
      <% unread = conversation.unread_for?(current_user) %>
      <%= link_to conversation_path(conversation), class: "group block rounded-3xl border bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 hover:shadow-lg #{unread ? 'border-indigo-200 ring-4 ring-indigo-50' : 'border-slate-200'}" do %>
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl <%= conversation.job? ? 'bg-blue-100 text-blue-700' : 'bg-indigo-100 text-indigo-700' %>">
            <% if conversation.job? %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0zM13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1h2m-2 0V8h4l3 3v5h-2"/></svg>
            <% else %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M12 3v3m0 12v3m9-9h-3M6 12H3"/></svg>
            <% end %>
          </div>
          <div class="min-w-0 flex-1">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="truncate font-black text-slate-900 group-hover:text-indigo-700"><%= conversation.display_subject %></p>
                <p class="mt-1 text-sm text-slate-500">
                  <% if last_message %>
                    <span class="font-semibold"><%= last_message.sender_label %>:</span>
                    <%= truncate(last_message.body, length: 96) %>
                  <% else %>
                    No messages yet.
                  <% end %>
                </p>
              </div>
              <% if unread %>
                <span class="shrink-0 rounded-full bg-rose-500 px-2.5 py-1 text-xs font-black text-white">New</span>
              <% end %>
            </div>
            <div class="mt-3 flex flex-wrap items-center gap-2 text-xs font-bold text-slate-400">
              <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-600"><%= conversation.kind.humanize %></span>
              <span class="rounded-full px-2.5 py-1 <%= conversation.open? ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-600' %>"><%= conversation.status.humanize %></span>
              <% if last_message %>
                <span><%= time_ago_in_words(last_message.created_at) %> ago</span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
    <% if @conversations.empty? %>
      <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center shadow-sm">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
        </div>
        <p class="mt-4 text-sm font-black text-slate-900">No conversations yet</p>
        <p class="mt-1 text-sm text-slate-500">Start with support or open a job chat when a move is confirmed.</p>
      </div>
    <% end %>
  </div>
</div>
