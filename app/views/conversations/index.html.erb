<% content_for :title, "Messages — Removlo" %>

<div class="mx-auto max-w-5xl space-y-6">
  <div class="flex flex-col gap-4 min-[1025px]:flex-row min-[1025px]:items-center min-[1025px]:justify-between">
    <div>
      <h1 class="text-3xl font-black text-slate-900">Messages</h1>
      <p class="mt-2 text-sm text-slate-500">Job chat and support conversations in one place.</p>
    </div>
    <%= button_to "Contact support", conversations_path, method: :post, params: { conversation: { subject: "Support request" } }, class: "rounded-xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white" %>
  </div>

  <div class="space-y-3">
    <% @conversations.each do |conversation| %>
      <%= link_to conversation_path(conversation), class: "block rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-indigo-200" do %>
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="font-bold text-slate-900"><%= conversation.display_subject %></p>
            <p class="text-sm text-slate-500"><%= conversation.kind.humanize %> · <%= conversation.status.humanize %></p>
          </div>
          <% if conversation.unread_for?(current_user) %>
            <span class="rounded-full bg-rose-500 px-2 py-1 text-xs font-bold text-white">New</span>
          <% end %>
        </div>
      <% end %>
    <% end %>
    <% if @conversations.empty? %>
      <p class="rounded-2xl border border-dashed border-slate-200 bg-white p-8 text-center text-sm text-slate-500">No conversations yet.</p>
    <% end %>
  </div>
</div>
