<% selected_role = %w[customer driver].include?(resource.role.to_s) ? resource.role : "customer" %>
<% account_roles = [
  {
    role: "customer",
    label: "Customer",
    eyebrow: "I need a move",
    description: "Request quotes, pay deposits, track bookings, and message the Removlo team.",
    bullets: ["Quote and booking dashboard", "Deposit-protected job chat", "Invoices and support in one place"]
  },
  {
    role: "driver",
    label: "Driver",
    eyebrow: "I provide moves",
    description: "See available jobs, submit offers, set availability, and manage earnings.",
    bullets: ["Driver job workspace", "Offer and availability tools", "Wallet, payouts, and payslips"]
  }
] %>
<% content_for(:title, "#{selected_role == "driver" ? "Driver sign up" : "Customer sign up"} — Removlo") %>

<div data-controller="signup-role">
<div class="mb-8">
  <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-indigo-100 bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">Free · Role-based dashboard</span>
  <h1 class="text-3xl font-extrabold tracking-tight text-slate-900" data-signup-role-target="title"><%= selected_role == "driver" ? "Join Removlo as a driver" : "Create your customer account" %></h1>
  <p class="mt-2 text-sm text-slate-500" data-signup-role-target="subtitle"><%= selected_role == "driver" ? "Receive moving jobs, submit offers, manage availability, and track payouts." : "Get quotes, pay deposits, message support, and track your move from start to finish." %></p>
</div>

<%= render "devise/shared/error_messages", resource: resource %>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
  <fieldset>
    <legend class="mb-3 block text-sm font-medium text-slate-900">Choose account type</legend>
    <div class="grid gap-3 sm:grid-cols-2">
      <% account_roles.each do |account| %>
        <label data-signup-role-target="card" data-role="<%= account[:role] %>" data-action="click->signup-role#select keydown.enter->signup-role#select" class="cursor-pointer rounded-2xl border p-4 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/60 <%= selected_role == account[:role] ? "border-indigo-500 bg-indigo-50 shadow-indigo-100" : "border-slate-200 bg-white" %>">
          <div class="flex items-start gap-3">
            <%= f.radio_button :role, account[:role], checked: selected_role == account[:role], data: { action: "change->signup-role#refresh" }, class: "mt-1 h-4 w-4 border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
            <div>
              <p class="text-xs font-bold uppercase tracking-wide text-indigo-600"><%= account[:eyebrow] %></p>
              <p class="mt-1 text-sm font-extrabold text-slate-900"><%= account[:label] %></p>
              <p class="mt-1 text-xs leading-5 text-slate-500"><%= account[:description] %></p>
            </div>
          </div>
        </label>
      <% end %>
    </div>
  </fieldset>

  <% account_roles.each do |account| %>
    <div data-signup-role-target="panel" data-role="<%= account[:role] %>" class="<%= "hidden" unless selected_role == account[:role] %> rounded-2xl border border-slate-200 bg-slate-50 p-4">
      <p class="text-sm font-bold text-slate-900"><%= account[:label] %> account includes</p>
      <ul class="mt-3 space-y-2">
        <% account[:bullets].each do |bullet| %>
          <li class="flex gap-2 text-sm text-slate-600">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-500"></span>
            <span><%= bullet %></span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :email, "Email address", class: "mb-2 block text-sm font-medium text-slate-900" %>
    <div class="relative">
      <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </span>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 py-3 pl-11 pr-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>
  </div>

  <div>
    <%= f.label :password, class: "mb-2 block text-sm font-medium text-slate-900" %>
    <div class="relative">
      <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      </span>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 py-3 pl-11 pr-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>
    <% if @minimum_password_length %>
      <p class="mt-1.5 text-xs text-slate-400"><%= @minimum_password_length %> characters minimum</p>
    <% end %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm password", class: "mb-2 block text-sm font-medium text-slate-900" %>
    <div class="relative">
      <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </span>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 py-3 pl-11 pr-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>
  </div>

  <%= f.submit selected_role == "driver" ? "Create driver account" : "Create customer account", data: { signup_role_target: "submit" }, class: "w-full cursor-pointer rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3.5 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30 transition hover:shadow-xl hover:shadow-indigo-600/40 focus:outline-none focus:ring-4 focus:ring-indigo-300" %>

  <p class="text-center text-xs text-slate-400">By creating an account you agree to our <a href="#" class="font-medium text-slate-500 hover:text-indigo-600">Terms</a> and <a href="#" class="font-medium text-slate-500 hover:text-indigo-600">Privacy Policy</a>.</p>
<% end %>

<div class="mt-8 border-t border-slate-100 pt-6 text-center text-sm text-slate-500">
  Already have an account?
  <%= link_to "Sign in", new_session_path(resource_name), class: "font-semibold text-indigo-600 transition hover:text-indigo-700" %>
</div>
</div>
