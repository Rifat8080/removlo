<% content_for(:title, "Sign in — Removlo") %>

<%= render "devise/shared/brand_header", tagline: "Welcome back to Removlo" %>

<div class="mb-8">
  <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-indigo-100 bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">Welcome back</span>
  <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Sign in to Removlo</h1>
  <p class="mt-2 text-sm text-slate-500">Track your quotes and manage your move in one place.</p>
</div>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
  <div>
    <%= f.label :email, "Email address", class: "mb-2 block text-sm font-medium text-slate-900" %>
    <div class="relative">
      <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </span>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 py-3 pl-11 pr-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>
  </div>

  <div>
    <div class="mb-2 flex items-center justify-between">
      <%= f.label :password, class: "block text-sm font-medium text-slate-900" %>
      <% if devise_mapping.recoverable? %>
        <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs font-semibold text-indigo-600 hover:text-indigo-700" %>
      <% end %>
    </div>
    <div class="relative">
      <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      </span>
      <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 py-3 pl-11 pr-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-200" %>
    </div>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center">
      <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
      <%= f.label :remember_me, "Remember me for 30 days", class: "ml-2 text-sm text-slate-600" %>
    </div>
  <% end %>

  <%= f.submit "Sign in", class: "w-full cursor-pointer rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 px-5 py-3.5 text-sm font-semibold text-white shadow-lg shadow-indigo-600/30 transition hover:shadow-xl hover:shadow-indigo-600/40 focus:outline-none focus:ring-4 focus:ring-indigo-300" %>
<% end %>

<div class="mt-8 border-t border-slate-100 pt-6 text-center text-sm text-slate-500">
  Don't have an account?
  <%= link_to "Create one for free", new_registration_path(resource_name), class: "font-semibold text-indigo-600 transition hover:text-indigo-700" %>
</div>
